<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:XuLyDonShopee.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1480" d:DesignHeight="860"
             x:Class="XuLyDonShopee.App.Views.MainView"
             x:DataType="vm:MainViewModel"
             FontFamily="{StaticResource UiFont}">

    <!-- ═══ Cô lập tài nguyên/style của module vào ĐÚNG subtree này (không đổ vào Application của suite) ═══
         Trước đây (app độc lập) Colors.axaml + 6 converter + Controls.axaml nằm ở App.axaml cấp Application.
         Nay app là module của Shopee.Suite: khai báo tại UserControl để orange/converter/class của đơn hàng
         KHÔNG đè lên (và không bị đè bởi) Theme.axaml của suite — 2 bên trùng key AccentBrush/SuccessBrush/… -->
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://XuLyDonShopee.App/Styles/ModuleResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.Styles>
        <StyleInclude Source="avares://XuLyDonShopee.App/Styles/Controls.axaml" />
    </UserControl.Styles>

    <DockPanel>

        <!-- Nền gradient (trước là Window.Background) chuyển xuống DockPanel gốc của UserControl. -->
        <DockPanel.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#F7F8FA" />
                <GradientStop Offset="1" Color="#F0F2F5" />
            </LinearGradientBrush>
        </DockPanel.Background>

        <!-- (Thanh MENU NGANG cũ đã bỏ: 4 màn con nay điều hướng từ dải Ribbon của shell suite qua
             MainViewModel.SelectedNavIndex; màn Cài đặt dời sang tab Cài đặt chung.) -->

        <!-- ===== Thanh TRẠNG THÁI (đáy) ===== -->
        <Border DockPanel.Dock="Bottom" Classes="statusBar">
            <StackPanel Orientation="Horizontal" Spacing="14" Margin="16,0"
                        VerticalAlignment="Center">
                <TextBlock Classes="statusText" Text="{Binding StatusAccountsText}" />
                <TextBlock Classes="statusSep" Text="·" />
                <TextBlock Classes="statusText" Text="{Binding StatusOrdersText}" />
                <TextBlock Classes="statusSep" Text="·" />
                <TextBlock Classes="statusText" Text="{Binding StatusProxiesText}" />
                <TextBlock Classes="statusSep" Text="·" />
                <TextBlock Classes="statusText" Text="{Binding StatusBrowserText}" />
            </StackPanel>
        </Border>

        <!-- ===== Nội dung (full width) ===== -->
        <ContentControl Content="{Binding CurrentViewModel}" />
    </DockPanel>
</UserControl>
