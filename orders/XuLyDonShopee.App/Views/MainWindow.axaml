<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XuLyDonShopee.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1480" d:DesignHeight="860"
        x:Class="XuLyDonShopee.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1480" Height="860"
        MinWidth="1200" MinHeight="640"
        FontFamily="{StaticResource UiFont}"
        Icon="/Assets/avalonia-logo.ico"
        Title="Xử lý đơn Shopee">

    <Window.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#F7F8FA" />
            <GradientStop Offset="1" Color="#F0F2F5" />
        </LinearGradientBrush>
    </Window.Background>

    <DockPanel>

        <!-- ===== Thanh MENU NGANG (trên) ===== -->
        <Border DockPanel.Dock="Top" Classes="topbar">
            <Grid ColumnDefinitions="Auto,*">

                <!-- Tiêu đề app -->
                <TextBlock Grid.Column="0"
                           Text="Xử lý đơn Shopee"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource TextInk}"
                           VerticalAlignment="Center"
                           Margin="16,0,24,0" />

                <!-- Menu ngang: icon + nhãn nằm cạnh nhau, tab đang chọn nổi bật -->
                <ListBox Grid.Column="1"
                         Classes="navTop"
                         VerticalAlignment="Center"
                         ItemsSource="{Binding NavItems}"
                         SelectedIndex="{Binding SelectedNavIndex}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavItem">
                            <StackPanel Orientation="Horizontal" Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBlock Classes="nav-top-icon" Text="{Binding Icon}" />
                                <TextBlock Classes="nav-top-label" Text="{Binding Label}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ===== Thanh TRẠNG THÁI (đáy) ===== -->
        <Border DockPanel.Dock="Bottom" Classes="statusBar">
            <StackPanel Orientation="Horizontal" Spacing="14" Margin="16,0"
                        VerticalAlignment="Center">
                <TextBlock Classes="statusText" Text="{Binding StatusAccountsText}" />
                <TextBlock Classes="statusSep" Text="·" />
                <TextBlock Classes="statusText" Text="{Binding StatusOrdersText}" />
                <TextBlock Classes="statusSep" Text="·" />
                <TextBlock Classes="statusText" Text="{Binding StatusProxiesText}" />
                <TextBlock Classes="statusSep" Text="·" />
                <TextBlock Classes="statusText" Text="{Binding StatusBrowserText}" />
            </StackPanel>
        </Border>

        <!-- ===== Nội dung (full width) ===== -->
        <ContentControl Content="{Binding CurrentViewModel}" />
    </DockPanel>
</Window>
