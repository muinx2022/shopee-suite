@inherits LayoutComponentBase
@implements IDisposable
@inject FleetStateService Fleet
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="app">
    <nav class="side">
        <div class="brand">
            <div class="brand-logo">S</div>
            <div class="brand-text">
                <div class="brand-name">Shopee Hub</div>
                <div class="brand-sub">Fleet control</div>
            </div>
        </div>

        <div class="side-scroll">
            <div class="navsec">Điều khiển</div>
            <NavLink class="nav" href="/" Match="NavLinkMatch.All"><span class="nav-ic">@NavIcon("fleet")</span><span>Fleet</span></NavLink>
            <NavLink class="nav" href="/stats"><span class="nav-ic">@NavIcon("stats")</span><span>Thống kê</span></NavLink>
            <NavLink class="nav" href="/machines"><span class="nav-ic">@NavIcon("machines")</span><span>Máy client</span></NavLink>
            <NavLink class="nav" href="/search"><span class="nav-ic">@NavIcon("search")</span><span>Search</span></NavLink>

            <div class="navsec">Cấu hình</div>
            <NavLink class="nav" href="/config/bigseller"><span class="nav-ic">@NavIcon("bigseller")</span><span>BigSeller</span></NavLink>
            <NavLink class="nav" href="/config/accounts"><span class="nav-ic">@NavIcon("users")</span><span>Acc Shopee &amp; Proxy</span></NavLink>
            <NavLink class="nav" href="/config/errored"><span class="nav-ic">@NavIcon("alert")</span><span>Acc lỗi</span></NavLink>
            <NavLink class="nav" href="/config/ai"><span class="nav-ic">@NavIcon("ai")</span><span>AI</span></NavLink>

            <div class="navsec">Hệ thống</div>
            <NavLink class="nav" href="/settings"><span class="nav-ic">@NavIcon("settings")</span><span>Cài đặt</span></NavLink>
            <NavLink class="nav" href="/files"><span class="nav-ic">@NavIcon("files")</span><span>Files</span></NavLink>
            <NavLink class="nav" href="/logs-view"><span class="nav-ic">@NavIcon("logs")</span><span>Logs</span></NavLink>
        </div>

        <div class="side-foot">
            <div class="fleet-badge">
                <span class="fb-dot @(_online > 0 ? "on" : "")"></span>
                <span><b>@_online</b>/@_total máy online</span>
            </div>
        </div>
    </nav>

    <div class="main">
        <header class="topbar">
            <div class="topbar-title">@_pageTitle</div>
            <div class="topbar-right">
                <span class="topbar-user">👤 admin</span>
                <button class="theme-btn" title="Đổi sáng/tối" @onclick="ToggleTheme">
                    <svg class="ico-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                    <svg class="ico-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.5"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
                </button>
                <form method="post" action="/logout"><button class="btn sm danger" type="submit">↪ Đăng xuất</button></form>
            </div>
        </header>

        <main class="content">
            @Body
        </main>
    </div>
</div>

@code {
    private int _online, _total;
    private string _pageTitle = "Fleet";

    protected override void OnInitialized()
    {
        Fleet.Changed += OnChanged;
        Nav.LocationChanged += OnLocationChanged;
        Recount();
        UpdateTitle();
    }

    private async Task ToggleTheme() => await JS.InvokeVoidAsync("toggleTheme");

    private void OnChanged() => InvokeAsync(() => { Recount(); StateHasChanged(); });
    private void OnLocationChanged(object? s, LocationChangedEventArgs e) => InvokeAsync(() => { UpdateTitle(); StateHasChanged(); });

    private void Recount()
    {
        var m = Fleet.Snapshot.Machines;
        _total = m.Count;
        _online = m.Count(x => (DateTimeOffset.Now - x.LastSeen).TotalSeconds < 45);
    }

    private void UpdateTitle()
    {
        var p = Nav.ToBaseRelativePath(Nav.Uri);
        var q = p.IndexOf('?'); if (q >= 0) p = p[..q];
        p = p.TrimEnd('/');
        _pageTitle = p switch
        {
            "" => "Fleet",
            "stats" => "Thống kê (dòng đã scrape / import / update theo shop)",
            "machines" => "Máy client",
            "search" => "Search",
            "config/bigseller" => "Cấu hình BigSeller",
            "config/accounts" => "Tài khoản Shopee & Proxy",
            "config/errored" => "Tài khoản lỗi",
            "config/ai" => "Cấu hình AI",
            "settings" => "Cài đặt",
            "files" => "Files",
            "logs-view" => "Logs",
            _ => "Shopee Hub",
        };
    }

    public void Dispose()
    {
        Fleet.Changed -= OnChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }

    // ── SVG line icons (Lucide-style, stroke=currentColor) ──
    private static readonly Dictionary<string, string> Icons = new()
    {
        ["fleet"] = "<rect x='3' y='3' width='7' height='9' rx='1'/><rect x='14' y='3' width='7' height='5' rx='1'/><rect x='14' y='12' width='7' height='9' rx='1'/><rect x='3' y='16' width='7' height='5' rx='1'/>",
        ["stats"] = "<path d='M3 3v18h18'/><rect x='7' y='12' width='3' height='6'/><rect x='12' y='8' width='3' height='10'/><rect x='17' y='4' width='3' height='14'/>",
        ["machines"] = "<rect x='2' y='3' width='20' height='14' rx='2'/><path d='M8 21h8M12 17v4'/>",
        ["search"] = "<circle cx='11' cy='11' r='7'/><path d='M21 21l-4.3-4.3'/>",
        ["bigseller"] = "<path d='M12 2 2 7l10 5 10-5-10-5z'/><path d='M2 17l10 5 10-5'/><path d='M2 12l10 5 10-5'/>",
        ["users"] = "<path d='M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75'/>",
        ["alert"] = "<path d='M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z'/><path d='M12 9v4M12 17h.01'/>",
        ["ai"] = "<rect x='4' y='4' width='16' height='16' rx='2'/><rect x='9' y='9' width='6' height='6'/><path d='M9 2v2M15 2v2M9 20v2M15 20v2M20 9h2M20 14h2M2 9h2M2 14h2'/>",
        ["settings"] = "<circle cx='12' cy='12' r='3'/><path d='M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z'/>",
        ["files"] = "<path d='M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z'/>",
        ["logs"] = "<path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'/><path d='M14 2v6h6M8 13h8M8 17h8M8 9h2'/>",
    };

    private static MarkupString NavIcon(string key)
    {
        var body = Icons.TryGetValue(key, out var b) ? b : "";
        return new MarkupString($"<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'>{body}</svg>");
    }
}
