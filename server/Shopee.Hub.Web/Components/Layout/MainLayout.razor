@inherits LayoutComponentBase
@implements IDisposable
@using Shopee.Hub.Web.Auth
@inject FleetStateService Fleet
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AdminAccountService Admin

<div class="app">
    <nav class="side">
        <div class="brand">
            <div class="brand-logo">S</div>
            <div class="brand-text">
                <div class="brand-name">Shopee Hub</div>
                <div class="brand-sub">Fleet control</div>
            </div>
        </div>

        <div class="side-scroll">
            <div class="navsec">Điều khiển</div>
            <NavLink class="nav" href="/" Match="NavLinkMatch.All"><span class="nav-ic">@HubIcons.Svg("fleet")</span><span>Fleet</span></NavLink>
            <NavLink class="nav" href="/stats"><span class="nav-ic">@HubIcons.Svg("stats")</span><span>Thống kê</span></NavLink>
            <NavLink class="nav" href="/machines"><span class="nav-ic">@HubIcons.Svg("machines")</span><span>Máy client</span></NavLink>
            <NavLink class="nav" href="/search"><span class="nav-ic">@HubIcons.Svg("search")</span><span>Search</span></NavLink>

            <div class="navsec">Cấu hình</div>
            <NavLink class="nav" href="/config/bigseller"><span class="nav-ic">@HubIcons.Svg("bigseller")</span><span>BigSeller</span></NavLink>
            <NavLink class="nav" href="/config/accounts"><span class="nav-ic">@HubIcons.Svg("users")</span><span>Acc Shopee &amp; Proxy</span></NavLink>
            <NavLink class="nav" href="/config/errored"><span class="nav-ic">@HubIcons.Svg("alert")</span><span>Acc lỗi</span></NavLink>
            <NavLink class="nav" href="/config/ai"><span class="nav-ic">@HubIcons.Svg("ai")</span><span>AI</span></NavLink>

            <div class="navsec">Hệ thống</div>
            <NavLink class="nav" href="/settings"><span class="nav-ic">@HubIcons.Svg("settings")</span><span>Cài đặt</span></NavLink>
            <NavLink class="nav" href="/files"><span class="nav-ic">@HubIcons.Svg("files")</span><span>Files</span></NavLink>
            <NavLink class="nav" href="/logs-view"><span class="nav-ic">@HubIcons.Svg("logs")</span><span>Logs</span></NavLink>
        </div>

        <div class="side-foot">
            <div class="fleet-badge">
                <span class="fb-dot @(_online > 0 ? "on" : "")"></span>
                <span><b>@_online</b>/@_total máy online</span>
            </div>
        </div>
    </nav>

    <div class="main">
        <header class="topbar">
            <div class="topbar-title">@_pageTitle</div>
            <div class="topbar-right">
                <span class="topbar-user">👤 @(Admin.Username ?? "admin")</span>
                <button class="theme-btn" title="Đổi sáng/tối" @onclick="ToggleTheme">
                    <svg class="ico-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                    <svg class="ico-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.5"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
                </button>
                <form method="post" action="/logout"><button class="btn sm danger" type="submit">↪ Đăng xuất</button></form>
            </div>
        </header>

        <main class="content">
            @Body
        </main>
    </div>
</div>

@code {
    private int _online, _total;
    private string _pageTitle = "Fleet";

    protected override void OnInitialized()
    {
        Fleet.Changed += OnChanged;
        Nav.LocationChanged += OnLocationChanged;
        Recount();
        UpdateTitle();
    }

    private async Task ToggleTheme() => await JS.InvokeVoidAsync("toggleTheme");

    private void OnChanged() => InvokeAsync(() => { Recount(); StateHasChanged(); });
    private void OnLocationChanged(object? s, LocationChangedEventArgs e) => InvokeAsync(() => { UpdateTitle(); StateHasChanged(); });

    private void Recount()
    {
        var m = Fleet.Snapshot.Machines;
        _total = m.Count;
        _online = m.Count(x => (DateTimeOffset.Now - x.LastSeen).TotalSeconds < 45);
    }

    private void UpdateTitle()
    {
        var p = Nav.ToBaseRelativePath(Nav.Uri);
        var q = p.IndexOf('?'); if (q >= 0) p = p[..q];
        p = p.TrimEnd('/');
        _pageTitle = p switch
        {
            "" => "Fleet",
            "stats" => "Thống kê (dòng đã scrape / import / update theo shop)",
            "machines" => "Quản lý máy client",
            "search" => "Search đa máy",
            "config/bigseller" => "Cấu hình BigSeller",
            "config/accounts" => "Tài khoản Shopee & Proxy",
            "config/errored" => "Tài khoản lỗi / captcha",
            "config/ai" => "Cấu hình AI",
            "settings" => "Cài đặt hub",
            "files" => "Files (kho dùng chung)",
            "logs-view" => "Logs",
            _ => "Shopee Hub",
        };
    }

    public void Dispose()
    {
        Fleet.Changed -= OnChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
