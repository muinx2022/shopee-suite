@page "/config/proxies"
@attribute [Authorize(Policy = "Web")]
@inject FileStoreConfigService Config

<h1>Kho proxy (KiotProxy)</h1>
<p class="hint">Mỗi dòng 1 key KiotProxy hoặc host:port. Client kéo về round-robin theo index acc.</p>

<div class="editcard" style="max-width:640px">
    <textarea @bind="_text" rows="14" style="width:100%;font-family:monospace"></textarea>
    <div class="bar">
        <button class="btn primary" @onclick="Save">💾 Lưu</button>
        <span class="action">@_status</span>
    </div>
</div>

@code {
    private string _text = "";
    private int _version;
    private string _status = "";

    protected override void OnInitialized() => Load();

    private void Load()
    {
        _text = string.Join("\n", Config.KiotProxies());
        _version = Config.VersionOf(FileStoreConfigService.KiotProxiesFile);
    }

    private void Save()
    {
        var list = _text.Split('\n').Select(x => x.Trim()).Where(x => x.Length > 0).Distinct().ToList();
        var res = Config.Save(FileStoreConfigService.KiotProxiesFile, list, _version);
        if (res.Ok) { _version = res.Version; _status = $"✔ Đã lưu {list.Count} proxy (v{res.Version})."; }
        else if (res.Conflict == "version-conflict") { _status = "⚠ Client vừa đẩy bản mới — đã tải lại."; Load(); }
        else _status = $"✘ Lỗi lưu: {res.Conflict}";
    }
}
