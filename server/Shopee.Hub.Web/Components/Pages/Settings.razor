@page "/settings"
@attribute [Authorize(Policy = "Web")]
@using Shopee.Hub.Web.Auth
@using XuLyDonShopee.Core.Services
@inject HubDatabase Db
@inject AdminAccountService Admin
@inject IJSRuntime JS

<h2>API Token — client dùng để kết nối</h2>
<div class="editcard" style="max-width:720px">
    <p class="hint m-hide">Mọi máy client nhập token này (app → Cài đặt → ApiToken, BaseUrl = <code>https://api.schedra.net</code>) để vào fleet.
       <b>Đổi token → TẤT CẢ client phải nhập lại token mới</b> (token cũ sẽ bị 401).</p>
    <label>Token hiện tại</label>
    <div class="row">
        <input readonly value="@_token" style="width:440px;font-family:monospace" onfocus="this.select()" />
        <button class="btn" @onclick="CopyToken">📋 Copy</button>
        <span class="action">@_copyStatus</span>
    </div>
    <label style="margin-top:12px">Đổi token</label>
    <div class="row">
        <input @bind="_newToken" placeholder="dán token mới, hoặc bấm Sinh ngẫu nhiên" style="width:440px;font-family:monospace" />
        <button class="btn" @onclick="GenToken">🎲 Sinh ngẫu nhiên</button>
    </div>
    <div class="bar">
        <button class="btn danger" @onclick="SaveToken" title="Đổi token → TẤT CẢ client phải nhập lại token mới!">💾 Lưu token mới</button>
        <span class="action">@_tokenStatus</span>
    </div>
</div>

<h2>Báo đơn mới — webhook Slack / Discord / Telegram</h2>
<div class="editcard" style="max-width:720px">
    <p class="hint m-hide">Khi client push đơn <b>MỚI</b>, hub bắn tin về các webhook dưới đây — <b>mỗi dòng 1 URL</b>.
       Nhận diện kênh theo URL: <code>hooks.slack.com/...</code> (Slack), <code>discord.com/api/webhooks/...</code>
       (Discord), <code>api.telegram.org/bot&lt;token&gt;/sendMessage?chat_id=&lt;id&gt;</code> (Telegram). Để trống = tắt.</p>
    <label>Danh sách webhook (mỗi dòng 1 URL)</label>
    <textarea @bind="_webhooks" rows="4" style="width:100%;font-family:monospace;font-size:12px"
              placeholder="https://hooks.slack.com/services/..."></textarea>
    <div class="bar">
        <button class="btn primary" @onclick="SaveWebhooks">💾 Lưu webhook</button>
        <span class="action">@_webhookStatus</span>
    </div>
</div>

<h2>Đổi mật khẩu admin (đăng nhập web)</h2>
<div class="editcard" style="max-width:720px">
    <label>Mật khẩu mới (≥ 6 ký tự)</label>
    <input @bind="_newPass" type="password" style="width:320px" />
    <div class="bar">
        <button class="btn primary" @onclick="SavePass">💾 Đổi mật khẩu</button>
        <span class="action">@_passStatus</span>
    </div>
</div>

@code {
    private string _token = "";
    private string _newToken = "";
    private string _tokenStatus = "";
    private string _copyStatus = "";
    private string _newPass = "";
    private string _passStatus = "";
    private string _webhooks = "";
    private string _webhookStatus = "";

    protected override void OnInitialized()
    {
        _token = Db.GetSetting(SettingKeys.ApiToken) ?? "";
        _webhooks = Db.GetSetting(SettingKeys.NotifyWebhooks) ?? "";
    }

    private void GenToken() =>
        _newToken = Convert.ToHexString(System.Security.Cryptography.RandomNumberGenerator.GetBytes(24));

    private async Task CopyToken()
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", _token); _copyStatus = "✔ đã copy"; }
        catch { _copyStatus = "⚠ trình duyệt chặn — bôi đen ô để copy tay"; }
    }

    private async Task SaveToken()
    {
        var t = _newToken.Trim();
        if (t.Length < 8) { _tokenStatus = "⚠ Token quá ngắn (≥ 8 ký tự)."; return; }
        if (!await JS.InvokeAsync<bool>("confirm", "Đổi token → MỌI client mất kết nối cho tới khi nhập token mới. Tiếp tục?")) return;
        Db.SetSetting(SettingKeys.ApiToken, t);
        _token = t; _newToken = "";
        _tokenStatus = "✔ Đã đổi token — hiệu lực NGAY. Nhập token này vào MỌI client (token cũ giờ bị 401).";
    }

    private void SavePass()
    {
        if (_newPass.Length < 6) { _passStatus = "⚠ Mật khẩu < 6 ký tự."; return; }
        Admin.SetAdmin(Admin.Username ?? "admin", _newPass);
        _newPass = "";
        _passStatus = "✔ Đã đổi mật khẩu admin (lần đăng nhập sau dùng mật khẩu mới).";
    }

    private void SaveWebhooks()
    {
        // Validate TỪNG dòng không rỗng bằng OrderNotifyService.KiemTraUrl (nguồn sự thật nhận diện kênh);
        // dòng đầu tiên sai → báo lỗi + KHÔNG lưu (tránh ghi URL hỏng).
        var lines = (_webhooks ?? "").Replace("\r\n", "\n").Replace('\r', '\n').Split('\n');
        for (int i = 0; i < lines.Length; i++)
        {
            var line = lines[i].Trim();
            if (line.Length == 0) continue;
            var err = OrderNotifyService.KiemTraUrl(line);
            if (err is not null) { _webhookStatus = $"⚠ Dòng {i + 1}: {err}"; return; }
        }
        // Chuẩn hoá: trim + bỏ dòng trống trước khi lưu.
        var normalized = string.Join('\n', lines.Select(l => l.Trim()).Where(l => l.Length > 0));
        Db.SetSetting(SettingKeys.NotifyWebhooks, normalized);
        _webhooks = normalized;
        _webhookStatus = normalized.Length == 0
            ? "✔ Đã lưu (không có webhook — tính năng báo đơn mới đang TẮT)."
            : "✔ Đã lưu webhook — hiệu lực ngay cho lượt push kế tiếp.";
    }
}
