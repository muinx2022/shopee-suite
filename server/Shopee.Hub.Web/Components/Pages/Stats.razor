@page "/stats"
@* Route UI-only; KHÔNG trùng /ledger (API client trả JSON). Trang đọc sổ ledger (Hub lưu) → xem mỗi shop
   đã scrape/import/update/tên-SP được NHỮNG DÒNG NÀO. Dữ liệu nằm ở Hub nên xem tập trung, không phụ thuộc
   client nào đang chạy việc gì. Bố cục: KPI + ma trận 1 dòng/shop + panel chi tiết khi bấm 1 shop. *@
@attribute [Authorize(Policy = "Web")]
@inherits FleetPageBase
@inject FileStoreConfigService Config
@inject SheetMapService SheetMap

<div class="statspage">
    <p class="hint m-hide">Tổng hợp từ Hub — mỗi shop đã scrape / import / update / đổi tên được bao nhiêu dòng, không phụ thuộc máy nào đang chạy. Bấm 1 shop để xem khoảng dòng chi tiết.</p>

    <div class="kpis">
        <div class="kpi">
            <div class="kpi-ic green">@HubIcons.Svg("shop", 22)</div>
            <div><div class="kpi-val">@_kShops</div><div class="kpi-label">Shop có tiến độ</div></div>
        </div>
        <div class="kpi">
            <div class="kpi-ic blue">@HubIcons.Svg("scrape", 22)</div>
            <div><div class="kpi-val">@_kScrape.ToString("N0")</div><div class="kpi-label">Dòng đã scrape</div></div>
        </div>
        <div class="kpi">
            <div class="kpi-ic blue">@HubIcons.Svg("import", 22)</div>
            <div><div class="kpi-val">@_kImport.ToString("N0")</div><div class="kpi-label">Dòng đã import</div></div>
        </div>
        <div class="kpi">
            <div class="kpi-ic amber">@HubIcons.Svg("update", 22)</div>
            <div><div class="kpi-val">@_kUpdate.ToString("N0")</div><div class="kpi-label">Dòng đã update</div></div>
        </div>
        <div class="kpi">
            <div class="kpi-ic amber">@HubIcons.Svg("tag", 22)</div>
            <div><div class="kpi-val">@_kRewrite.ToString("N0")</div><div class="kpi-label">Dòng đổi tên SP</div></div>
        </div>
    </div>

    <div class="bar">
        <span class="stat">@_summary</span>
        <label>Tìm tài khoản / shop
            <input type="text" @bind="_search" @bind:event="oninput" placeholder="gõ để lọc…" />
        </label>
        <label class="toggle">
            <input type="checkbox" @bind="_onlyWithRows" /> Chỉ shop đã có tiến độ
        </label>
    </div>

    <h2>Tiến độ theo shop</h2>
    <div class="tablewrap">
        <table class="grid sm">
            <thead>
                <tr>
                    <th>Shop</th>
                    <th>Scrape</th><th>Import</th><th>Update</th><th>Tên SP</th>
                </tr>
            </thead>
            <tbody>
                @{ string? lastAcct = null; }
                @foreach (var r in Filtered())
                {
                    @if (r.AccountName != lastAcct)
                    {
                        lastAcct = r.AccountName;
                        var n = _rows.Count(x => x.AccountName == r.AccountName);
                        <tr class="acctrow"><td colspan="5">@r.AccountName <span class="cnt">· @n shop</span></td></tr>
                    }
                    var sel = _selAcctId == r.AccountId && _selShopId == r.ShopId;
                    <tr class="@(sel ? "sel" : "")" @onclick="() => Select(r)">
                        <td class="shop">@r.ShopName</td>
                        @foreach (var op in OpOrder)
                        {
                            <td>@Chip(r, op)</td>
                        }
                    </tr>
                }
                @if (!Filtered().Any())
                {
                    <tr><td colspan="5" class="empty">Chưa có dữ liệu (chưa máy nào scrape/import/update, hoặc bị lọc hết).</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (_sel is not null)
    {
        <div class="pinpanel">
            <h2>📊 Chi tiết — @_sel.AccountName › @_sel.ShopName</h2>
            <div class="opcards">
                @foreach (var op in OpOrder)
                {
                    var st = _sel.Ops.GetValueOrDefault(op);
                    <div class="opcard @(st is null ? "empty0" : "")">
                        <div class="ohead">
                            <span class="olabel">@OpLabel(op)</span>
                            @if (st is not null)
                            {
                                <span class="pill @st.StatusCss">@st.StatusText</span>
                            }
                            else
                            {
                                <span class="pill idle">chưa chạy</span>
                            }
                        </div>
                        @if (st is not null)
                        {
                            <div class="n">@st.RowCount.ToString("N0") <span class="sub">dòng</span>
                                <button class="linkbtn" @onclick="() => OpenMap(op)">🔍 xem dòng</button>
                            </div>
                            <div class="sub">tới dòng @st.LastRow</div>
                            <div class="rng m-hide">@st.Ranges</div>
                            <div class="sub" title="@st.LastAbs">Gần nhất: @(string.IsNullOrEmpty(st.Machine) ? "—" : st.Machine)@(string.IsNullOrEmpty(st.LastAgo) ? "" : $" · {st.LastAgo}")</div>
                            @if (st.Machines.Count > 1)
                            {
                                <div class="sub m-hide">Đã tham gia (@st.Machines.Count máy): @string.Join(", ", st.Machines)</div>
                            }
                        }
                        else
                        {
                            <div class="sub">Chưa có lượt chạy nào cho việc này.</div>
                        }
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <p class="hint">Bấm 1 shop ở bảng trên để xem khoảng dòng chi tiết.</p>
    }

    @if (_mapOpen)
    {
        <div class="modal-overlay" @onclick="CloseMap">
            <div class="modal wide" @onclick:stopPropagation="true">
                <div class="modal-head">
                    <span>🗺️ @_mapTitle</span>
                    <button class="linkbtn" @onclick="CloseMap">✕</button>
                </div>
                <div class="modal-body">
                    @if (_mapLoading)
                    {
                        <div class="hint">Đang đọc cấu trúc sheet…</div>
                    }
                    else if (_mapError is not null)
                    {
                        <div class="warn">@_mapError</div>
                    }
                    else if (_mapCells.Count == 0)
                    {
                        <div class="empty">Sheet không có dòng dữ liệu.</div>
                    }
                    else
                    {
                        <div class="hmbar">
                            <span class="stat"><b>@_mapDone.ToString("N0")</b> / @_mapTotal.ToString("N0") dòng đã @_mapOpLabel</span>
                            <span class="hmleg"><span class="hm-cell on"></span> đã làm &nbsp; <span class="hm-cell"></span> chưa</span>
                        </div>
                        <div class="heatmap">
                            @foreach (var cell in _mapCells)
                            {
                                <span class="hm-cell @(cell.Done ? "on" : "")" title="@(cell.Done ? $"dòng {cell.Row} · đã {_mapOpLabel}" : $"dòng {cell.Row} · chưa")"></span>
                            }
                        </div>
                        @if (_mapCapped)
                        {
                            <div class="sub">Hiển thị @_mapCells.Count.ToString("N0") ô đầu (sheet rất lớn) — đủ để thấy vùng đã làm.</div>
                        }
                    }
                </div>
                <div class="modal-foot">
                    <button class="btn" @onclick="CloseMap">Đóng</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<BigSellerAccount> _accounts = new();
    private List<ShopRow> _rows = new();
    private string _summary = "";
    private int _kShops, _kScrape, _kImport, _kUpdate, _kRewrite;
    private DateTimeOffset _accountsLoadedAt;

    private string _search = "";
    private bool _onlyWithRows;
    private string? _selAcctId, _selShopId;
    private ShopRow? _sel;

    private static readonly string[] OpOrder = ["scrape", "import", "update", "rewrite"];

    private sealed class OpStat
    {
        public string StatusText = "", StatusCss = "", Ranges = "—", Machine = "", LastAgo = "", LastAbs = "";
        public int RowCount, LastRow;
        public List<string> Machines = new();   // hostnames đã tham gia việc này
    }

    private sealed class ShopRow
    {
        public string AccountId = "", AccountName = "", ShopId = "", ShopName = "", Sheet = "";
        public Dictionary<string, OpStat> Ops = new();
    }

    // ── Bản đồ dòng (heatmap) ──
    private bool _mapOpen, _mapLoading, _mapCapped;
    private string? _mapError, _mapTitle, _mapOpLabel;
    private int _mapTotal, _mapDone;
    private List<(int Row, bool Done)> _mapCells = new();
    private const int MapCap = 20000;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        ReloadAccounts();
        Rebuild();
    }

    // Modal heatmap dùng dữ liệu chụp lúc mở → dừng hẳn nhịp vẽ (cả StateHasChanged) khỏi diff 20k ô mỗi 2s.
    protected override bool ShouldTickRender() => !_mapOpen;

    protected override void OnFleetTick()
    {
        if ((DateTimeOffset.UtcNow - _accountsLoadedAt).TotalSeconds > 10) ReloadAccounts();
        Rebuild();
    }

    private void ReloadAccounts()
    {
        _accounts = Config.BigSellerAccounts();
        _accountsLoadedAt = DateTimeOffset.UtcNow;
    }

    private void Rebuild()
    {
        var byId = _accounts.ToDictionary(a => a.Id, a => a);
        var shops = new Dictionary<string, ShopRow>(StringComparer.Ordinal);

        foreach (var l in Snap.Ledger)
        {
            if (string.IsNullOrEmpty(l.BigsellerId)) continue;   // (search dùng bảng khác, không nằm ở ledger)
            byId.TryGetValue(l.BigsellerId, out var acct);
            var key = l.BigsellerId + "__" + l.ShopId;
            if (!shops.TryGetValue(key, out var row))
            {
                var shop = acct?.Shops.FirstOrDefault(s => s.Id == l.ShopId);
                row = new ShopRow
                {
                    AccountId = l.BigsellerId,
                    AccountName = acct?.DisplayName ?? ShortId(l.BigsellerId),
                    ShopId = l.ShopId,
                    ShopName = shop?.DisplayName ?? (string.IsNullOrWhiteSpace(l.Sheet) ? ShortId(l.ShopId) : l.Sheet),
                    Sheet = !string.IsNullOrWhiteSpace(shop?.ShopeeDataSheet) ? shop!.ShopeeDataSheet : (l.Sheet ?? ""),
                };
                shops[key] = row;
            }
            var (stText, stCss) = LedgerStatus(l.Status);
            var last = l.LastRunAt ?? l.UpdatedAt;
            row.Ops[l.Op] = new OpStat
            {
                StatusText = stText, StatusCss = stCss,
                RowCount = CountRows(l.Completed), LastRow = l.LastRowReached,
                Ranges = FormatRanges(l.Completed), Machine = Machine(l),
                LastAgo = FleetStateService.Ago(last),
                LastAbs = last == default ? "" : last.LocalDateTime.ToString("dd/MM/yyyy HH:mm:ss"),
                Machines = l.MachineIds.Select(HostName).Where(h => !string.IsNullOrEmpty(h)).Distinct().ToList(),
            };
        }

        _rows = shops.Values
            .OrderBy(r => r.AccountName, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(r => r.ShopName, StringComparer.CurrentCultureIgnoreCase)
            .ToList();

        // KPI: shop có ít nhất 1 khoảng dòng + tổng dòng theo từng việc.
        _kShops = _rows.Count(r => r.Ops.Values.Any(o => o.RowCount > 0));
        _kScrape = _rows.Sum(r => r.Ops.GetValueOrDefault("scrape")?.RowCount ?? 0);
        _kImport = _rows.Sum(r => r.Ops.GetValueOrDefault("import")?.RowCount ?? 0);
        _kUpdate = _rows.Sum(r => r.Ops.GetValueOrDefault("update")?.RowCount ?? 0);
        _kRewrite = _rows.Sum(r => r.Ops.GetValueOrDefault("rewrite")?.RowCount ?? 0);
        _summary = $"{_rows.Count} shop có ghi nhận · cập nhật {DateTimeOffset.Now:HH:mm:ss}";

        // Giữ shop đang chọn qua các lần refresh (đọc lại tham chiếu mới).
        _sel = _selAcctId is null ? null
            : _rows.FirstOrDefault(r => r.AccountId == _selAcctId && r.ShopId == _selShopId);
    }

    private IEnumerable<ShopRow> Filtered()
    {
        var q = _search?.Trim() ?? "";
        return _rows
            .Where(r => q.Length == 0
                || r.AccountName.Contains(q, StringComparison.OrdinalIgnoreCase)
                || r.ShopName.Contains(q, StringComparison.OrdinalIgnoreCase))
            .Where(r => !_onlyWithRows || r.Ops.Values.Any(o => o.RowCount > 0));
    }

    private void Select(ShopRow r)
    {
        if (_selAcctId == r.AccountId && _selShopId == r.ShopId) { _selAcctId = _selShopId = null; _sel = null; return; }
        _selAcctId = r.AccountId; _selShopId = r.ShopId; _sel = r;
    }

    /// <summary>Mở bản đồ dòng của 1 việc trên shop đang chọn: đọc cấu trúc sheet (cache) rồi tô dòng đã làm.</summary>
    private async Task OpenMap(string op)
    {
        if (_sel is null) return;
        var shop = _sel;
        _mapOpen = true; _mapLoading = true; _mapError = null; _mapCapped = false;
        _mapCells = new(); _mapTotal = _mapDone = 0; _mapOpLabel = OpLabel(op);
        _mapTitle = $"{OpLabel(op)} · {shop.ShopName} · sheet '{shop.Sheet}'";
        StateHasChanged();

        var info = await SheetMap.GetAsync(shop.AccountId, shop.Sheet);
        if (!_mapOpen) return;   // người dùng đã đóng modal trong lúc đọc
        if (!info.Found) { _mapError = info.Error; _mapLoading = false; StateHasChanged(); return; }

        var abs = info.DataRows;                 // số dòng tuyệt đối, tăng dần; vị trí i ↔ chỉ số dồn i+1
        var led = Snap.Ledger.FirstOrDefault(l => l.Key == $"{shop.AccountId}__{shop.ShopId}__{op}");
        var ranges = led?.Completed ?? new List<RowRange>();
        var done = new bool[abs.Count];
        if (op == "scrape")
        {
            // scrape: ledger là CHỈ SỐ DỒN (1-based) → phần tử thứ p trong danh sách.
            foreach (var rr in ranges)
                for (var p = Math.Max(1, rr.From); p <= rr.To && p <= abs.Count; p++)
                    done[p - 1] = true;
        }
        else
        {
            // import/update: ledger là SỐ DÒNG TUYỆT ĐỐI → tra vị trí trong danh sách.
            var idx = new Dictionary<int, int>(abs.Count);
            for (var i = 0; i < abs.Count; i++) idx[abs[i]] = i;
            foreach (var rr in ranges)
                for (var a = rr.From; a <= rr.To; a++)
                    if (idx.TryGetValue(a, out var i)) done[i] = true;
        }
        _mapTotal = abs.Count;
        _mapDone = done.Count(b => b);
        var cells = abs.Select((rowNum, i) => (Row: rowNum, Done: done[i]));
        _mapCapped = abs.Count > MapCap;
        _mapCells = (_mapCapped ? cells.Take(MapCap) : cells).ToList();
        _mapLoading = false;
        StateHasChanged();
    }

    private void CloseMap() { _mapOpen = false; _mapCells = new(); }

    // Ô việc trong ma trận: có record → pill màu + glyph + số dòng; không có → dấu chấm mờ.
    private RenderFragment Chip(ShopRow r, string op) => builder =>
    {
        if (!r.Ops.TryGetValue(op, out var st))
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "dash");
            builder.AddContent(2, "·");
            builder.CloseElement();
            return;
        }
        var glyph = st.StatusCss switch { "done" => "✓", "warn" => "■", "run" => "⏳", _ => "•" };
        var text = st.RowCount > 0 ? $"{glyph} {st.RowCount:N0}" : glyph;
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"pill {st.StatusCss}");
        builder.AddContent(2, text);
        builder.CloseElement();
    };

    private string Machine(WorkLedgerRecord l)
    {
        if (!string.IsNullOrEmpty(l.LastMachineId))
        {
            var m = Snap.Machines.FirstOrDefault(x => x.MachineId == l.LastMachineId);
            if (m is not null && !string.IsNullOrWhiteSpace(m.Hostname)) return m.Hostname;
        }
        return string.IsNullOrWhiteSpace(l.LastHostname) ? "" : l.LastHostname;
    }

    private string HostName(string machineId)
    {
        if (string.IsNullOrEmpty(machineId)) return "";
        var m = Snap.Machines.FirstOrDefault(x => x.MachineId == machineId);
        return m is not null && !string.IsNullOrWhiteSpace(m.Hostname) ? m.Hostname : ShortId(machineId);
    }

    private static (string text, string css) LedgerStatus(string s) => s switch
    {
        "completed" => ("✓ xong", "done"),
        "stopped" => ("■ dừng dở", "warn"),
        "running" => ("⏳ đang chạy", "run"),
        _ => ("· chưa xong", "idle"),
    };

    private static string OpLabel(string op) => op switch
    {
        "scrape" => "Scrape", "import" => "Import", "update" => "Update", "rewrite" => "Tên SP", _ => op,
    };

    private static int CountRows(List<RowRange> rr) => rr.Sum(r => Math.Max(0, r.To - r.From + 1));

    private static string FormatRanges(List<RowRange> rr) => rr.Count == 0
        ? "—"
        : string.Join(", ", rr.OrderBy(r => r.From).Select(r => r.From == r.To ? $"{r.From}" : $"{r.From}–{r.To}"));

    private static string ShortId(string id) => string.IsNullOrEmpty(id) ? "?" : (id.Length <= 8 ? id : id[..8] + "…");

}
