@page "/config/errored"
@attribute [Authorize(Policy = "Web")]
@inherits FleetPageBase
@inject FileStoreConfigService Config
@inject HubDatabase Db

<p class="hint m-hide">Acc Shopee do client báo dính captcha hoặc lỗi. Gỡ báo khi đã xử lý.</p>

<div class="bar">
    <span class="stat">@_errors.Count acc đang báo lỗi</span>
    <button class="btn" @onclick="Refresh">↻ Cập nhật</button>
</div>

@if (_errors.Count == 0)
{
    <p class="hint">Không có acc nào đang báo lỗi. 🎉</p>
}
else
{
    <div class="tablewrap">
    <table class="grid sm stack-sm">
        <thead><tr><th>Acc</th><th>Máy</th><th>Lý do</th><th>Captcha URL</th><th>Trạng thái</th><th>Lúc</th><th></th></tr></thead>
        <tbody>
        @foreach (var e in _errors.OrderByDescending(x => x.ReportedAt))
        {
            <tr>
                <td data-label="Acc">@AccLabel(e.AccountId)</td>
                <td data-label="Máy">@e.Hostname</td>
                <td data-label="Lý do">@e.Reason</td>
                <td data-label="Captcha">@if (!string.IsNullOrEmpty(e.CaptchaUrl)) { <a class="btn sm" href="@e.CaptchaUrl" target="_blank">mở</a> } else { <text>—</text> }</td>
                <td data-label="Trạng thái"><span class="pill @(e.Status == "failed" ? "fail" : "warn")">@e.Status</span></td>
                <td data-label="Lúc">@FleetStateService.Ago(e.ReportedAt)</td>
                <td data-label=""><button class="btn sm" @onclick="() => ClearError(e.AccountId)">Gỡ báo</button></td>
            </tr>
        }
        </tbody>
    </table>
    </div>
}

@code {
    private List<AccountError> _errors = new();
    private List<ShopeeAccount> _accounts = new();

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Refresh();
        _accounts = Config.ShopeeAccounts();
    }

    protected override void OnFleetTick() => _errors = Db.AllAccountErrors();
    private void Refresh() => _errors = Db.AllAccountErrors();

    private string AccLabel(string id) =>
        _accounts.FirstOrDefault(a => a.Id == id)?.DisplayName ?? id[..Math.Min(8, id.Length)];

    private void ClearError(string id) { Db.ClearAccountError(id); Refresh(); }
}
