@page "/"
@* KHÔNG dùng @@page "/fleet": route đó thuộc API client (GET /fleet trả JSON). Trang này ở "/".
   Trang vận hành DUY NHẤT — bố cục WORKSPACE master-detail: KPI + danh sách acc→shop bên TRÁI,
   bên PHẢI 3 tab (Hành động / Thống kê / Cấu hình) cho mục đang chọn. *@
@attribute [Authorize(Policy = "Web")]
@inherits FleetPageBase
@inject FileStoreConfigService Config
@inject DispatcherService Dispatcher
@inject HubDatabase Db

<div class="fleetpage">
<div class="kpis">
    <div class="kpi">
        <div class="kpi-ic green">@HubIcons.Svg("machines", 22)</div>
        <div><div class="kpi-val">@_kMachines</div><div class="kpi-label">Máy online</div></div>
    </div>
    <div class="kpi">
        <div class="kpi-ic blue">@HubIcons.Svg("run", 22)</div>
        <div><div class="kpi-val">@_kRunning</div><div class="kpi-label">Việc đang chạy</div></div>
    </div>
    <div class="kpi">
        <div class="kpi-ic amber">@HubIcons.Svg("clock", 22)</div>
        <div><div class="kpi-val">@_kQueued</div><div class="kpi-label">Việc chờ</div></div>
    </div>
    <div class="kpi m-hide">
        <div class="kpi-ic blue">@HubIcons.Svg("cookie", 22)</div>
        <div><div class="kpi-val">@_kCookies</div><div class="kpi-label">Acc có cookie</div></div>
    </div>
</div>

<div class="bar">
    <span class="stat m-hide">@_summary</span>
    <label class="toggle">
        <input type="checkbox" checked="@Dispatcher.Enabled" @onchange="ToggleDispatch" />
        Điều phối tự động (scrape→import→update)
    </label>
</div>

<div class="workspace">
    <div class="wslist">
        <input type="text" @bind="_search" @bind:event="oninput" placeholder="tìm acc / shop…" />
        <button class="btn sm" style="margin-bottom:8px" @onclick="AddAccount">+ Thêm tài khoản</button>
        @foreach (var g in Filtered())
        {
            <div class="wsacct @(_selRow is null && _selAcctId == g.AccountId ? "sel" : "")" @onclick="() => SelectAcct(g.AccountId)">
                @g.AccountName <span class="cnt">@g.Shops.Count shop</span>
            </div>
            @foreach (var row in g.Shops)
            {
                var sel = _selShopKey is { } k && k.AccountId == row.AccountId && k.ShopId == row.ShopId;
                var run = IsRunningShop(row);
                <div class="wsshop @(sel ? "sel" : "") @(row.InConfig ? "" : "ghost") @(run ? "run" : "")" title="@GlyphTitle(row)" @onclick="() => SelectShop(row)">
                    @if (run)
                    {
                        <span class="glyph"><span class="rundot"></span></span> @row.ShopName <span class="runbadge">chạy</span>
                    }
                    else
                    {
                        <span class="glyph">@GlyphOf(row)</span> @row.ShopName
                    }
                </div>
            }
        }
        @if (!Filtered().Any())
        {
            <div class="empty">@(_rows.Count == 0 && _accounts.Count == 0 ? "Chưa có tài khoản." : "Không khớp tìm kiếm.")</div>
        }
    </div>

    <div class="wsmain">
        <h2>@AcctName@(_selRow is not null ? " › " + _selRow.ShopName : "")</h2>
        <div class="tabs">
            <button class="@(_tab == "action" ? "active" : "")" @onclick='() => _tab = "action"'>⚡ Hành động</button>
            @* Thống kê chỉ còn ở mức SHOP; mức ACC đã gộp vào dashboard của tab Hành động. *@
            @if (_selRow is not null)
            {
                <button class="@(_tab == "stats" ? "active" : "")" @onclick='() => _tab = "stats"'>📊 Thống kê</button>
                <button class="@(_tab == "data" ? "active" : "")" @onclick='() => _tab = "data"'>📋 Dữ liệu</button>
            }
            <button class="@(_tab == "config" ? "active" : "")" @onclick='() => _tab = "config"'>⚙ Cấu hình</button>
        </div>

        @if (_selRow is not null)
        {
            var row = _selRow!;
            @if (_tab == "action")
            {
                @* (a) Trạng thái 4 op của shop + combo đặt-tay ledger *@
                <div class="tablewrap">
                <table class="grid sm">
                    <thead><tr><th>Việc</th><th>Trạng thái</th><th>Dòng</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var op in OpOrder)
                        {
                            var cell = FleetStateService.OpCell(Snap, row.AccountId, row.ShopId, op);
                            var st = row.Ops.GetValueOrDefault(op);
                            <tr>
                                <td>@OpLabel(op)</td>
                                <td><span class="pill @cell.Css" title="@(st is null ? "" : $"{st.Machine} · {st.LastAgo}")">@cell.Text</span></td>
                                <td>@(st is { RowCount: > 0 } ? st.RowCount.ToString("N0") : "")</td>
                                <td>
                                    @* Máy đang chạy (Locked) → ẩn combo. Rewrite + shop mồ côi + shop chưa gán sheet cũng không đặt-tay được. *@
                                    @if (op != "rewrite" && row.InConfig && !cell.Locked && !string.IsNullOrEmpty(row.Sheet))
                                    {
                                        @* Select UNCONTROLLED → PHẢI @key theo (acc|shop|op|thế hệ): thiếu key thì Blazor tái dùng
                                           đúng element DOM cũ khi đổi shop → lựa chọn vừa đặt (vd "Chưa (reset)") hiện dính sang
                                           MỌI shop khác; sau khi đặt-tay xong cũng nhảy thế hệ để combo dựng lại, quay về ⋯. *@
                                        <select class="cellset" @key="@($"{row.AccountId}|{row.ShopId}|{op}|{_cellsetGen}")"
                                                @onchange="e => SetLedger(row.AccountId, row.ShopId, row.Sheet, op, e.Value?.ToString())">
                                            <option value="">⋯</option>
                                            <option value="completed">✓ Xong</option>
                                            <option value="idle">Chưa (reset)</option>
                                            <option value="stopped">■ Dừng</option>
                                        </select>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>

                @* (b) Form ghim việc *@
                @if (!row.InConfig)
                {
                    <p class="hint">Shop không còn trong cấu hình — chỉ xem tiến độ.</p>
                }
                else if (string.IsNullOrEmpty(row.Sheet))
                {
                    <p class="hint">@(IsHubAcct(row.AccountId)
                        ? "Shop thiếu ngăn dữ liệu — mở tab ⚙ Cấu hình bấm Lưu để vá."
                        : "Shop chưa gán sheet — vào tab ⚙ Cấu hình.")</p>
                }
                else
                {
                    <div class="pinpanel">
                        <div class="pin">
                            <div>Shop: <b>@row.ShopName</b></div>
                            <label>Op
                                <select @bind="_pinOp">
                                    <option value="">-- Chọn Op --</option>
                                    <option value="scrape">Scrape</option>
                                    <option value="import">Import</option>
                                    <option value="update">Update</option>
                                </select>
                            </label>
                            <label>Máy
                                <select @bind="_pinMachine">
                                    <option value="">— chọn máy —</option>
                                    @foreach (var m in _pinnableMachines)
                                    {
                                        var off = FleetStateService.MachineOffline(Snap, m.MachineId);
                                        <option value="@m.MachineId" disabled="@off">@(off ? "⚪" : "🟢") @m.Hostname @(off ? "(offline)" : "")</option>
                                    }
                                </select>
                            </label>
                            <label>Từ dòng <input type="number" @bind="_pinStart" style="width:80px" /></label>
                            <label>Đến dòng <input type="number" @bind="_pinEnd" style="width:80px" /></label>
                            <label>Số process <input type="number" @bind="_pinProcs" style="width:70px" /></label>
                            @if (_pinOp == "scrape")
                            {
                                <label>Số tk / khung <input type="number" @bind="_pinFrame" style="width:70px" /></label>
                            }
                            @if (_pinOp == "import" || _pinOp == "update")
                            {
                                <label>Reload (s) <input type="number" @bind="_pinReload" style="width:70px" /></label>
                            }
                            @if (_pinOp == "import")
                            {
                                <label><input type="checkbox" @bind="_pinFromClaimed" /> Import từ tab "Đã nhận"</label>
                            }
                        </div>
                        <p class="hint">Tham số truyền cho client lượt này (0 = dùng cấu hình client). Thư mục video/ảnh luôn dùng của máy client.</p>
                        @* Nút hành động ở hàng riêng, khỏi trôi lơ lửng theo flex-wrap của hàng field.
                           CHỈ 1 trong 2 nút hiện tại 1 thời điểm: có việc (hoặc đang hủy dở) → nút Huỷ; rảnh → nút Ghim.
                           Trạng thái chuyển tiếp bám THEO CLIENT thật (lease) chứ không lạc quan theo DB:
                           • Ghim xong → "Đang giao việc…" (xanh) tới khi client nhận + chạy thật (lease xuất hiện).
                           • Huỷ → nút Huỷ DISABLED + "Đang hủy…" (đỏ) tới khi client dừng hẳn (lease biến mất) → về nút Ghim. *@
                        <div class="pin pinbtns">
                            @if (_hasWork || _canceling)
                            {
                                <button class="btn danger" disabled="@_canceling" @onclick="CancelSelected">✖ Huỷ việc (hub giao)</button>
                            }
                            else
                            {
                                <button class="btn primary" disabled="@(string.IsNullOrEmpty(_pinMachine) || string.IsNullOrEmpty(_pinOp) || _pinBlocked)" @onclick="Pin">📌 Ghim việc</button>
                            }
                        </div>
                        @if (_assigning)
                        {
                            <div class="busyline assigning"><span class="dot"></span> Đang giao việc @OpLabel(_activeAsn!.Op) cho máy <b>@AsnMachineName(_activeAsn!)</b>…</div>
                        }
                        else if (_canceling)
                        {
                            <div class="busyline canceling"><span class="dot"></span> Đang hủy — chờ máy <b>@(_shopLease?.Hostname ?? "client")</b> dừng hẳn…</div>
                        }
                        <div class="action">@_action</div>
                        @if (_pinBlocked)
                        {
                            <div class="warn">⚠ Máy này KHÁC máy đang giữ acc (<b>@_accountOwnerWarn</b>) — 1 acc chỉ chạy 1 máy. Chọn <b>@_accountOwnerWarn</b>, hoặc vào 🖥️ Máy client → Reset máy đó trước.</div>
                        }
                        else if (_manualLease is not null)
                        {
                            <div class="hint" style="margin-top:4px">▶ Shop đang <b>chạy TAY</b> trên máy <b>@_manualLease.Hostname</b> — hub KHÔNG huỷ việc chạy tay; dừng bằng nút ■ trong app trên máy đó (client sẽ tự báo hub khi dừng). Việc do <b>hub giao</b> mới huỷ được ở đây.</div>
                        }
                        else if (_accountOwnerWarn is not null)
                        {
                            <div class="hint" style="margin-top:4px">ℹ Acc đang do máy <b>@_accountOwnerWarn</b> dùng — ghim thêm nên vào máy đó.</div>
                        }
                    </div>
                }
            }
            else if (_tab == "stats")
            {
                <div class="opcards">
                    @foreach (var op in OpOrder)
                    {
                        var cell = FleetStateService.OpCell(Snap, row.AccountId, row.ShopId, op);
                        var st = row.Ops.GetValueOrDefault(op);
                        <div class="opcard @(st is null ? "empty0" : "")">
                            <div class="ohead">
                                <span class="olabel">@OpLabel(op)</span>
                                @* Đang chạy (lease sống) → ưu tiên chip ⏳+máy từ OpCell, kể cả khi ledger chưa có
                                   bản ghi (per-row chưa về / bị reset) — tránh báo "chưa chạy" gây hiểu nhầm. *@
                                @if (cell.Kind == 1)
                                {
                                    <span class="pill @cell.Css">@cell.Text</span>
                                }
                                else if (st is not null)
                                {
                                    <span class="pill @st.StatusCss">@st.StatusText</span>
                                }
                                else
                                {
                                    <span class="pill idle">chưa chạy</span>
                                }
                            </div>
                            @if (st is not null)
                            {
                                <div class="n">@st.RowCount.ToString("N0") <span class="sub">dòng</span>
                                    <button class="linkbtn" @onclick="() => OpenMap(op)">🔍 xem dòng</button>
                                </div>
                                <div class="sub">tới dòng @st.LastRow</div>
                                <div class="rng m-hide">@st.Ranges</div>
                                <div class="sub" title="@st.LastAbs">Gần nhất: @(string.IsNullOrEmpty(st.Machine) ? "—" : st.Machine)@(string.IsNullOrEmpty(st.LastAgo) ? "" : $" · {st.LastAgo}")</div>
                                @if (st.Machines.Count > 1)
                                {
                                    <div class="sub m-hide">Đã tham gia (@st.Machines.Count máy): @string.Join(", ", st.Machines)</div>
                                }
                            }
                            else if (cell.Kind == 1)
                            {
                                <div class="sub">Đang chạy — chưa có dòng nào báo về.</div>
                            }
                            else
                            {
                                <div class="sub">Chưa có lượt chạy nào cho việc này.</div>
                            }
                        </div>
                    }
                </div>
            }
            else if (_tab == "data")
            {
                <ProductGridPanel AccountId="@row.AccountId" Sheet="@row.Sheet" />
            }
            else
            {
                @if (row.InConfig)
                {
                    <ShopConfigPanel AccountId="@row.AccountId" ShopId="@row.ShopId" OnChanged="OnConfigChanged" OnDeleted="OnShopDeleted" />
                }
                else
                {
                    <p class="hint">Shop không còn trong cấu hình — chỉ xem tiến độ.</p>
                }
            }
        }
        else if (_selAcctId is not null)
        {
            @if (_tab == "action")
            {
                @* Dashboard gọn của ACC: 4 ô tổng quan theo op (tổng dòng + số shop ✓) + việc đang chạy +
                   máy giữ acc + ma-trận shop (trạng thái · số dòng, bấm dòng mở shop). Tab Thống kê mức acc
                   đã GỘP vào đây (dòng Tổng nằm cuối bảng). *@
                <div class="kpis acct">
                    @foreach (var op in OpOrder)
                    {
                        var s = AcctOpSummary(op);
                        <div class="kpi">
                            <div>
                                <div class="kpi-val">@s.Rows.ToString("N0")</div>
                                <div class="kpi-label">@OpLabel(op) · @s.Done/@s.Total shop ✓</div>
                            </div>
                        </div>
                    }
                </div>
                @foreach (var l in AcctLeases())
                {
                    <div class="busyline running"><span class="dot"></span> Đang chạy: <b>@ShopNameOf(l.ShopId)</b> · @OpLabel(l.Op) · máy <b>@l.Hostname</b></div>
                }
                @if (!AcctLeases().Any() && OwnerOf(_selAcctId!) is { } om)
                {
                    <div class="hint" style="margin:2px 0 8px">🔒 Acc đang do máy <b>@HostName(om)</b> giữ — việc mới của acc sẽ vào máy này.</div>
                }
                <div class="tablewrap" style="margin-top:10px">
                <table class="grid sm">
                    <thead><tr><th>Shop</th><th>Scrape</th><th>Import</th><th>Update</th><th>Tên SP</th></tr></thead>
                    <tbody>
                        @foreach (var r in AcctShops())
                        {
                            <tr @onclick="() => SelectShop(r)">
                                <td class="shop">@r.ShopName</td>
                                @foreach (var op in OpOrder)
                                {
                                    <td>
                                        @if (string.IsNullOrEmpty(r.Sheet))
                                        {
                                            <span class="sub">—</span>
                                        }
                                        else
                                        {
                                            var cell = FleetStateService.OpCell(Snap, r.AccountId, r.ShopId, op);
                                            var st = r.Ops.GetValueOrDefault(op);
                                            <span class="pill @cell.Css" title="@(st is null ? "" : $"{st.Machine} · {st.LastAgo}")">@cell.Text@(st is { RowCount: > 0 } ? $" · {st.RowCount:N0}" : "")</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                        @if (AcctShops().Any())
                        {
                            <tr class="acctrow">
                                <td>Tổng</td>
                                @foreach (var op in OpOrder)
                                {
                                    var tot = AcctShops().Sum(r => r.Ops.GetValueOrDefault(op)?.RowCount ?? 0);
                                    <td>@tot.ToString("N0")</td>
                                }
                            </tr>
                        }
                        else
                        {
                            <tr><td colspan="5" class="empty">Tài khoản chưa có shop nào.</td></tr>
                        }
                    </tbody>
                </table>
                </div>
            }
            else
            {
                @if (_accounts.Any(a => a.Id == _selAcctId))
                {
                    <AccountConfigPanel AccountId="@(_selAcctId!)" OnChanged="OnConfigChanged" OnDeleted="OnAcctDeleted" OnShopAdded="OnShopAdded" OnShopOpen="OnShopOpen" />
                    <DataStorePanel AccountId="@(_selAcctId!)" OnChanged="OnConfigChanged" />
                }
                else
                {
                    <p class="hint">Tài khoản không còn trong cấu hình (chỉ còn lịch sử).</p>
                }
            }
        }
        else
        {
            <p class="hint">Chọn 1 tài khoản hoặc shop ở danh sách bên trái.</p>
        }
    </div>
</div>
</div>

@if (_map is not null)
{
    <RowMapModal Title="@_map.Title" Op="@_map.Op" OpLabel="@_map.OpLabel" AccountId="@_map.AccountId"
                 Sheet="@_map.Sheet" Ledger="_map.Ledger" OnClose="() => _map = null" />
}

@code {
    // Cột lưới + thẻ Tiến độ (4 op). Đếm running/queued/failed cho summary CHỈ 3 op hub-điều-phối.
    private static readonly string[] OpOrder = ["scrape", "import", "update", "rewrite"];
    private static readonly string[] SummaryOps = ["scrape", "import", "update"];

    private List<BigSellerAccount> _accounts = new();
    private List<ShopRow> _rows = new();
    private string _summary = "";
    private int _kMachines, _kRunning, _kQueued, _kCookies;
    private DateTimeOffset _accountsLoadedAt;

    private string _search = "";
    // Selection master-detail: chọn shop set cả 2 (acct = của shop); chọn acc thì _selShopKey = null.
    private string? _selAcctId;
    private (string AccountId, string ShopId)? _selShopKey;
    private ShopRow? _selRow;
    private string _tab = "action";

    private string _pinOp = "";
    private string _pinMachine = "";
    private int _pinStart, _pinEnd;
    // Tham số chạy Hub đặt cho lượt này (mặc định = default của BigSellerRunConfig; 0 = client tự dùng cấu hình).
    private int _pinProcs = 2;
    private int _pinFrame = 10;
    private int _pinReload = 20;
    private bool _pinFromClaimed;
    private string _action = "";

    // Ngữ cảnh modal bản đồ dòng (heatmap) — mở modal = dựng ctx, đóng = null.
    private RowMapCtx? _map;
    private sealed record RowMapCtx(string Title, string Op, string OpLabel, string AccountId, string Sheet, WorkLedgerRecord? Ledger);

    private sealed record AcctGroup(string AccountId, string AccountName, List<ShopRow> Shops);

    private sealed class OpStat
    {
        public string StatusText = "", StatusCss = "", Ranges = "—", Machine = "", LastAgo = "", LastAbs = "";
        public int RowCount, LastRow;
        public List<string> Machines = new();   // hostnames đã tham gia việc này
    }

    private sealed class ShopRow
    {
        public string AccountId = "", AccountName = "", ShopId = "", ShopName = "", Sheet = "";
        public bool InConfig;
        public Dictionary<string, OpStat> Ops = new();
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        ReloadAccounts();
        Rebuild();
        RecomputeSummary();
    }

    // Modal heatmap dùng dữ liệu chụp lúc mở → dừng hẳn nhịp vẽ (cả StateHasChanged) khỏi diff 20k ô mỗi 2s.
    protected override bool ShouldTickRender() => _map is null;

    protected override void OnFleetTick()
    {
        // Config đọc lại tối đa mỗi 10s (khỏi đọc file mỗi 2s).
        if ((DateTimeOffset.UtcNow - _accountsLoadedAt).TotalSeconds > 10) ReloadAccounts();
        Rebuild();
        RecomputeSummary();
    }

    private void ReloadAccounts()
    {
        _accounts = Config.BigSellerAccounts();
        _accountsLoadedAt = DateTimeOffset.UtcNow;
        try { _kCookies = Db.ListFiles().Count(f => f.Name.StartsWith("cookies/", StringComparison.OrdinalIgnoreCase)); } catch { }
    }

    private void Rebuild()
    {
        var byId = _accounts.ToDictionary(a => a.Id, a => a);
        var shops = new Dictionary<string, ShopRow>(StringComparer.Ordinal);

        // 1) Từ config: mọi acct, MỌI shop (kể cả chưa gán sheet) → dòng danh sách (InConfig = true).
        //    Shop chưa sheet vẫn hiện (glyph ⚠) để đợt 2 còn cấu hình được — nhưng KHÔNG ghim/đặt-tay được.
        foreach (var acct in _accounts)
        foreach (var shop in acct.Shops)
        {
            shops[acct.Id + "__" + shop.Id] = new ShopRow
            {
                AccountId = acct.Id,
                AccountName = acct.DisplayName,
                ShopId = shop.Id,
                ShopName = shop.DisplayName,
                Sheet = shop.ShopeeDataSheet ?? "",
                InConfig = true,
            };
        }

        // 2) Overlay ledger: shop không còn trong config → dòng mồ côi (InConfig = false, chỉ xem tiến độ).
        foreach (var l in Snap.Ledger)
        {
            if (string.IsNullOrEmpty(l.BigsellerId)) continue;   // (search dùng bảng khác, không nằm ở ledger)
            byId.TryGetValue(l.BigsellerId, out var acct);
            var key = l.BigsellerId + "__" + l.ShopId;
            if (!shops.TryGetValue(key, out var row))
            {
                var shop = acct?.Shops.FirstOrDefault(s => s.Id == l.ShopId);
                row = new ShopRow
                {
                    AccountId = l.BigsellerId,
                    AccountName = acct?.DisplayName ?? ShortId(l.BigsellerId),
                    ShopId = l.ShopId,
                    ShopName = shop?.DisplayName ?? (string.IsNullOrWhiteSpace(l.Sheet) ? ShortId(l.ShopId) : l.Sheet),
                    Sheet = !string.IsNullOrWhiteSpace(shop?.ShopeeDataSheet) ? shop!.ShopeeDataSheet : (l.Sheet ?? ""),
                    InConfig = false,
                };
                shops[key] = row;
            }
            var (stText, stCss) = LedgerStatus(l.Status);
            var last = l.LastRunAt ?? l.UpdatedAt;
            row.Ops[l.Op] = new OpStat
            {
                StatusText = stText, StatusCss = stCss,
                RowCount = CountRows(l.Completed), LastRow = l.LastRowReached,
                Ranges = FormatRanges(l.Completed), Machine = Machine(l),
                LastAgo = FleetStateService.Ago(last),
                LastAbs = last == default ? "" : last.LocalDateTime.ToString("dd/MM/yyyy HH:mm:ss"),
                Machines = l.MachineIds.Select(HostName).Where(h => !string.IsNullOrEmpty(h)).Distinct().ToList(),
            };
        }

        _rows = shops.Values
            .OrderBy(r => r.AccountName, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(r => r.ShopName, StringComparer.CurrentCultureIgnoreCase)
            .ToList();

        // Giữ shop đang chọn qua các lần refresh (đọc lại tham chiếu mới theo key).
        _selRow = _selShopKey is { } k
            ? _rows.FirstOrDefault(r => r.AccountId == k.AccountId && r.ShopId == k.ShopId)
            : null;

        // Mặc định: chưa chọn gì → chọn acc đầu tiên theo thứ tự hiển thị (luôn có 1 mục được chọn).
        if (_selAcctId is null && _selShopKey is null)
            _selAcctId = OrderedGroups().FirstOrDefault()?.AccountId;
    }

    private void RecomputeSummary()
    {
        _kMachines = Snap.Machines.Count(m => (DateTimeOffset.Now - m.LastSeen).TotalSeconds < 45);
        int running = 0, queued = 0, failed = 0;
        foreach (var r in _rows)
        foreach (var op in SummaryOps)
        {
            var k = FleetStateService.OpCell(Snap, r.AccountId, r.ShopId, op).Kind;
            if (k == 1) running++; else if (k == 2) queued++; else if (k == 3) failed++;
        }
        // KPI phải KHỚP lưới → lấy từ cùng nguồn OpCell (không đếm Assignments.Status, field đó không mang "running").
        _kRunning = running;
        _kQueued = queued;
        var tScrape = _rows.Sum(r => r.Ops.GetValueOrDefault("scrape")?.RowCount ?? 0);
        var tImport = _rows.Sum(r => r.Ops.GetValueOrDefault("import")?.RowCount ?? 0);
        var tUpdate = _rows.Sum(r => r.Ops.GetValueOrDefault("update")?.RowCount ?? 0);
        var tRewrite = _rows.Sum(r => r.Ops.GetValueOrDefault("rewrite")?.RowCount ?? 0);
        _summary = $"{running} đang chạy · {queued} chờ · {failed} dừng/lỗi · {Snap.Machines.Count} máy · "
            + $"{tScrape:N0} scrape · {tImport:N0} import · {tUpdate:N0} update · {tRewrite:N0} tên SP · cập nhật {DateTimeOffset.Now:HH:mm:ss}";
    }

    // Nhóm shop theo account cho danh sách trái (gồm mồ côi + acc config chưa có shop nào), sắp theo tên acc.
    private List<AcctGroup> OrderedGroups()
    {
        var groups = _rows
            .GroupBy(r => r.AccountId)
            .ToDictionary(g => g.Key, g => new AcctGroup(g.Key, g.First().AccountName, g.ToList()));
        foreach (var a in _accounts)
            if (!groups.ContainsKey(a.Id))
                groups[a.Id] = new AcctGroup(a.Id, a.DisplayName, new List<ShopRow>());
        return groups.Values
            .OrderBy(g => g.AccountName, StringComparer.CurrentCultureIgnoreCase)
            .ToList();
    }

    // Lọc danh sách trái theo ô tìm: acc khớp → cả nhóm; shop khớp → shop + dòng acc; không khớp → ẩn nhóm.
    private IEnumerable<AcctGroup> Filtered()
    {
        var q = _search?.Trim() ?? "";
        var ordered = OrderedGroups();
        if (q.Length == 0) return ordered;
        var result = new List<AcctGroup>();
        foreach (var g in ordered)
        {
            if (g.AccountName.Contains(q, StringComparison.OrdinalIgnoreCase))
                result.Add(g);
            else
            {
                var matched = g.Shops.Where(s => s.ShopName.Contains(q, StringComparison.OrdinalIgnoreCase)).ToList();
                if (matched.Count > 0) result.Add(g with { Shops = matched });
            }
        }
        return result;
    }

    private List<ShopRow> AcctShops() =>
        _selAcctId is null ? new() : _rows.Where(r => r.AccountId == _selAcctId).ToList();

    // ── Dashboard gọn của acc (panel phải khi chưa chọn shop) ──
    /// <summary>Tổng quan 1 op trên toàn acc: tổng dòng đã làm + số shop đã ✓ / tổng shop.</summary>
    private (long Rows, int Done, int Total) AcctOpSummary(string op)
    {
        var shops = AcctShops();
        long rows = 0; var done = 0;
        foreach (var r in shops)
        {
            rows += r.Ops.GetValueOrDefault(op)?.RowCount ?? 0;
            if (FleetStateService.OpCell(Snap, r.AccountId, r.ShopId, op).Text.StartsWith("✓")) done++;
        }
        return (rows, done, shops.Count);
    }

    /// <summary>Lease sống của acc đang chọn — mỗi lease = 1 việc đang chạy thật (shop/op/máy).</summary>
    private List<LeaseRecord> AcctLeases() =>
        _selAcctId is null ? new() : Snap.Leases.Where(l => l.BigsellerId == _selAcctId).ToList();

    private string ShopNameOf(string shopId) =>
        _rows.FirstOrDefault(r => r.AccountId == _selAcctId && r.ShopId == shopId)?.ShopName
        ?? (shopId.Length > 8 ? shopId[..8] : shopId);

    // Tên acc hiển thị ở header (chọn acc-không-shop cũng lấy được tên từ config).
    private string AcctName =>
        _selRow?.AccountName
        ?? (_selAcctId is null ? ""
            : _rows.FirstOrDefault(r => r.AccountId == _selAcctId)?.AccountName
              ?? _accounts.FirstOrDefault(a => a.Id == _selAcctId)?.DisplayName
              ?? "");

    // Glyph trạng thái nhanh của shop cho danh sách trái.
    private string GlyphOf(ShopRow r)
    {
        if (r.InConfig && string.IsNullOrEmpty(r.Sheet)) return "⚠";
        var cells = SummaryOps.Select(op => FleetStateService.OpCell(Snap, r.AccountId, r.ShopId, op)).ToList();
        if (cells.Any(c => c.Kind == 1)) return "⏳";
        if (cells.Any(c => c.Kind == 3)) return "■";
        if (cells.All(c => c.Text.StartsWith("✓"))) return "✓";
        return "·";
    }

    // Shop có op ĐANG CHẠY? → danh sách trái tô nổi hẳn (nền xanh + chấm nhấp nháy + badge "chạy").
    private bool IsRunningShop(ShopRow r) =>
        SummaryOps.Any(op => FleetStateService.OpCell(Snap, r.AccountId, r.ShopId, op).Kind == 1);

    private string GlyphTitle(ShopRow r) =>
        r.InConfig && string.IsNullOrEmpty(r.Sheet)
            ? (IsHubAcct(r.AccountId) ? "thiếu ngăn dữ liệu" : "chưa gán sheet")
            : "";

    // Acc này đang ở chế độ kho Hub (Postgres) — dùng để chọn chữ hiển thị (né "sheet/workbook" của excel-mode).
    private bool IsHubAcct(string accountId) =>
        _accounts.FirstOrDefault(a => a.Id == accountId)?.UsesHubData == true;

    private void SelectShop(ShopRow r)
    {
        _selShopKey = (r.AccountId, r.ShopId);
        _selAcctId = r.AccountId;
        _selRow = r;
        _action = "";
    }

    private void SelectAcct(string accountId)
    {
        _selAcctId = accountId;
        _selShopKey = null;
        _selRow = null;
        _action = "";
        if (_tab is "stats" or "data") _tab = "action";   // mức acc không có tab Thống kê/Dữ liệu (chỉ ở mức shop)
    }

    // Thêm 1 acc BigSeller rỗng, lưu ngay (đọc list+version tươi), rồi chọn nó ở tab Cấu hình để điền tiếp.
    private void AddAccount()
    {
        var all = Config.BigSellerAccounts();
        var version = Config.VersionOf(FileStoreConfigService.BigSellerFile);
        // Acc tạo trên web hub mặc định dùng KHO HUB (Postgres) — bản mới không còn workbook Excel; excel-mode
        // chỉ còn là đường chuyển tiếp cho acc cũ (tạo từ client hoặc migrate dở).
        var acc = new BigSellerAccount { Label = "Tài khoản mới", DataSource = "hub" };
        all.Add(acc);
        ConfigSave.Apply(Config, FileStoreConfigService.BigSellerFile, all, ref version, () => { });
        ReloadAccounts();
        Rebuild();
        RecomputeSummary();
        SelectAcct(acc.Id);
        _tab = "config";
    }

    // Panel con báo đã lưu/đổi cấu hình → parent nạp lại + vẽ lại ngay (khỏi chờ nhịp 2s).
    private void OnConfigChanged()
    {
        ReloadAccounts();
        Rebuild();
        RecomputeSummary();
    }

    // "➕ Thêm"/🗑 xoá shop ở lưới AccountConfigPanel đã LƯU → chỉ rebuild list trái, KHÔNG nhảy panel (shop mới
    // dùng được ngay, khỏi ép user vào màn cấu hình).
    private void OnShopAdded()
    {
        ReloadAccounts();
        Rebuild();
        RecomputeSummary();
    }

    // Nút ⚙ trong lưới shop → chọn shop đó + mở tab Cấu hình nâng cao (ShopConfigPanel).
    private void OnShopOpen(string shopId)
    {
        ReloadAccounts();
        Rebuild();
        RecomputeSummary();
        var row = _rows.FirstOrDefault(r => r.AccountId == _selAcctId && r.ShopId == shopId);
        if (row is not null) { SelectShop(row); _tab = "config"; }
    }

    // Xoá shop → bỏ chọn shop (vẫn đứng ở acc); xoá acc → bỏ chọn hết (Rebuild tự chọn acc đầu).
    private void OnShopDeleted() { _selShopKey = null; _selRow = null; OnConfigChanged(); }
    private void OnAcctDeleted() { _selAcctId = null; _selShopKey = null; _selRow = null; OnConfigChanged(); }

    // Thế hệ của các combo đặt-tay ledger — nhảy sau mỗi lần đặt để @key đổi → element dựng lại về ⋯.
    private int _cellsetGen;

    private void SetLedger(string bs, string shop, string sheet, string op, string? status)
    {
        if (string.IsNullOrEmpty(status)) return;
        Db.SetLedgerStatus($"{bs}__{shop}__{op}", bs, shop, sheet, op, status);
        _cellsetGen++;
        FleetState.Refresh();
    }

    private void ToggleDispatch(ChangeEventArgs e)
    {
        Dispatcher.Enabled = e.Value is true;
        FleetState.Refresh();
    }

    /// <summary>Mở bản đồ dòng của 1 việc trên shop đang chọn: chỉ dựng ctx → RowMapModal tự đọc sheet + tô dòng.</summary>
    private void OpenMap(string op)
    {
        if (_selRow is null) return;
        var shop = _selRow;
        // Acc hub-mode: "sheet" là ngăn nội bộ (= GUID) → KHÔNG phô ra tiêu đề; chỉ excel-mode mới hiện tên sheet.
        var hub = _accounts.FirstOrDefault(a => a.Id == shop.AccountId)?.UsesHubData == true;
        var title = hub
            ? $"{OpLabel(op)} · {shop.ShopName}"
            : $"{OpLabel(op)} · {shop.ShopName} · sheet '{shop.Sheet}'";
        _map = new RowMapCtx(
            title, op, OpLabel(op), shop.AccountId, shop.Sheet,
            Snap.Ledger.FirstOrDefault(l => l.Key == $"{shop.AccountId}__{shop.ShopId}__{op}"));
    }

    private void Pin()
    {
        if (_selRow is null || string.IsNullOrEmpty(_pinMachine) || string.IsNullOrEmpty(_pinOp)) return;
        var payload = _pinOp == "import"
            ? JsonSerializer.Serialize(new ImportJobPayload { FromClaimedTab = _pinFromClaimed })
            : "";
        // FrameSize chỉ scrape đọc, Reload chỉ import/update đọc → op khác truyền 0 để sạch dữ liệu. Processes áp mọi op.
        Db.CreateAssignment(new CreateAssignmentRequest(
            _selRow.AccountId, _selRow.ShopId, _selRow.Sheet, _pinOp, _pinMachine, true,
            Math.Max(0, _pinStart), Math.Max(0, _pinEnd), payload,
            Processes: Math.Max(0, _pinProcs),
            FrameSize: _pinOp == "scrape" ? Math.Max(0, _pinFrame) : 0,
            ReloadSeconds: _pinOp is "import" or "update" ? Math.Max(0, _pinReload) : 0));
        var host = Snap.Machines.FirstOrDefault(m => m.MachineId == _pinMachine)?.Hostname ?? _pinMachine;
        _action = FleetStateService.MachineOffline(Snap, _pinMachine)
            ? $"⚠ Đã ghim {_pinOp} · {_selRow.ShopName} → {host} (máy đang TẮT — chờ tới khi mở app)."
            : $"✔ Đã ghim {_pinOp} · {_selRow.ShopName} → {host}.";
        FleetState.Refresh();
    }

    private void CancelSelected()
    {
        if (_selRow is null) return;
        var n = 0;
        foreach (var a in Snap.Assignments.Where(a =>
            a.BigsellerId == _selRow.AccountId && a.ShopId == _selRow.ShopId && a.Status is "queued" or "running"))
        { Db.CancelAssignment(a.Id); n++; }
        _action = $"✖ Đã huỷ {n} việc của shop {_selRow.ShopName}.";
        FleetState.Refresh();
    }

    // Assignment hub-giao ĐANG HIỆU LỰC (queued/running) của shop đang chọn — nguồn cho nút Huỷ + "Đang giao việc…".
    private Assignment? _activeAsn => _selRow is null ? null : Snap.Assignments.FirstOrDefault(a =>
        a.BigsellerId == _selRow.AccountId && a.ShopId == _selRow.ShopId && a.Status is "queued" or "running");

    // Shop đang chọn có việc HUB-GIAO (assignment) queued/running → hub huỷ được (khoá Ghim).
    private bool _hasWork => _activeAsn is not null;

    // Lease sống của shop = client THẬT SỰ đang chạy op trên máy (nguồn sự thật cho "đã chạy"/"đã dừng hẳn").
    private LeaseRecord? _shopLease => _selRow is null ? null
        : Snap.Leases.FirstOrDefault(l => l.BigsellerId == _selRow.AccountId && l.ShopId == _selRow.ShopId);

    // Đã ghim nhưng client CHƯA thật sự chạy (chưa có lease — đang chờ máy claim + khởi động) → "Đang giao việc…" (xanh).
    private bool _assigning => _activeAsn is not null && _shopLease is null;

    // Đã bấm Huỷ (assignment vừa 'canceled') nhưng client CHƯA dừng hẳn (lease cùng op còn sống) → nút Huỷ
    // DISABLED + "Đang hủy…" (đỏ); lease biến mất = hủy xong → về nút Ghim. Cửa sổ 15' tránh khớp nhầm bản
    // 'canceled' cũ (còn trong list 2h) với lần chạy TAY sau đó.
    private bool _canceling => _selRow is not null && _activeAsn is null && _shopLease is { } l
        && Snap.Assignments.Any(a => a.BigsellerId == _selRow.AccountId && a.ShopId == _selRow.ShopId
            && a.Status == "canceled" && a.Op == l.Op
            && (DateTimeOffset.UtcNow - a.UpdatedAt) < TimeSpan.FromMinutes(15));

    // Máy nhận việc để hiện ở "Đang giao việc…": đã claim thì tên máy claim, chưa thì máy được ghim.
    private string AsnMachineName(Assignment a) =>
        HostName(!string.IsNullOrEmpty(a.ClaimedByMachineId) ? a.ClaimedByMachineId : a.TargetMachineId ?? "");

    // Shop đang chọn có LEASE nhưng KHÔNG có assignment hub-giao (và không phải đang-hủy-dở) = việc CHẠY TAY trên
    // client. Hub không huỷ được (client tự dừng bằng nút ■ rồi nhả lease báo hub); chỉ hiện chú thích cho rõ.
    private LeaseRecord? _manualLease => (_selRow is null || _hasWork || _canceling) ? null : _shopLease;

    // Chủ sở hữu acc hiện tại (nếu có) — ràng buộc máy ghim được.
    private string? _accountOwnerMachine => _selRow is null ? null : OwnerOf(_selRow.AccountId);
    private string? _accountOwnerWarn => _accountOwnerMachine is { } mid
        ? Snap.Machines.FirstOrDefault(m => m.MachineId == mid)?.Hostname ?? mid : null;

    // Hiện MỌI máy trong dropdown; chỉ CHẶN (nút Ghim mờ + cảnh báo) khi chọn máy KHÁC máy đang giữ acc.
    private IEnumerable<MachinePresence> _pinnableMachines => Snap.Machines;

    /// <summary>Đang chọn máy KHÁC máy đang giữ acc → ghim sẽ bị khoá 1-acc-1-máy (việc nằm chờ mãi) → chặn.</summary>
    private bool _pinBlocked => _accountOwnerMachine is { } o && !string.IsNullOrEmpty(_pinMachine)
        && !string.Equals(_pinMachine, o, StringComparison.Ordinal);

    private string? OwnerOf(string bs)
    {
        // Máy đang giữ lease tươi hoặc assignment running của acc này.
        var lease = Snap.Leases.FirstOrDefault(l => l.BigsellerId == bs);
        if (lease is not null) return lease.MachineId;
        var asn = Snap.Assignments.FirstOrDefault(a => a.BigsellerId == bs && a.Status == "running");
        return asn?.ClaimedByMachineId;
    }

    private string Machine(WorkLedgerRecord l)
    {
        if (!string.IsNullOrEmpty(l.LastMachineId))
        {
            var m = Snap.Machines.FirstOrDefault(x => x.MachineId == l.LastMachineId);
            if (m is not null && !string.IsNullOrWhiteSpace(m.Hostname)) return m.Hostname;
        }
        return string.IsNullOrWhiteSpace(l.LastHostname) ? "" : l.LastHostname;
    }

    private string HostName(string machineId)
    {
        if (string.IsNullOrEmpty(machineId)) return "";
        var m = Snap.Machines.FirstOrDefault(x => x.MachineId == machineId);
        return m is not null && !string.IsNullOrWhiteSpace(m.Hostname) ? m.Hostname : ShortId(machineId);
    }

    private static (string text, string css) LedgerStatus(string s) => s switch
    {
        "completed" => ("✓ xong", "done"),
        "stopped" => ("■ dừng dở", "warn"),
        "running" => ("⏳ đang chạy", "run"),
        _ => ("· chưa xong", "idle"),
    };

    private static string OpLabel(string op) => op switch
    {
        "scrape" => "Scrape", "import" => "Import", "update" => "Update", "rewrite" => "Tên SP", _ => op,
    };

    private static int CountRows(List<RowRange> rr) => rr.Sum(r => Math.Max(0, r.To - r.From + 1));

    private static string FormatRanges(List<RowRange> rr) => rr.Count == 0
        ? "—"
        : string.Join(", ", rr.OrderBy(r => r.From).Select(r => r.From == r.To ? $"{r.From}" : $"{r.From}–{r.To}"));

    private static string ShortId(string id) => string.IsNullOrEmpty(id) ? "?" : (id.Length <= 8 ? id : id[..8] + "…");

}
