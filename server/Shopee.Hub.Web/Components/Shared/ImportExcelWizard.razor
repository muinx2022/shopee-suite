@* Nút "⬆ Nhập Excel" + modal WIZARD nhập Excel vào 1 shop — DÙNG CHUNG cho lưới per-shop (ProductGridPanel: đích
   CỐ ĐỊNH qua FixedAcct/FixedSheet, ẩn selector) và trang /data (AllData: chọn Acc/Shop ngay trong form, prefill từ
   bộ lọc). Flow: upload → chọn sheet → xem trước → map 6 cột → khoảng dòng → Ghi đè/Nối thêm → checkbox tự sinh SKU
   thiếu (mặc định BẬT) → OK (pre-check trùng nội bộ ở ProductDb). Blazor gọi THẲNG ProductDb; ProductDb có thể chưa
   đăng ký DI → resolve qua IServiceProvider. LƯU Ý: component có thể được đặt TRONG .editcard (ProductGridPanel) →
   MỌI input trong modal PHẢI có width tường minh (.ci / inline) hoặc là checkbox, kẻo dính .editcard input{width:100%}. *@
@using Microsoft.Extensions.DependencyInjection
@inject FileStoreConfigService Config
@inject IServiceProvider Sp
@inject IJSRuntime JS

<label class="btn sm" style="@(BtnDisabled ? "opacity:.45;cursor:not-allowed" : "")">⬆ Nhập Excel
    <InputFile OnChange="OnFile" accept=".xlsx" disabled="@BtnDisabled" style="display:none" />
</label>

@if (_open)
{
    @* KHÔNG đóng khi bấm ra backdrop (dễ nhầm mất dữ liệu đang nhập) — chỉ ✕ / Huỷ / OK-thành-công mới đóng. *@
    <div class="modal-overlay">
        <div class="modal wide" @onclick:stopPropagation="true">
            <div class="modal-head">
                <span>⬆ Nhập Excel vào shop</span>
                <button class="linkbtn" title="Đóng" @onclick="Cancel">✕</button>
            </div>
            <div class="modal-body">
                @* Chọn đích (chỉ khi KHÔNG cố định) — 2 select Acc/Shop đầu form, prefill từ bộ lọc. *@
                @if (!Fixed)
                {
                    <div style="display:flex;flex-wrap:wrap;gap:10px 16px;align-items:flex-end">
                        <label style="@MapLbl">Tài khoản *
                            <select value="@_selAcct" @onchange="OnSelAcct" disabled="@_wizBusy" style="width:220px">
                                <option value="">— chọn tài khoản —</option>
                                @foreach (var a in _accounts) { <option value="@a.Id">@a.DisplayName</option> }
                            </select>
                        </label>
                        <label style="@MapLbl">Shop *
                            <select value="@_selSheet" @onchange="OnSelSheet" disabled="@(_wizBusy || string.IsNullOrEmpty(_selAcct))" style="width:220px">
                                <option value="">— chọn shop —</option>
                                @foreach (var s in SelShopOptions()) { <option value="@s.ShopeeDataSheet">@s.DisplayName</option> }
                            </select>
                        </label>
                    </div>
                }

                <div class="wbrow">
                    <span class="wblabel">📄 File:</span>
                    <span class="wbname">@_wizFileName</span>
                    <span class="wblabel" style="margin-left:auto">Sheet:</span>
                    <select value="@_wizSheet" @onchange="WizSelectSheet" disabled="@(_wizBusy || _wizSheets.Count == 0)" style="width:220px">
                        @foreach (var sh in _wizSheets)
                        {
                            <option value="@sh">@sh</option>
                        }
                    </select>
                </div>

                @if (!string.IsNullOrEmpty(_wizError))
                {
                    <div class="warn">@_wizError</div>
                }
                @if (Pg is not { IsReady: true })
                {
                    <div class="warn">Postgres chưa sẵn sàng — xem trước được nhưng chưa nhập được.</div>
                }

                <div class="subhead">Xem trước (@_wizPreview.Count dòng đầu)</div>
                <div class="tablewrap" style="max-height:210px">
                    <table class="grid sm">
                        <thead>
                            <tr>
                                <th style="width:52px">Dòng</th>
                                @foreach (var c in _wizCols) { <th>@c</th> }
                            </tr>
                        </thead>
                        <tbody>
                            @if (_wizPreview.Count == 0)
                            {
                                <tr><td colspan="@(_wizCols.Count + 1)" class="empty">Sheet không có dòng dữ liệu.</td></tr>
                            }
                            else
                            {
                                @foreach (var (rowNo, cells) in _wizPreview)
                                {
                                    <tr>
                                        <td>@rowNo</td>
                                        @foreach (var cell in cells)
                                        {
                                            <td style="@Clip" title="@cell">@cell</td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="subhead">Ánh xạ cột (1-based, 0 = bỏ trường)</div>
                <div style="display:flex;flex-wrap:wrap;gap:10px 16px;align-items:flex-end">
                    <label style="@MapLbl">Link <input type="number" @bind="_wizLink" class="ci" /></label>
                    <label style="@MapLbl">Giá bán <input type="number" @bind="_wizPrice" class="ci" /></label>
                    <label style="@MapLbl">SKU <input type="number" @bind="_wizSku" class="ci" /></label>
                    <label style="@MapLbl">Item ID <input type="number" @bind="_wizItem" class="ci" /></label>
                    <label style="@MapLbl">Tên gốc <input type="number" @bind="_wizName" class="ci" /></label>
                    <label style="@MapLbl">Tên đã sửa <input type="number" @bind="_wizRewritten" class="ci" /></label>
                </div>
                <p class="hint">Các cột phụ (giá gốc, danh mục, rating…) đọc theo vị trí chuẩn B, H..Q nếu có.</p>

                <div style="display:flex;flex-wrap:wrap;gap:10px 16px;align-items:flex-end">
                    <label style="@MapLbl">Từ dòng <input type="number" @bind="_wizFrom" class="ci" /></label>
                    <label style="@MapLbl">Đến dòng <input type="number" @bind="_wizTo" class="ci" /></label>
                    <span class="hint" style="margin:0 0 4px">(dòng 1 là tiêu đề; đến dòng 0 = hết)</span>
                    <label style="@MapLbl">Chế độ
                        <select @bind="_wizMode" style="width:180px">
                            <option value="replace">Ghi đè (thay toàn bộ)</option>
                            <option value="append">Nối thêm (vào cuối)</option>
                        </select>
                    </label>
                    <label class="toggle" style="margin:0 0 4px"><input type="checkbox" @bind="_wizFillSku" /> Tự sinh SKU cho dòng thiếu (B#####)</label>
                </div>
            </div>
            <div class="modal-foot">
                @if (_wizBusy) { <span class="action">⏳ đang xử lý…</span> }
                <button class="btn" @onclick="Cancel" disabled="@_wizBusy">Huỷ</button>
                <button class="btn primary" @onclick="Import"
                        disabled="@(_wizBusy || Pg is not { IsReady: true } || _wizSheets.Count == 0 || string.IsNullOrEmpty(_wizSheet) || string.IsNullOrEmpty(TargetAcct) || string.IsNullOrEmpty(TargetSheet))">OK — Nhập</button>
            </div>
        </div>
    </div>
}

@code {
    // Đích CỐ ĐỊNH (per-shop): set cả 2 → ẩn selector Acc/Shop. Null → cho chọn trong form (prefill từ bộ lọc /data).
    [Parameter] public string? FixedAcct { get; set; }
    [Parameter] public string? FixedSheet { get; set; }
    [Parameter] public string? PrefillAcct { get; set; }
    [Parameter] public string? PrefillSheet { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<ImportResult> OnImported { get; set; }

    /// <summary>Kết quả nhập trả về parent: thông điệp + có phải ghi đè (parent per-shop dùng để về trang 1/cuối) + số dòng.</summary>
    public sealed record ImportResult(string Message, bool Replace, int Count);

    private const int PreviewRows = 5;   // số dòng dữ liệu hiện trong bảng xem trước
    private const string Clip = "max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap";
    // Label cột dọc trong modal (modal-body label mặc định display:block → ép flex-column cho input nằm dưới chữ).
    private const string MapLbl = "display:flex;flex-direction:column;gap:4px;margin:0;font-size:12.5px";

    private bool _open, _wizBusy;
    private byte[]? _wizBytes;
    private string _wizFileName = "", _wizSheet = "", _wizError = "", _wizMode = "replace";
    private List<string> _wizSheets = new(), _wizCols = new();
    private List<(int RowNo, List<string> Cells)> _wizPreview = new();
    // Ánh xạ 6 field nghiệp vụ (1-based; 0 = bỏ) — mặc định = ColumnOverrides.Default (1,3,4,5,6,7).
    private int _wizLink = 1, _wizPrice = 3, _wizSku = 4, _wizItem = 5, _wizName = 6, _wizRewritten = 7;
    private int _wizFrom = 2, _wizTo;   // khoảng dòng; _wizTo = 0 = hết
    private bool _wizFillSku = true;    // tự sinh SKU 'B#####' cho dòng file thiếu SKU (mặc định BẬT)
    // Đích chọn trong form (khi không cố định).
    private string _selAcct = "", _selSheet = "";
    private List<BigSellerAccount> _accounts = new();

    private ProductDb? Pg => Sp.GetService<ProductDb>();
    private bool Fixed => !string.IsNullOrEmpty(FixedAcct) && !string.IsNullOrEmpty(FixedSheet);
    private bool BtnDisabled => Disabled || _wizBusy;
    private string TargetAcct => Fixed ? FixedAcct! : _selAcct;
    private string TargetSheet => Fixed ? FixedSheet! : _selSheet;

    private IEnumerable<BigSellerShop> SelShopOptions() =>
        _accounts.FirstOrDefault(a => a.Id == _selAcct)?.Shops.Where(s => !string.IsNullOrWhiteSpace(s.ShopeeDataSheet))
        ?? Enumerable.Empty<BigSellerShop>();

    private void OnSelAcct(ChangeEventArgs e) { _selAcct = e.Value?.ToString() ?? ""; _selSheet = ""; }
    private void OnSelSheet(ChangeEventArgs e) => _selSheet = e.Value?.ToString() ?? "";

    // Chọn file → KHÔNG import ngay: đọc bytes (256MB), Task.Run lấy tên sheet + xem trước sheet đầu → MỞ modal.
    private async Task OnFile(InputFileChangeEventArgs e)
    {
        if (_wizBusy) return;
        // Đọc file + xem trước KHÔNG cần Postgres (chỉ ParseSheet); chỉ bước Import (OK) mới gated theo Pg.
        var file = e.File;
        _wizBusy = true; _wizError = "";
        try
        {
            byte[] bytes;
            await using (var s = file.OpenReadStream(maxAllowedSize: 256L * 1024 * 1024))
            using (var buf = new MemoryStream())
            {
                await s.CopyToAsync(buf);
                bytes = buf.ToArray();
            }

            var load = await Task.Run(() =>
            {
                try
                {
                    List<string> sheets;
                    using (var ms = new MemoryStream(bytes)) sheets = ProductXlsxCodec.ListSheetNames(ms);
                    if (sheets.Count == 0)
                        return (sheets, "", new List<string>(), new List<(int, List<string>)>(), "File không có worksheet nào.");
                    var s0 = sheets[0];
                    using var msp = new MemoryStream(bytes);
                    var pv = ProductXlsxCodec.PreviewSheet(msp, s0, PreviewRows);
                    return (sheets, s0, pv.ColLetters, pv.Rows, "");
                }
                catch (Exception ex)
                {
                    return (new List<string>(), "", new List<string>(), new List<(int, List<string>)>(), "Không đọc được file: " + ex.Message);
                }
            });

            // Nạp state modal + reset map/khoảng dòng/chế độ về mặc định cho lần nhập này.
            _wizBytes = bytes; _wizFileName = file.Name;
            _wizSheets = load.Item1; _wizSheet = load.Item2; _wizCols = load.Item3; _wizPreview = load.Item4; _wizError = load.Item5;
            _wizLink = 1; _wizPrice = 3; _wizSku = 4; _wizItem = 5; _wizName = 6; _wizRewritten = 7;
            _wizFrom = 2; _wizTo = 0; _wizMode = "replace"; _wizFillSku = true;
            // Đích chọn-trong-form → nạp accounts + prefill từ bộ lọc.
            if (!Fixed)
            {
                _accounts = Config.BigSellerAccounts();
                _selAcct = PrefillAcct ?? "";
                _selSheet = PrefillSheet ?? "";
            }
            _open = true;   // mở modal kể cả khi có lỗi (báo lỗi trong modal, không đóng)
        }
        catch (Exception ex) { _wizError = "✘ Lỗi đọc file: " + ex.Message; _open = true; }
        finally { _wizBusy = false; }
    }

    // Đổi sheet trong modal → parse lại xem trước (Task.Run). Lỗi → báo trong modal, giữ modal mở.
    private async Task WizSelectSheet(ChangeEventArgs e)
    {
        _wizSheet = e.Value?.ToString() ?? "";
        if (_wizBytes is null || string.IsNullOrEmpty(_wizSheet)) return;
        _wizBusy = true; _wizError = "";
        try
        {
            var bytes = _wizBytes; var sheet = _wizSheet;
            var res = await Task.Run(() =>
            {
                try { using var ms = new MemoryStream(bytes); var pv = ProductXlsxCodec.PreviewSheet(ms, sheet, PreviewRows); return (pv.ColLetters, pv.Rows, ""); }
                catch (Exception ex) { return (new List<string>(), new List<(int, List<string>)>(), "Không đọc được sheet: " + ex.Message); }
            });
            _wizCols = res.Item1; _wizPreview = res.Item2; _wizError = res.Item3;
        }
        finally { _wizBusy = false; }
    }

    private void Cancel() { _open = false; _wizBytes = null; _wizError = ""; }

    // OK → confirm chế độ → ParseSheet(bytes, sheet, ov, from, to) → (fill SKU thiếu) → ImportIntoSheetAsync. Ghi đè giữ
    // RowNo từ ParseSheet; nối thêm để ProductDb tự cấp row_no từ max+1. Lỗi → giữ modal. Xong → bắn OnImported.
    private async Task Import()
    {
        if (_wizBusy || _wizBytes is null || string.IsNullOrEmpty(_wizSheet)) return;
        var pg = Pg;
        if (pg is null || !pg.IsReady) return;
        var acct = TargetAcct; var dest = TargetSheet;
        if (string.IsNullOrEmpty(acct) || string.IsNullOrEmpty(dest)) { _wizError = "Chọn tài khoản + shop đích."; return; }
        var replace = !string.Equals(_wizMode, "append", StringComparison.Ordinal);
        if (!await JS.InvokeAsync<bool>("confirm", replace
                ? $"Nhập từ sheet '{_wizSheet}' theo GHI ĐÈ — XOÁ toàn bộ dòng hiện có của shop rồi nạp phần đã chọn. Tiếp tục?"
                : $"Nhập từ sheet '{_wizSheet}' theo NỐI THÊM — thêm phần đã chọn vào cuối shop. Tiếp tục?"))
            return;

        _wizBusy = true; _wizError = "";
        try
        {
            var bytes = _wizBytes; var sheet = _wizSheet; var src = _wizFileName; var from = _wizFrom; var to = _wizTo;
            var ov = new ProductXlsxCodec.ColumnOverrides(
                Math.Max(0, _wizLink), Math.Max(0, _wizPrice), Math.Max(0, _wizSku),
                Math.Max(0, _wizItem), Math.Max(0, _wizName), Math.Max(0, _wizRewritten));

            var rows = await Task.Run(() => { using var ms = new MemoryStream(bytes); return ProductXlsxCodec.ParseSheet(ms, sheet, ov, from, to); });
            // Tự sinh SKU 'B#####' cho dòng file THIẾU SKU (nếu bật) → dòng nào cũng đạt chuẩn per-shop trước khi ghi.
            var filled = 0;
            if (_wizFillSku) (rows, filled) = await Task.Run(() => pg.FillMissingSkusAsync(acct, dest, rows, CancellationToken.None));
            var count = await Task.Run(() => pg.ImportIntoSheetAsync(acct, dest, rows, replace, src, "hub-web", CancellationToken.None));

            _open = false; _wizBytes = null;
            var msg = $"✔ Đã nhập {count:N0} dòng vào shop ({(replace ? "ghi đè" : "nối thêm")})"
                + (filled > 0 ? $" — tự sinh SKU cho {filled:N0} dòng thiếu." : ".");
            await OnImported.InvokeAsync(new ImportResult(msg, replace, count));
        }
        catch (Exception ex) { _wizError = "✘ Lỗi nhập: " + ProductDb.Friendly(ex); }
        finally { _wizBusy = false; }
    }
}
