<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Shopee.Suite.MainWindow"
        Title="Shopee Suite" Width="1500" Height="940" MinWidth="1080" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="{DynamicResource UiFont}">

    <Grid RowDefinitions="56,*">
        <!-- ══════════ TOP APP BAR ══════════ -->
        <Border Grid.Row="0" ZIndex="1" Background="{DynamicResource SidebarBackgroundBrush}"
                BoxShadow="0 1 6 0 #22000000">
            <Grid ColumnDefinitions="Auto,*">
                <!-- Brand — bấm để quay về màn hình Welcome -->
                <Button Grid.Column="0" Classes="brand" VerticalAlignment="Stretch"
                        Command="{Binding GoHomeCommand}" ToolTip.Tip="Về màn hình chính">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" CornerRadius="9" Background="{DynamicResource AccentBrush}">
                            <TextBlock Text="S" FontSize="18" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Shopee Suite" FontSize="15" FontWeight="SemiBold" Foreground="White"
                                   Margin="11,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Vạch ngăn brand ↔ tab -->
                <Border Grid.Column="0" Width="1" HorizontalAlignment="Right" Margin="0,14"
                        Background="{DynamicResource SidebarItemHoverBrush}" />

                <!-- Tab module (ngang, cuộn ngang nếu tràn) -->
                <ListBox Grid.Column="1" Classes="topnav" VerticalAlignment="Center" Margin="6,0"
                         ItemsSource="{Binding Modules}" SelectedItem="{Binding Selected}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding Subtitle}">
                                <TextBlock Classes="emoji" Text="{Binding Glyph}" FontSize="15"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding NavTitle}" FontSize="13" FontWeight="SemiBold"
                                           Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ══════════ CONTENT ══════════ -->
        <ContentControl Grid.Row="1" Content="{Binding Current}" />
    </Grid>
</Window>
