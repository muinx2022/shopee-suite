<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Shopee.Suite.MainWindow"
        Title="Shopee Suite" Width="1240" Height="780" MinWidth="980" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="{DynamicResource UiFont}">

    <Grid ColumnDefinitions="244,*">
        <!-- ══════════ SIDEBAR ══════════ -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}">
            <DockPanel>
                <!-- Brand header -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource SidebarHeaderBrush}" Height="76">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                        <Border Width="38" Height="38" CornerRadius="10" Background="{DynamicResource AccentBrush}">
                            <TextBlock Text="S" FontSize="20" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Shopee Suite" FontSize="15.5" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="Bộ công cụ hợp nhất" FontSize="11"
                                       Foreground="{DynamicResource SidebarMutedBrush}" Margin="0,1,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="MODULE" FontSize="10.5" FontWeight="SemiBold"
                           Foreground="{DynamicResource SidebarMutedBrush}" Margin="20,16,0,8" />

                <!-- (Đã bỏ badge vai trò HUB/CLIENT/NONE — app chỉ còn là client, không xác định Hub trên app.) -->

                <!-- Nav list -->
                <ListBox Classes="nav" ItemsSource="{Binding Modules}" SelectedItem="{Binding Selected}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10"
                                        Background="{DynamicResource SidebarItemHoverBrush}" VerticalAlignment="Center">
                                    <TextBlock Classes="emoji" Text="{Binding Glyph}" FontSize="17"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SidebarTextBrush}" />
                                    <TextBlock Text="{Binding Subtitle}" FontSize="10.5"
                                               Foreground="{DynamicResource SidebarMutedBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ══════════ CONTENT ══════════ -->
        <ContentControl Grid.Column="1" Content="{Binding Current}" />
    </Grid>
</Window>
