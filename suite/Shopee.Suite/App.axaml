<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Shopee.Suite.App"
             xmlns:vm="using:Shopee.Suite.ViewModels"
             xmlns:views="using:Shopee.Suite.Views"
             xmlns:ws="using:Shopee.Suite.Modules.Workspace"
             xmlns:bs="using:Shopee.Suite.Modules.BigSeller"
             xmlns:data="using:Shopee.Suite.Modules.Data"
             xmlns:srch="using:Shopee.Suite.Modules.Search"
             xmlns:acc="using:Shopee.Suite.Modules.Accounts"
             xmlns:ca="using:Shopee.Suite.Modules.CheckAccount"
             xmlns:fleet="using:Shopee.Suite.Modules.Fleet"
             xmlns:settings="using:Shopee.Suite.Modules.Settings"
             xmlns:conv="using:Shopee.Suite.Infrastructure"
             xmlns:ordersRoot="using:XuLyDonShopee.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <conv:CountToBoolConverter x:Key="CountToBool" />
        <conv:StringToBoolConverter x:Key="StringToBool" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <StyleInclude Source="/Themes/Theme.axaml" />
    </Application.Styles>

    <Application.DataTemplates>
        <!-- ViewModel-first navigation. Đã port: Welcome, ComingSoon. -->
        <DataTemplate DataType="vm:WelcomeViewModel"><views:WelcomeView /></DataTemplate>
        <DataTemplate DataType="vm:ComingSoonViewModel"><views:ComingSoonView /></DataTemplate>

        <!-- GĐ5: 7 module view Avalonia thật. -->
        <DataTemplate DataType="ws:WorkspaceViewModel"><ws:WorkspaceView /></DataTemplate>
        <DataTemplate DataType="bs:BigSellerViewModel"><bs:BigSellerView /></DataTemplate>
        <DataTemplate DataType="data:DataViewModel"><data:DataView /></DataTemplate>
        <DataTemplate DataType="srch:SearchViewModel"><srch:SearchView /></DataTemplate>
        <DataTemplate DataType="acc:AccountsViewModel"><acc:AccountsView /></DataTemplate>
        <DataTemplate DataType="ca:CheckAccountViewModel"><ca:CheckAccountView /></DataTemplate>
        <DataTemplate DataType="fleet:FleetViewModel"><fleet:FleetView /></DataTemplate>
        <DataTemplate DataType="settings:SettingsViewModel"><settings:SettingsView /></DataTemplate>

        <!-- Module "Xử lý đơn Shopee" (phase 1b): ViewLocator reflection của app đơn hàng — Match CHỈ nhận
             XuLyDonShopee.App.ViewModels.ViewModelBase nên KHÔNG hijack VM của suite; các DataTemplate tường
             minh ở trên vẫn thắng cho VM suite. Resolve MainViewModel → Views.MainView (UserControl). -->
        <ordersRoot:ViewLocator />
    </Application.DataTemplates>
</Application>
