<Window
    x:Class="Shopee.Suite.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Shopee.Suite.ViewModels"
    Title="Shopee Suite" Height="1040" Width="1480"
    MinHeight="720" MinWidth="1180"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource WindowBackgroundBrush}"
    FontFamily="{StaticResource UiFont}">

    <Window.DataContext>
        <vm:ShellViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="288" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════ SIDEBAR ══════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <DockPanel>
                <!-- Brand header -->
                <Border DockPanel.Dock="Top" Background="{StaticResource SidebarHeaderBrush}" Height="92">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="22,0">
                        <Border Width="46" Height="46" CornerRadius="12" Background="{StaticResource AccentBrush}">
                            <TextBlock Text="S" FontSize="24" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Shopee Suite" FontSize="18.5" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="Bộ công cụ hợp nhất" FontSize="12"
                                       Foreground="{StaticResource SidebarMutedBrush}" Margin="0,1,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="MODULE" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource SidebarMutedBrush}" Margin="24,20,0,10" />

                <!-- Badge vai trò máy: HUB / CLIENT / NONE (đáy sidebar) -->
                <Border DockPanel.Dock="Bottom" Margin="18,10,18,16" CornerRadius="10" Padding="12,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#3A3F4B" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RoleBadge}" Value="HUB">
                                    <Setter Property="Background" Value="#1E5AA8" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RoleBadge}" Value="CLIENT">
                                    <Setter Property="Background" Value="#1E7D46" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🖥" FontFamily="Segoe UI Emoji" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding RoleBadge}" FontSize="13.5" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Nav list -->
                <ListBox x:Name="NavList"
                         Background="Transparent" BorderThickness="0"
                         ItemsSource="{Binding Modules}"
                         SelectedItem="{Binding Selected}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="12,3" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" CornerRadius="11" Background="Transparent" Padding="6,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="bar" Grid.Column="0" Width="3" Height="26" CornerRadius="2"
                                                        Background="Transparent" Margin="0,0,8,0" HorizontalAlignment="Left" VerticalAlignment="Center" />
                                                <Border x:Name="chip" Grid.Column="1" Width="42" Height="42" CornerRadius="11"
                                                        Background="{StaticResource SidebarItemHoverBrush}" VerticalAlignment="Center">
                                                    <TextBlock x:Name="glyph" Text="{Binding Glyph}"
                                                               FontFamily="Segoe UI Emoji" FontSize="19"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="2" Margin="14,0,8,0" VerticalAlignment="Center">
                                                    <TextBlock x:Name="title" Text="{Binding Title}" FontSize="14.5" FontWeight="SemiBold"
                                                               Foreground="{StaticResource SidebarTextBrush}" />
                                                    <TextBlock Text="{Binding Subtitle}" FontSize="11.5"
                                                               Foreground="{StaticResource SidebarMutedBrush}"
                                                               TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background"
                                                        Value="{StaticResource SidebarItemHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#FF2A3042" />
                                                <Setter TargetName="bar" Property="Background" Value="{StaticResource AccentBrush}" />
                                                <Setter TargetName="chip" Property="Background" Value="{StaticResource AccentBrush}" />
                                                <Setter TargetName="title" Property="Foreground" Value="White" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ══════════ CONTENT ══════════ -->
        <ContentControl Grid.Column="1" Content="{Binding Current}" Margin="0" />
    </Grid>
</Window>
