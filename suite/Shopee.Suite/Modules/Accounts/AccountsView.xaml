<UserControl
    x:Class="Shopee.Suite.Modules.Accounts.AccountsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root" Unloaded="OnUnloaded">
    <Grid Margin="28,22,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Tài khoản &amp; Proxy" Style="{StaticResource H1}" />
                <TextBlock Text="Kho tài khoản Shopee dùng chung — Scrape và Search đều chạy trên danh sách này."
                           Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{StaticResource SubtleBrush}" CornerRadius="14" Padding="14,6">
                <TextBlock Text="{Binding Status}" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="420" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: list + toolbar -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <!-- Quản lý danh sách CHỈ trên Hub/standalone; client read-only (chỉ xem + xử lý captcha + Đồng bộ). -->
                    <Button Style="{StaticResource SuccessButton}" Content="+  Thêm" MinWidth="80"
                            Command="{Binding AddCommand}"
                            Visibility="{Binding IsFullEditMode, Converter={StaticResource BoolToVis}}" />
                    <Button Style="{StaticResource DangerButton}" Content="−  Xóa" MinWidth="80"
                            Margin="8,0,0,0" Command="{Binding DeleteCommand}"
                            CommandParameter="{Binding SelectedItems, ElementName=AccountsGrid}"
                            Visibility="{Binding IsFullEditMode, Converter={StaticResource BoolToVis}}" />
                    <Button Content="⬇  Import…" Margin="8,0,0,0" Command="{Binding ImportCommand}"
                            Visibility="{Binding IsFullEditMode, Converter={StaticResource BoolToVis}}" />
                    <Button Content="⟲  Đồng bộ acc" Margin="8,0,0,0" Command="{Binding SyncFromHubCommand}"
                            Visibility="{Binding IsHubClient, Converter={StaticResource BoolToVis}}"
                            ToolTip="Kéo tài khoản + proxy + cookie từ Hub về máy này (gộp/append, không nhân đôi)." />
                    <TextBlock Text="Hiện:" VerticalAlignment="Center" Margin="16,0,6,0" Style="{StaticResource Caption}" />
                    <ComboBox MinWidth="150" VerticalAlignment="Center"
                              SelectedItem="{Binding SelectedFilter}" ItemsSource="{Binding FilterOptions}" />
                    <TextBlock Text="Mẹo: bấm đúp 1 acc lỗi để mở giải captcha." VerticalAlignment="Center" Margin="16,0,0,0"
                               Style="{StaticResource Caption}" Visibility="{Binding IsErrorFilter, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <!-- Kho KiotProxy dùng chung — xoay vòng gán cho acc lúc chạy (CHỈ Hub/standalone sửa; client nhận) -->
                <Border DockPanel.Dock="Bottom" Style="{StaticResource Card}" Padding="12,10" Margin="0,10,0,0"
                        Visibility="{Binding IsFullEditMode, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Kho KiotProxy dùng chung (xoay vòng lúc chạy)"
                                       Style="{StaticResource H2}" VerticalAlignment="Center" />
                            <Button HorizontalAlignment="Right" Style="{StaticResource PrimaryButton}"
                                    Content="💾  Lưu proxy" MinWidth="110" Command="{Binding SaveProxyPoolCommand}" />
                        </Grid>
                        <TextBlock Style="{StaticResource Caption}" Margin="0,2,0,6" TextWrapping="Wrap"
                                   Text="Mỗi dòng 1 KiotProxy key hoặc host:port. Lúc chạy: acc thứ i → proxy thứ (i mod số proxy). Máy Hub quản lý; client tự nhận (sửa ở client sẽ bị Hub ghi đè)." />
                        <TextBox Style="{StaticResource MonoTextBox}" Height="90" AcceptsReturn="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ProxyPoolText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <!-- Acc client báo lỗi (CHỈ Hub): client dính captcha/không-sửa-được báo về đây → operator quyết giữ/xóa -->
                <Border DockPanel.Dock="Bottom" Style="{StaticResource Card}" Padding="12,10" Margin="0,10,0,0"
                        Visibility="{Binding IsHubMode, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Acc client báo lỗi (captcha / không sửa được)" Style="{StaticResource H2}" VerticalAlignment="Center" />
                            <Button HorizontalAlignment="Right" Content="⟳  Làm mới" MinWidth="90" Command="{Binding RefreshReportsCommand}" />
                        </Grid>
                        <Border MaxHeight="140" ClipToBounds="True">
                            <DataGrid ItemsSource="{Binding ClientErrorReports}" AutoGenerateColumns="False" IsReadOnly="True"
                                      BorderThickness="0" HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tài khoản" Binding="{Binding AccountName}" Width="1.4*" />
                                    <DataGridTextColumn Header="Máy" Binding="{Binding Machine}" Width="1*" />
                                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding StatusText}" Width="1.2*" />
                                    <DataGridTextColumn Header="Lúc" Binding="{Binding When}" Width="90" />
                                    <DataGridTemplateColumn Header="" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="🗑 Xóa acc" Style="{StaticResource DangerButton}" Padding="8,2" FontSize="11.5"
                                                            Command="{Binding DataContext.DeleteReportedAccountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Bỏ qua" Margin="6,0,0,0" Padding="8,2" FontSize="11.5"
                                                            Command="{Binding DataContext.DismissReportCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" ClipToBounds="True">
                    <DataGrid x:Name="AccountsGrid" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                              MouseDoubleClick="AccountsGrid_DoubleClick"
                              BorderThickness="0" IsReadOnly="True" SelectionMode="Extended">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tên" Binding="{Binding DisplayName}" Width="1.2*" />
                            <DataGridTextColumn Header="Tài khoản" Binding="{Binding Username}" Width="1.4*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Proxy" Binding="{Binding ProxySummary}" Width="1.2*" />
                            <DataGridTextColumn Header="Tình trạng" Binding="{Binding UsageStatus}" Width="0.9*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UsageStatus}" Value="Đang dùng">
                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UsageStatus}" Value="Đã dùng">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UsageStatus}" Value="⚠ Captcha">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Lỗi / captcha" Binding="{Binding LastError}" Width="1.6*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </DockPanel>

            <!-- RIGHT: detail editor -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="18"
                    DataContext="{Binding Selected}">
                <Grid>
                    <TextBlock Text="Chọn một tài khoản để xem / sửa chi tiết."
                               Style="{StaticResource Caption}" VerticalAlignment="Top"
                               Visibility="{Binding DataContext.HasSelection, ElementName=Root, Converter={StaticResource InverseBoolToVis}}" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding DataContext.HasSelection, ElementName=Root, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Chi tiết tài khoản" Style="{StaticResource H2}" Margin="0,0,0,12" />

                            <TextBlock Text="Tên hiển thị" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,12"
                                     IsReadOnly="{Binding DataContext.IsReadOnlyMode, ElementName=Root}" />

                            <TextBlock Text="Đăng nhập Shopee (user|pass|.shopee.vn=SPC_F=…)" Style="{StaticResource Caption}" />
                            <TextBox Style="{StaticResource MonoTextBox}" Height="60" TextWrapping="Wrap"
                                     Text="{Binding ShopeeAccountLogin, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,8"
                                     IsReadOnly="{Binding DataContext.IsReadOnlyMode, ElementName=Root}" />
                            <CheckBox Content="Mở với tài khoản Shopee (tự đăng nhập)" Margin="0,0,0,14"
                                      IsChecked="{Binding OpenWithShopeeAccount}"
                                      IsEnabled="{Binding DataContext.IsFullEditMode, ElementName=Root}" />

                            <TextBlock Text="PROXY" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="KiotProxy key" Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding KiotProxyKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,10"
                                     IsReadOnly="{Binding DataContext.IsReadOnlyMode, ElementName=Root}" />

                            <Grid Margin="0,0,0,10" IsEnabled="{Binding DataContext.IsFullEditMode, ElementName=Root}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Vùng" Style="{StaticResource Caption}" />
                                    <ComboBox Margin="0,3,0,0" SelectedItem="{Binding Region}"
                                              ItemsSource="{Binding DataContext.RegionOptions, ElementName=Root}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Loại proxy" Style="{StaticResource Caption}" />
                                    <ComboBox Margin="0,3,0,0" SelectedItem="{Binding ProxyType}"
                                              ItemsSource="{Binding DataContext.ProxyTypeOptions, ElementName=Root}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Proxy thủ công (host:port hoặc http://… — nếu không dùng Kiot)"
                                       Style="{StaticResource Caption}" />
                            <TextBox Text="{Binding ManualProxy, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,10"
                                     IsReadOnly="{Binding DataContext.IsReadOnlyMode, ElementName=Root}" />
                            <CheckBox Content="Bắt buộc có proxy mới chạy" IsChecked="{Binding RequireProxy}" Margin="0,0,0,4"
                                      IsEnabled="{Binding DataContext.IsFullEditMode, ElementName=Root}" />
                            <CheckBox Content="Tạm tắt tài khoản này" IsChecked="{Binding Disabled}"
                                      IsEnabled="{Binding DataContext.IsFullEditMode, ElementName=Root}" />

                            <!-- Nút thao tác — dời sang TRÁI. Xử lý captcha (double-click mở Brave) → "Đóng và …". -->
                            <WrapPanel HorizontalAlignment="Left" Margin="0,18,0,0">
                                <Button Content="Bật lại" MinWidth="100" Margin="0,0,10,6"
                                        ToolTip="Bỏ đánh dấu lỗi/captcha của tài khoản này → đưa về rotation Scrape/Search"
                                        Foreground="{StaticResource SuccessBrush}" BorderBrush="{StaticResource SuccessBrush}"
                                        Command="{Binding DataContext.ReenableCommand, ElementName=Root}" />
                                <Button Style="{StaticResource PrimaryButton}" Content="Lưu thay đổi" MinWidth="120" Margin="0,0,10,6"
                                        Command="{Binding DataContext.SaveCommand, ElementName=Root}"
                                        Visibility="{Binding DataContext.IsFullEditMode, ElementName=Root, Converter={StaticResource BoolToVis}}" />
                            </WrapPanel>

                            <!-- Xử lý captcha (chỉ khi lọc "Bị lỗi/captcha"): đóng Brave vừa mở kiểm tra rồi lưu/xóa/báo. -->
                            <WrapPanel HorizontalAlignment="Left" Margin="0,0,0,0"
                                       Visibility="{Binding DataContext.IsErrorFilter, ElementName=Root, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource SuccessButton}" Content="✔  Đóng và lưu" MinWidth="120" Margin="0,0,10,6"
                                        ToolTip="Đã giải captcha xong: đóng Brave + bật lại acc + gỡ báo trên Hub."
                                        Command="{Binding DataContext.CloseAndSaveCommand, ElementName=Root}" />
                                <Button Content="⚠  Đóng và báo không sửa được" MinWidth="180" Margin="0,0,10,6"
                                        ToolTip="Đóng Brave, giữ acc tắt, báo Hub — Hub quyết giữ/xóa."
                                        Command="{Binding DataContext.CloseAndReportFailedCommand, ElementName=Root}"
                                        Visibility="{Binding DataContext.IsReadOnlyMode, ElementName=Root, Converter={StaticResource BoolToVis}}" />
                                <Button Style="{StaticResource DangerButton}" Content="🗑  Đóng và xóa tk" MinWidth="140" Margin="0,0,10,6"
                                        ToolTip="Đóng Brave + xóa acc khỏi kho (đồng bộ gỡ mọi máy)."
                                        Command="{Binding DataContext.CloseAndDeleteCommand, ElementName=Root}"
                                        Visibility="{Binding DataContext.IsFullEditMode, ElementName=Root, Converter={StaticResource BoolToVis}}" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
