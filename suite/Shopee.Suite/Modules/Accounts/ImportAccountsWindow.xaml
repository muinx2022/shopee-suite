<Window
    x:Class="Shopee.Suite.Modules.Accounts.ImportAccountsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Import tài khoản" Height="560" Width="720"
    WindowStartupLocation="CenterOwner"
    Background="{StaticResource WindowBackgroundBrush}"
    FontFamily="{StaticResource UiFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="0.7*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <TextBlock DockPanel.Dock="Top" Style="{StaticResource Caption}" Margin="0,0,0,5"
                       Text="Tài khoản Shopee (mỗi dòng 1 tk: user|pass  hoặc  user|pass|.shopee.vn=SPC_F=value)" />
            <TextBox x:Name="LoginsBox" Style="{StaticResource MonoTextBox}" />
        </DockPanel>

        <TextBlock Grid.Row="1" Style="{StaticResource Caption}" Margin="0,12,0,5"
                   Text="Proxy (mỗi dòng 1 kiotproxy key hoặc host:port) — ghép xoay vòng cho từng tài khoản. Nếu CHỈ nhập proxy (để trống tài khoản) thì gán xoay vòng cho các tài khoản ĐÃ CÓ." />

        <TextBox Grid.Row="2" x:Name="KeysBox" Style="{StaticResource MonoTextBox}" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" MinWidth="90" IsCancel="True" Click="OnCancel" />
            <Button Style="{StaticResource PrimaryButton}" Content="Import" MinWidth="110"
                    Margin="10,0,0,0" IsDefault="True" Click="OnOk" />
        </StackPanel>
    </Grid>
</Window>
