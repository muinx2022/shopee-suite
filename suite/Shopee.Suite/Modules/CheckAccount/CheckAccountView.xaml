<UserControl
    x:Class="Shopee.Suite.Modules.CheckAccount.CheckAccountView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    x:Name="Root">
    <Grid Margin="28,22,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Check tài khoản Shopee" Style="{StaticResource H1}" />
                <TextBlock Text="Kiểm tra hàng loạt tài khoản qua Edge + proxy, giữ profile khi đăng nhập thành công."
                           Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{StaticResource SubtleBrush}" CornerRadius="14" Padding="14,6">
                <TextBlock Text="{Binding Status}" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>
        </Grid>

        <!-- Body -->
        <TabControl Grid.Row="1" x:Name="Tabs" SelectionChanged="OnTabChanged">
            <!-- ══════════ TAB 1: CHECK ══════════ -->
            <TabItem Header="Check tài khoản">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="120" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="150" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1.3*" MinHeight="140" />
                    </Grid.RowDefinitions>

                    <!-- Accounts -->
                    <DockPanel Grid.Row="0">
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Caption}" Margin="0,0,0,5"
                                   Text="Danh sách tài khoản (mỗi dòng: user|pass  hoặc  user|pass|.shopee.vn=SPC_F=...)" />
                        <TextBox Style="{StaticResource MonoTextBox}"
                                 IsReadOnly="{Binding IsRunning}"
                                 Text="{Binding Accounts, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <!-- Proxy -->
                    <DockPanel Grid.Row="2" Margin="0,12,0,0">
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Caption}" Margin="0,0,0,5"
                                   Text="Danh sách proxy (mỗi dòng 1 kiotproxy key hoặc host:port — nhiều key để mỗi tk 1 IP mới)" />
                        <TextBox Style="{StaticResource MonoTextBox}"
                                 IsReadOnly="{Binding IsRunning}"
                                 Text="{Binding ProxyList, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <!-- Button row -->
                    <Grid Grid.Row="3" Margin="0,14,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource SuccessButton}" Content="▶  Chạy"
                                    MinWidth="120" Command="{Binding RunCommand}" />
                            <Button Style="{StaticResource DangerButton}" Content="■  Dừng"
                                    MinWidth="100" Margin="10,0,0,0" Command="{Binding StopCommand}" />
                            <Button Content="📁  Thư mục profile" Margin="10,0,0,0"
                                    Command="{Binding OpenProfilesCommand}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="Số luồng" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <ComboBox Width="64" SelectedItem="{Binding Lanes}" IsEnabled="{Binding IsIdle}">
                                <sys:Int32>1</sys:Int32>
                                <sys:Int32>2</sys:Int32>
                                <sys:Int32>3</sys:Int32>
                                <sys:Int32>4</sys:Int32>
                                <sys:Int32>5</sys:Int32>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Log -->
                    <Border Grid.Row="4" CornerRadius="8" ClipToBounds="True"
                            Background="{StaticResource LogBackgroundBrush}">
                        <TextBox x:Name="LogBox" Style="{StaticResource LogTextBox}" />
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════ TAB 2: TK OK ══════════ -->
            <TabItem Header="TK OK">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Chọn tất cả" VerticalAlignment="Center" Margin="2,0,14,0"
                                      IsChecked="{Binding SelectAll}" />
                            <Button Content="↻  Tải lại" Command="{Binding ReloadOkCommand}" />
                            <Button Style="{StaticResource PrimaryButton}" Content="→  Lưu vào kho chung"
                                    Margin="10,0,0,0" Command="{Binding SaveToSharedCommand}" />
                            <Button Content="📂  Mở file" Margin="10,0,0,0" Command="{Binding OpenOkFileCommand}" />
                        </StackPanel>
                        <TextBlock Text="{Binding OkStatus}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}" FontSize="12.5" />
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource Card}" ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding OkAccounts}" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="46" Header="✓" CanUserResize="False" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox HorizontalAlignment="Center"
                                                      IsChecked="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Tài khoản" Binding="{Binding Account, Mode=OneWay}" Width="2*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status, Mode=OneWay}" Width="*" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
