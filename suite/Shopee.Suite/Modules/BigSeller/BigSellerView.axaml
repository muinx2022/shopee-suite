<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="using:Shopee.Suite.Behaviors"
    xmlns:sys="using:System"
    x:Class="Shopee.Suite.Modules.BigSeller.BigSellerView"
    x:Name="Root">
    <Grid Margin="28,22,28,24" RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Cấu hình BigSeller" Classes="h1" />
                <TextBlock Text="Tài khoản BigSeller + workbook + shop (mỗi shop 1 sheet) + cookie dùng chung cho Scrape và Update Product."
                           Classes="caption" Margin="0,3,0,0" />
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{DynamicResource SubtleBrush}" CornerRadius="14" Padding="14,6">
                <TextBlock Text="{Binding Status}" FontSize="12.5" Foreground="{DynamicResource TextSecondaryBrush}" />
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="300,14,*">

            <!-- LEFT: account list -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Classes="success" Content="+ Thêm" MinWidth="78"
                            Command="{Binding AddCommand}" />
                    <Button Classes="danger" Content="− Xóa" MinWidth="72"
                            Margin="8,0,0,0" Command="{Binding DeleteCommand}" />
                    <Button Content="💾 Lưu" Margin="8,0,0,0" Command="{Binding SaveCommand}" />
                </StackPanel>

                <!-- Tự đăng nhập TẤT CẢ tk (headless, không hiện cửa sổ) rồi lưu cookie — dưới list. -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <Button Classes="primary" Content="🔐  Đăng nhập tất cả (headless)"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Command="{Binding LoginAllCommand}"
                            ToolTip.Tip="Tự đăng nhập HEADLESS mọi tk có đủ Email + Mật khẩu rồi lưu cookie cho client. Cần API key OpenAI (trang Cấu hình AI trên Hub) để giải captcha; tk đòi mã email sẽ được báo để đăng nhập tay 1 lần." />
                    <Button Classes="danger" Content="■ Dừng" Margin="0,6,0,0"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            IsVisible="{Binding IsLoggingIn}" Command="{Binding StopLoginCommand}" />
                </StackPanel>

                <Border Classes="card" ClipToBounds="True">
                    <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6,7">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13.5" />
                                    <TextBlock Text="{Binding CookieStatus}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- RIGHT: detail — 2 CỘT (trái: tài khoản/kết nối · phải: shops) để dùng chiều ngang,
                 tránh dồn dọc phải cuộn. Mỗi cột tự lo chiều cao (cột trái cuộn riêng nếu quá thấp;
                 lưới shop lấp đầy + cuộn nội bộ) → cửa sổ bình thường KHÔNG cần cuộn. -->
            <!-- CỘT PHẢI chia 2 hàng: khung CẤU HÌNH (trên) · khung LOG tách riêng (dưới) -->
            <Grid Grid.Column="2" RowDefinitions="*,Auto">
            <Border Grid.Row="0" Classes="card" Padding="18">
                <Grid>
                    <TextBlock Text="Chọn hoặc thêm một tài khoản BigSeller." Classes="caption"
                               VerticalAlignment="Top"
                               IsVisible="{Binding !HasSelection}" />

                    <Grid DataContext="{Binding Selected}" ColumnDefinitions="1*,18,1.1*"
                          IsVisible="{Binding #Root.DataContext.HasSelection}">
                        <Grid.Styles>
                            <!-- Ô nhập gọn (như cấu hình Workspace) để form đỡ cao. -->
                            <Style Selector="TextBox">
                                <Setter Property="Padding" Value="5,2" />
                                <Setter Property="FontSize" Value="11.5" />
                            </Style>
                        </Grid.Styles>

                        <!-- ══════════ CỘT TRÁI: tài khoản + kết nối ══════════ -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <Grid ColumnDefinitions="*,12,*">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Tên hiển thị" Classes="caption" />
                                        <TextBox Text="{Binding Label}" Margin="0,3,0,10" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Email BigSeller" Classes="caption" />
                                        <TextBox Text="{Binding Email}" Margin="0,3,0,10" />
                                    </StackPanel>
                                </Grid>

                                <!-- Mật khẩu BigSeller (masked) — cho auto-login tự mint token mỗi máy. -->
                                <TextBlock Text="Mật khẩu BigSeller (để tự đăng nhập)" Classes="caption" />
                                <TextBox PasswordChar="●" Text="{Binding Password, Mode=TwoWay}" Margin="0,3,0,10" />

                                <!-- Cả cụm Workbook (label + ô path + chọn file + ↻ Sheet) CHỈ cho excel-mode; hub-mode
                                     ẨN sạch (kho dữ liệu ở Hub, không có khái niệm workbook/sheet) → chỉ còn DataSourceLabel. -->
                                <TextBlock Text="Workbook (Excel)" Classes="caption" IsVisible="{Binding CanPickWorkbook}" />
                                <Grid Margin="0,3,0,3" ColumnDefinitions="*,Auto,Auto" IsVisible="{Binding CanPickWorkbook}">
                                    <TextBox Grid.Column="0" Text="{Binding WorkbookPath}" IsReadOnly="True"
                                             Classes="mono" />
                                    <Button Grid.Column="1" Content="…" Width="40" Margin="8,0,0,0"
                                            Command="{Binding #Root.DataContext.BrowseWorkbookCommand}" />
                                    <Button Grid.Column="2" Content="↻ Sheet" Margin="8,0,0,0"
                                            Command="{Binding #Root.DataContext.RefreshSheetsCommand}" />
                                </Grid>
                                <!-- Excel-mode (chuyển tiếp): workbook giờ là FILE LOCAL, không còn sync qua Hub. -->
                                <TextBlock Text="{Binding WorkbookSyncHint}" IsVisible="{Binding CanPickWorkbook}"
                                           FontSize="11.5" Margin="0,0,0,10" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding DataSourceLabel}" IsVisible="{Binding IsHubData}"
                                           FontSize="12.5" Margin="0,0,0,10" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />

                                <TextBlock Text="File cookie BigSeller (muc_token — dùng chung)" Classes="caption" />
                                <Grid Margin="0,3,0,8" ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding CookieFile}" IsReadOnly="True"
                                             Classes="mono" />
                                    <Button Grid.Column="1" Content="…" Width="40" Margin="8,0,0,0"
                                            Command="{Binding #Root.DataContext.BrowseCookieCommand}" />
                                </Grid>
                                <TextBlock Text="{Binding CookieStatus}" FontSize="12.5" Margin="0,0,0,10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />

                                <!-- Proxy RIÊNG cho tk BigSeller (tuỳ chọn). Có key → mỗi tk 1 IP → chạy SONG SONG.
                                     Trống → đi IP máy, các tk BigSeller chạy LẦN LƯỢT. -->
                                <TextBlock Text="Proxy riêng cho BigSeller (KiotProxy — tuỳ chọn)" Classes="caption" />
                                <Grid Margin="0,3,0,2" ColumnDefinitions="*,10,110,10,96">
                                    <TextBox Grid.Column="0" Text="{Binding KiotProxyKey}"
                                             Classes="mono"
                                             ToolTip.Tip="KiotProxy key riêng cho tk BigSeller này. Trống = đi IP máy (các tk chạy lần lượt)." />
                                    <TextBox Grid.Column="2" Text="{Binding Region}"
                                             ToolTip.Tip="Vùng KiotProxy (random/north/central/south)." />
                                    <ComboBox Grid.Column="4" SelectedItem="{Binding ProxyType, Mode=TwoWay}">
                                        <sys:String>http</sys:String>
                                        <sys:String>socks5</sys:String>
                                    </ComboBox>
                                </Grid>
                                <TextBlock Text="{Binding ProxyStatus}" FontSize="11.5" Margin="0,0,0,10"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button Classes="primary" Content="Mở Profile Bigseller" MinWidth="150"
                                            Command="{Binding #Root.DataContext.LoginCommand}" />
                                    <Button Classes="danger" Content="Đóng" MinWidth="80" Margin="10,0,0,0"
                                            Command="{Binding #Root.DataContext.StopLoginCommand}" />
                                </StackPanel>
                                <TextBlock Classes="caption" Margin="0,0,0,8" TextWrapping="Wrap"
                                           Text="Có proxy → đăng nhập qua proxy đó; không → IP máy. Cookie tự lưu." />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button Content="🗑 Xóa Medias" MinWidth="150"
                                            Command="{Binding #Root.DataContext.CleanMediasCommand}"
                                            ToolTip.Tip="Xóa TOÀN BỘ media trong thư viện ảnh (Material Center) BigSeller của tk này — luồng dọn media của Update sản phẩm. Mở Brave riêng bằng cookie tk, dọn xong tự đóng." />
                                    <Button Classes="danger" Content="■ Dừng" MinWidth="80" Margin="10,0,0,0"
                                            IsVisible="{Binding #Root.DataContext.IsCleaningMedia}"
                                            Command="{Binding #Root.DataContext.StopCleanMediasCommand}" />
                                </StackPanel>
                                <TextBlock Classes="caption" Margin="0,0,0,8" TextWrapping="Wrap"
                                           Text="Xóa Medias: dọn sạch thư viện ảnh khi kho đầy (BigSeller chặn upload ảnh lúc update)." />
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ══════════ CỘT PHẢI: shops + cấu hình shop ══════════ -->
                        <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">
                            <!-- Header + thêm/xóa shop -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Shops (mỗi shop 1 sheet)" Classes="h2" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="+ Thêm shop" Command="{Binding #Root.DataContext.AddShopCommand}" />
                                    <Button Content="− Xóa shop" Margin="8,0,0,0"
                                            Command="{Binding #Root.DataContext.RemoveShopCommand}" />
                                    <Button Content="⇄ Sync shop → Đơn hàng" Margin="8,0,0,0"
                                            Command="{Binding #Root.DataContext.SyncShopsToOrdersCommand}"
                                            ToolTip.Tip="Tạo sẵn dòng tài khoản bên module Đơn hàng cho từng shop của tài khoản BigSeller đang chọn (Email = tên shop) để đỡ nhập tay. MỘT CHIỀU, chỉ thêm bản mới — bỏ qua tên đã có/trùng, không sửa dữ liệu sẵn có. Tài khoản tạo ra CHƯA có mật khẩu: mở phiên lần đầu đăng nhập tay ở tab Đơn hàng, app tự lưu cookie." />
                                </StackPanel>
                            </Grid>

                            <!-- Bảng shop CHỈ XEM — lấp đầy chiều cao còn lại + cuộn nội bộ khi nhiều shop.
                                 Sửa mọi field ở panel "Cấu hình shop" bên dưới (tránh edit-transaction revert). -->
                            <Border Grid.Row="1" Classes="card" ClipToBounds="True">
                                <DataGrid ItemsSource="{Binding Shops}"
                                          SelectedItem="{Binding #Root.DataContext.SelectedShop}"
                                          BorderThickness="0" AutoGenerateColumns="False" IsReadOnly="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tên shop" Binding="{Binding Name}" Width="1.4*" />
                                        <!-- Hub-mode: cột để TRỐNG (SheetDisplay), không phô GUID ngăn; excel-mode: tên sheet. -->
                                        <DataGridTextColumn Header="Sheet" Binding="{Binding SheetDisplay}" Width="1.4*" />
                                        <DataGridTextColumn Header="Batch" Binding="{Binding OpenAiBatchSize}" Width="60" />
                                        <DataGridTextColumn Header="Crawl URL (Import)" Binding="{Binding BigSellerCrawlUrl}" Width="1.4*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- Ánh xạ field BigSeller ↔ cột Excel cho SHOP đang chọn -->
                            <Border Grid.Row="2" Classes="card" Padding="14" Margin="0,10,0,0"
                                    DataContext="{Binding #Root.DataContext.SelectedShop}"
                                    IsVisible="{Binding #Root.DataContext.HasShopSelection}">
                                <StackPanel>
                                    <StackPanel.Styles>
                                        <Style Selector="TextBox">
                                            <Setter Property="Padding" Value="5,2" />
                                            <Setter Property="FontSize" Value="11.5" />
                                        </Style>
                                    </StackPanel.Styles>
                                    <TextBlock Text="Cấu hình shop đang chọn" Classes="h2" Margin="0,0,0,10" />

                                    <!-- Tên shop + Sheet + Batch -->
                                    <Grid Margin="0,0,0,10" ColumnDefinitions="*,12,*,12,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Tên shop" Classes="caption" />
                                            <TextBox Margin="0,3,0,0" Text="{Binding Name}" />
                                        </StackPanel>
                                        <!-- Sheet dữ liệu: chỉ excel-mode; hub-mode ẨN (sheet = ngăn nội bộ tự gán = shop.Id). -->
                                        <StackPanel Grid.Column="2" IsVisible="{Binding !UsesHubData}">
                                            <TextBlock Text="Sheet dữ liệu (↔ shop này)" Classes="caption" />
                                            <ComboBox Margin="0,3,0,0" HorizontalAlignment="Stretch"
                                                      ItemsSource="{Binding #Root.DataContext.Selected.SheetOptions}"
                                                      SelectedItem="{Binding ShopeeDataSheet, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Batch" Classes="caption" />
                                            <TextBox Width="64" Margin="0,3,0,0" Text="{Binding OpenAiBatchSize}" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Crawl URL -->
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Crawl URL (Import từ BigSeller)" Classes="caption" />
                                        <TextBox Margin="0,3,0,0" Text="{Binding BigSellerCrawlUrl}"
                                                 Classes="mono" FontSize="11.5" />
                                    </StackPanel>

                                    <!-- Ánh xạ field ↔ cột Excel: chỉ excel-mode; hub-mode ẨN sạch (kho SP ở Hub, không có cột Excel). -->
                                    <TextBlock Text="Ánh xạ field ↔ cột Excel (nhập chữ cột: A, B, C…; trống = không dùng)"
                                               Classes="caption" Margin="0,0,0,8" IsVisible="{Binding !UsesHubData}" />
                                    <UniformGrid Columns="6" IsVisible="{Binding !UsesHubData}">
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Link" Classes="caption" />
                                            <TextBox Text="{Binding LinkColumnLetter}" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Item ID" Classes="caption" />
                                            <TextBox Text="{Binding ItemIdColumnLetter}" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Giá" Classes="caption" />
                                            <TextBox Text="{Binding PriceColumnLetter}" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="SKU" Classes="caption" />
                                            <TextBox Text="{Binding SkuColumnLetter}" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Tên gốc" Classes="caption" />
                                            <TextBox Text="{Binding ProductNameColumnLetter}" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Tên đã sửa" Classes="caption" />
                                            <TextBox Text="{Binding RewrittenNameColumnLetter}" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
            <!-- KHUNG LOG tách riêng — chạy hết chiều ngang cột phải, luôn hiển thị (kể cả khi chưa chọn tk) -->
            <Border Grid.Row="1" Classes="card" Padding="6" Margin="0,12,0,0" Height="180" ClipToBounds="True">
                <Border CornerRadius="6" ClipToBounds="True" Background="{DynamicResource LogBackgroundBrush}">
                    <TextBox Classes="log" FontSize="11.5" Padding="10,8"
                             b:LogText.Source="{Binding LogLines}" />
                </Border>
            </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
