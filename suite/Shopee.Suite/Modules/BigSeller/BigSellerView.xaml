<UserControl
    x:Class="Shopee.Suite.Modules.BigSeller.BigSellerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="clr-namespace:Shopee.Suite.Behaviors"
    x:Name="Root">
    <Grid Margin="28,22,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="BigSeller" Style="{StaticResource H1}" />
                <TextBlock Text="Tài khoản BigSeller + workbook + shop (mỗi shop 1 sheet) + cookie dùng chung cho Scrape và Update Product."
                           Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{StaticResource SubtleBrush}" CornerRadius="14" Padding="14,6">
                <TextBlock Text="{Binding Status}" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="240" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: account list -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Style="{StaticResource SuccessButton}" Content="+ Thêm" MinWidth="78"
                            Command="{Binding AddCommand}" />
                    <Button Style="{StaticResource DangerButton}" Content="− Xóa" MinWidth="72"
                            Margin="8,0,0,0" Command="{Binding DeleteCommand}" />
                    <Button Content="💾 Lưu" Margin="8,0,0,0" Command="{Binding SaveCommand}" />
                </StackPanel>
                <Border Style="{StaticResource Card}" ClipToBounds="True">
                    <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                             BorderThickness="0" Background="Transparent"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6,7">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13.5" />
                                    <TextBlock Text="{Binding CookieStatus}" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- RIGHT: detail -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="18">
                <Grid>
                    <TextBlock Text="Chọn hoặc thêm một tài khoản BigSeller." Style="{StaticResource Caption}"
                               VerticalAlignment="Top"
                               Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVis}}" />

                    <!-- Cuộn CẢ panel chi tiết (1 thanh cuộn duy nhất) → bảng Shops KHÔNG còn thanh cuộn
                         nội bộ bó ~2-3 dòng; khi cửa sổ thấp thì cuộn cả form thay vì kẹt riêng phần shop. -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding DataContext.HasSelection, ElementName=Root, Converter={StaticResource BoolToVis}}">
                    <Grid DataContext="{Binding Selected}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Account info -->
                        <StackPanel Grid.Row="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Tên hiển thị" Style="{StaticResource Caption}" />
                                    <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,10" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Email BigSeller" Style="{StaticResource Caption}" />
                                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,10" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Workbook (Excel)" Style="{StaticResource Caption}" />
                            <Grid Margin="0,3,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding WorkbookPath}" IsReadOnly="True"
                                         FontFamily="{StaticResource MonoFont}" />
                                <Button Grid.Column="1" Content="…" Width="40" Margin="8,0,0,0"
                                        Command="{Binding DataContext.BrowseWorkbookCommand, ElementName=Root}" />
                                <Button Grid.Column="2" Content="↻ Sheet" Margin="8,0,0,0"
                                        Command="{Binding DataContext.RefreshSheetsCommand, ElementName=Root}" />
                            </Grid>

                            <TextBlock Text="File cookie BigSeller (muc_token — dùng chung)" Style="{StaticResource Caption}" />
                            <Grid Margin="0,3,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding CookieFile}" IsReadOnly="True"
                                         FontFamily="{StaticResource MonoFont}" />
                                <Button Grid.Column="1" Content="…" Width="40" Margin="8,0,0,0"
                                        Command="{Binding DataContext.BrowseCookieCommand, ElementName=Root}" />
                            </Grid>
                            <TextBlock Text="{Binding CookieStatus}" FontSize="12.5" Margin="0,0,0,10"
                                       Foreground="{StaticResource TextSecondaryBrush}" />

                            <!-- Proxy RIÊNG cho tk BigSeller (tuỳ chọn). Có key → bigseller.com (login + scrape)
                                 đi qua IP này → mỗi tk 1 IP → chạy SONG SONG nhiều tk không bị đá phiên.
                                 Trống → đi IP máy, các tk BigSeller chạy LẦN LƯỢT. -->
                            <TextBlock Text="Proxy riêng cho BigSeller (KiotProxy — tuỳ chọn)" Style="{StaticResource Caption}" />
                            <Grid Margin="0,3,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding KiotProxyKey, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="{StaticResource MonoFont}"
                                         ToolTip="KiotProxy key riêng cho tk BigSeller này. Trống = đi IP máy (các tk chạy lần lượt)." />
                                <TextBox Grid.Column="2" Text="{Binding Region, UpdateSourceTrigger=LostFocus}"
                                         ToolTip="Vùng KiotProxy (random/north/central/south)." />
                                <ComboBox Grid.Column="4" SelectedValue="{Binding ProxyType, Mode=TwoWay}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="http" />
                                    <ComboBoxItem Content="socks5" />
                                </ComboBox>
                            </Grid>
                            <TextBlock Text="{Binding ProxyStatus}" FontSize="11.5" Margin="0,0,0,10"
                                       Foreground="{StaticResource TextSecondaryBrush}" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Style="{StaticResource PrimaryButton}" Content="Mở Profile Bigseller" MinWidth="160"
                                        Command="{Binding DataContext.LoginCommand, ElementName=Root}" />
                                <Button Style="{StaticResource DangerButton}" Content="Đóng" MinWidth="90" Margin="10,0,0,0"
                                        Command="{Binding DataContext.StopLoginCommand, ElementName=Root}" />
                                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="Có proxy → đăng nhập qua proxy đó; không → IP máy. Cookie tự lưu." />
                            </StackPanel>

                            <Border Height="84" CornerRadius="6" ClipToBounds="True" Margin="0,2,0,14"
                                    Background="{StaticResource LogBackgroundBrush}">
                                <TextBox Style="{StaticResource LogTextBox}" FontSize="11.5" Padding="8,6"
                                         b:LogText.Source="{Binding DataContext.LoginLog, ElementName=Root}" />
                            </Border>
                        </StackPanel>

                        <!-- Shops -->
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <TextBlock Text="Shops (mỗi shop 1 sheet)" Style="{StaticResource H2}" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="+ Thêm shop" Command="{Binding DataContext.AddShopCommand, ElementName=Root}" />
                                <Button Content="− Xóa shop" Margin="8,0,0,0"
                                        Command="{Binding DataContext.RemoveShopCommand, ElementName=Root}" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2" Style="{StaticResource Card}" ClipToBounds="True">
                            <!-- Bảng CHỈ XEM (read-only) — click 1 hàng để chọn shop; sửa MỌI field ở panel
                                 "Cấu hình shop" bên dưới (ngoài DataGrid) để tránh edit-transaction revert. -->
                            <DataGrid ItemsSource="{Binding Shops}"
                                      SelectedItem="{Binding DataContext.SelectedShop, ElementName=Root}"
                                      BorderThickness="0" AutoGenerateColumns="False" IsReadOnly="True"
                                      MinHeight="220" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tên shop" Binding="{Binding Name}" Width="1.4*" />
                                    <DataGridTextColumn Header="Sheet" Binding="{Binding ShopeeDataSheet}" Width="1.4*" />
                                    <DataGridTextColumn Header="Batch" Binding="{Binding OpenAiBatchSize}" Width="60" />
                                    <DataGridTextColumn Header="Crawl URL (Import)" Binding="{Binding BigSellerCrawlUrl}" Width="1.4*" />
                                    <DataGridCheckBoxColumn Header="Tab Claimed" Binding="{Binding BigSellerImportFromClaimedTab}" Width="80" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Ánh xạ field BigSeller ↔ cột Excel cho SHOP đang chọn (mỗi shop/sheet 1 map riêng) -->
                        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="14" Margin="0,10,0,0"
                                DataContext="{Binding DataContext.SelectedShop, ElementName=Root}"
                                Visibility="{Binding DataContext.HasShopSelection, ElementName=Root, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <!-- Sửa MỌI field per-shop ở đây (ngoài DataGrid) → lưu ngay, không bị revert. -->
                                <TextBlock Text="Cấu hình shop đang chọn" Style="{StaticResource H2}" Margin="0,0,0,10" />

                                <!-- 1 dòng: Tên shop + Sheet + Batch + Tab Claimed (AI model lấy từ Cài đặt App). -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Tên shop" Style="{StaticResource Caption}" />
                                        <TextBox Margin="0,3,0,0" Text="{Binding Name, UpdateSourceTrigger=LostFocus}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Sheet dữ liệu (↔ shop này)" Style="{StaticResource Caption}" />
                                        <ComboBox Margin="0,3,0,0"
                                                  ItemsSource="{Binding DataContext.Selected.SheetOptions, ElementName=Root}"
                                                  SelectedItem="{Binding ShopeeDataSheet, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Batch" Style="{StaticResource Caption}" />
                                        <TextBox Width="64" Margin="0,3,0,0" Text="{Binding OpenAiBatchSize, UpdateSourceTrigger=LostFocus}" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="6" VerticalAlignment="Bottom" Margin="0,0,0,6"
                                              IsChecked="{Binding BigSellerImportFromClaimedTab}"
                                              Content="Import từ tab Claimed" />
                                </Grid>

                                <!-- Crawl URL -->
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Crawl URL (Import từ BigSeller)" Style="{StaticResource Caption}" />
                                    <TextBox Margin="0,3,0,0" Text="{Binding BigSellerCrawlUrl, UpdateSourceTrigger=LostFocus}"
                                             FontFamily="{StaticResource MonoFont}" FontSize="11.5" />
                                </StackPanel>

                                <TextBlock Text="Ánh xạ field ↔ cột Excel (nhập chữ cột: A, B, C…; trống = không dùng)"
                                           Style="{StaticResource Caption}" Margin="0,0,0,8" />
                                <UniformGrid Columns="6">
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Link" Style="{StaticResource Caption}" />
                                        <TextBox Text="{Binding LinkColumnLetter, UpdateSourceTrigger=LostFocus}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Item ID" Style="{StaticResource Caption}" />
                                        <TextBox Text="{Binding ItemIdColumnLetter, UpdateSourceTrigger=LostFocus}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Giá" Style="{StaticResource Caption}" />
                                        <TextBox Text="{Binding PriceColumnLetter, UpdateSourceTrigger=LostFocus}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="SKU" Style="{StaticResource Caption}" />
                                        <TextBox Text="{Binding SkuColumnLetter, UpdateSourceTrigger=LostFocus}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Tên gốc" Style="{StaticResource Caption}" />
                                        <TextBox Text="{Binding ProductNameColumnLetter, UpdateSourceTrigger=LostFocus}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Tên đã sửa" Style="{StaticResource Caption}" />
                                        <TextBox Text="{Binding RewrittenNameColumnLetter, UpdateSourceTrigger=LostFocus}" Margin="0,3,0,0" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
