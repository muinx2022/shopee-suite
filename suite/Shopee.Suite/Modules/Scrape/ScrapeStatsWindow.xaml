<Window
    x:Class="Shopee.Suite.Modules.Scrape.ScrapeStatsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Thống kê scrape" Height="560" Width="760"
    WindowStartupLocation="CenterOwner"
    Background="{StaticResource WindowBackgroundBrush}"
    FontFamily="{StaticResource UiFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource Caption}" Text="{Binding Title}" />
        <TextBlock Grid.Row="1" Margin="0,4,0,10" Foreground="{StaticResource TextSecondaryBrush}" Text="{Binding Summary}" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Sheets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding Header}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RangesText}" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontFamily="{StaticResource MonoFont}" FontSize="12" />
                                <TextBlock Text="{Binding FrameText}" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />

                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Style="{StaticResource DangerButton}" Content="Xoá tiến độ" MinWidth="110"
                                            Command="{Binding DataContext.ClearProgressCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Làm mới" MinWidth="90" Command="{Binding RefreshCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Content="Đóng" MinWidth="90" Margin="10,0,0,0" IsCancel="True" Click="OnClose" />
        </StackPanel>
    </Grid>
</Window>
