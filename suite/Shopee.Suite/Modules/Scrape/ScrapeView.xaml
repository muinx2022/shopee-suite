<UserControl
    x:Class="Shopee.Suite.Modules.Scrape.ScrapeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="clr-namespace:Shopee.Suite.Behaviors"
    x:Name="Root">
    <Grid Margin="28,22,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Shopee Scrape" Style="{StaticResource H1}" />
                <TextBlock Text="Tick chọn nhiều tk BigSeller (chạy đồng thời) — click 1 tk để cấu hình chi tiết bên phải. Mỗi tk chiếm số tk Shopee RIÊNG; hết tk thì tk sau chờ."
                           Style="{StaticResource Caption}" Margin="0,3,0,0" TextWrapping="Wrap" />
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{StaticResource SubtleBrush}" CornerRadius="14" Padding="14,6">
                <TextBlock Text="{Binding Status}" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>
        </Grid>

        <!-- Actions + global video dir -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Thư mục video" Style="{StaticResource Caption}" VerticalAlignment="Center" />
                    <TextBox Width="220" Margin="8,0,0,0" Text="{Binding VideoDir}" FontFamily="{StaticResource MonoFont}" FontSize="11.5" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="↻ Tải lại" Command="{Binding ReloadCommand}" />
                    <Button Style="{StaticResource SuccessButton}" Content="▶  Chạy (reset)" MinWidth="130" Margin="10,0,0,0" Command="{Binding RunCommand}"
                            ToolTip="Chạy lại TỪ ĐẦU — xoá tiến độ đã lưu của các tk BigSeller được tick." />
                    <Button Content="⏯  Tiếp tục" MinWidth="110" Margin="10,0,0,0" Command="{Binding ResumeCommand}"
                            ToolTip="Chỉ chạy các dòng CÒN THIẾU theo tiến độ đã lưu." />
                    <Button Style="{StaticResource DangerButton}" Content="■  Dừng" MinWidth="90" Margin="10,0,0,0" Command="{Binding StopCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Master-detail -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="240" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: BigSeller account list (tick chọn để chạy; click để cấu hình) -->
            <DockPanel Grid.Column="0">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Tài khoản BigSeller" Style="{StaticResource Caption}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Tất cả" Padding="10,2" ToolTip="Chọn tất cả" Command="{Binding SelectAllTargetsCommand}" />
                        <Button Content="Bỏ chọn" Padding="10,2" Margin="6,0,0,0" ToolTip="Bỏ chọn tất cả" Command="{Binding UnselectAllTargetsCommand}" />
                    </StackPanel>
                </Grid>
                <Border Style="{StaticResource Card}" ClipToBounds="True">
                    <ListBox ItemsSource="{Binding ScrapeTargets}" SelectedItem="{Binding SelectedTarget}"
                             BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch"
                             PreviewMouseLeftButtonUp="TargetRow_Click">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Click checkbox: toggle tick + chọn dòng (focusable). Click thân dòng:
                                         chọn dòng + tự tick (xem code-behind TargetRow_Click). -->
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Click="Checkbox_Click" />
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"
                                               VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding CookieStatus}" VerticalAlignment="Center"
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- RIGHT: detail config (tk đang click) + tiến trình -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Detail của tk đang chọn -->
                <TextBlock Grid.Row="0" Text="Click 1 tài khoản BigSeller bên trái để cấu hình."
                           Style="{StaticResource Caption}" VerticalAlignment="Top"
                           Visibility="{Binding HasSelectedTarget, Converter={StaticResource InverseBoolToVis}}" />

                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12"
                        DataContext="{Binding SelectedTarget}"
                        Visibility="{Binding DataContext.HasSelectedTarget, ElementName=Root, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="{Binding DisplayName}" Style="{StaticResource H2}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CookieStatus}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>

                        <TextBlock Text="Workbook" Style="{StaticResource Caption}" />
                        <TextBox Text="{Binding WorkbookPath, Mode=OneWay}" IsReadOnly="True" Margin="0,3,0,10"
                                 FontFamily="{StaticResource MonoFont}" FontSize="11.5" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Shop (↔ sheet)" Style="{StaticResource Caption}" />
                                <ComboBox Margin="0,3,0,0" ItemsSource="{Binding Shops}" SelectedItem="{Binding SelectedShop}" DisplayMemberPath="DisplayName" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Sheet đang dùng" Style="{StaticResource Caption}" />
                                <TextBox Margin="0,3,0,0" Text="{Binding SheetName, Mode=OneWay}" IsReadOnly="True" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Phân bổ chạy (engine TỰ chia khối dòng cho từng tk Shopee theo 'Dòng / lần')"
                                   Style="{StaticResource Caption}" Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal">
                            <StackPanel><TextBlock Text="Bắt đầu dòng" Style="{StaticResource Caption}" />
                                <TextBox Width="84" Margin="0,3,0,0" Text="{Binding StartRow}" /></StackPanel>
                            <StackPanel Margin="10,0,0,0"><TextBlock Text="Đến dòng (0=hết)" Style="{StaticResource Caption}" />
                                <TextBox Width="100" Margin="0,3,0,0" Text="{Binding EndRow}"
                                         ToolTip="Chạy tới dòng này thì dừng. 0 = chạy hết sheet." /></StackPanel>
                            <StackPanel Margin="10,0,0,0"><TextBlock Text="Dòng / lần" Style="{StaticResource Caption}" />
                                <TextBox Width="84" Margin="0,3,0,0" Text="{Binding RowsPerAccount}" /></StackPanel>
                            <StackPanel Margin="10,0,0,0"><TextBlock Text="Tk Shopee dùng" Style="{StaticResource Caption}" />
                                <TextBox Width="100" Margin="0,3,0,0" Text="{Binding ShopeeCount}"
                                         ToolTip="Số tk Shopee tk BigSeller này chiếm (slice)." /></StackPanel>
                            <StackPanel Margin="10,0,0,0"><TextBlock Text="Số process" Style="{StaticResource Caption}" />
                                <TextBox Width="90" Margin="0,3,0,0" Text="{Binding MaxProcess}"
                                         ToolTip="Số process chạy đồng thời trong tk này (≤ Tk Shopee dùng)." /></StackPanel>
                        </StackPanel>

                        <!-- Tiến độ đã lưu + Thống kê -->
                        <Border Background="{StaticResource SubtleBrush}" CornerRadius="6" Padding="10,8" Margin="0,12,0,0">
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Tiến độ đã lưu" Style="{StaticResource Caption}" />
                                    <TextBlock Text="{Binding ProgressText}" Margin="0,2,0,0" FontSize="12.5" TextWrapping="Wrap" />
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="📊 Thống kê" MinWidth="110"
                                        Command="{Binding DataContext.ShowStatsCommand, ElementName=Root}"
                                        ToolTip="Xem đầy đủ: bao nhiêu tk đang giữ, đã xong tới dòng nào, nhả tay khi treo." />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Tiến trình + tk lỗi -->
                <DockPanel Grid.Row="1">
                    <TextBlock DockPanel.Dock="Top" Text="Tiến trình scrape" Style="{StaticResource H2}" Margin="0,0,0,8" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0"
                                Visibility="{Binding ErroredAccounts.Count, Converter={StaticResource CountToVis}}">
                        <TextBlock Margin="0,0,0,5" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}">
                            <Run Text="⚠ Tài khoản lỗi (" /><Run Text="{Binding ErroredAccounts.Count, Mode=OneWay}" /><Run Text=") — đã tự đổi tk" />
                        </TextBlock>
                        <Border Style="{StaticResource Card}" MaxHeight="110" ClipToBounds="True">
                            <DataGrid ItemsSource="{Binding ErroredAccounts}" BorderThickness="0" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Account" Binding="{Binding Account}" Width="1.4*" />
                                    <DataGridTextColumn Header="Lỗi" Binding="{Binding Reason}" Width="*" />
                                    <DataGridTextColumn Header="Lúc" Binding="{Binding Time}" Width="80" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                    <Border Style="{StaticResource Card}" ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding Instances}" BorderThickness="0" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Process" Binding="{Binding Label}" Width="1.4*" />
                                <DataGridTextColumn Header="Tài khoản đang chạy" Binding="{Binding AccountName}" Width="1.4*" />
                                <DataGridTextColumn Header="Dòng" Binding="{Binding RangeText}" Width="120" />
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="1.8*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>
            </Grid>
        </Grid>

        <!-- Log -->
        <Border Grid.Row="3" CornerRadius="8" ClipToBounds="True" Margin="0,12,0,0" Background="{StaticResource LogBackgroundBrush}">
            <TextBox Style="{StaticResource LogTextBox}" b:LogText.Source="{Binding LogLines}" />
        </Border>
    </Grid>
</UserControl>
