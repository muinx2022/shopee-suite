<UserControl
    x:Class="Shopee.Suite.Modules.UpdateProduct.UpdateProductView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="clr-namespace:Shopee.Suite.Behaviors"
    x:Name="Root">
    <Grid Margin="28,22,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Bigseller Update Product" Style="{StaticResource H1}" />
                <TextBlock Text="Tick chọn nhiều tk BigSeller (chạy song song) — click 1 tk để cấu hình chi tiết bên phải. Mỗi tk có dòng + số worker RIÊNG."
                           Style="{StaticResource Caption}" Margin="0,3,0,0" TextWrapping="Wrap" />
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{StaticResource SubtleBrush}" CornerRadius="14" Padding="14,6">
                <TextBlock Text="{Binding Status}" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>
        </Grid>

        <!-- Global actions + ảnh/video dùng chung -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Ảnh (chung)" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding ImagePath}" FontFamily="{StaticResource MonoFont}" FontSize="11.5" VerticalContentAlignment="Center" />
                    <Button Grid.Column="2" Content="…" Width="38" Margin="6,0,0,0" Command="{Binding BrowseImageCommand}" />
                    <TextBlock Grid.Column="3" Text="Video (chung)" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="16,0,8,0" />
                    <TextBox Grid.Column="4" Text="{Binding VideoFolder}" FontFamily="{StaticResource MonoFont}" FontSize="11.5" VerticalContentAlignment="Center" />
                    <Button Grid.Column="5" Content="…" Width="38" Margin="6,0,0,0" Command="{Binding BrowseVideoFolderCommand}" />
                </Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="↻ Tải lại" Command="{Binding ReloadCommand}" />
                    <Button Style="{StaticResource PrimaryButton}" Content="⬆ Import to store" MinWidth="150" Margin="10,0,0,0"
                            Command="{Binding RunImportCommand}" />
                    <Button Style="{StaticResource SuccessButton}" Content="✎ Update product" MinWidth="150" Margin="10,0,0,0"
                            Command="{Binding RunUpdateCommand}" />
                    <Button Content="🏷 Update tên SP" MinWidth="140" Margin="10,0,0,0"
                            Foreground="{StaticResource WarningBrush}" BorderBrush="{StaticResource WarningBrush}" FontWeight="SemiBold"
                            Command="{Binding RunNameRewriteCommand}" />
                    <Button Style="{StaticResource DangerButton}" Content="■ Dừng" MinWidth="80" Margin="10,0,0,0"
                            Command="{Binding StopCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Master-detail -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="260" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: danh sách tk BigSeller (tick chọn để chạy; click để cấu hình) -->
            <DockPanel Grid.Column="0">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Tài khoản BigSeller" Style="{StaticResource Caption}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Tất cả" Padding="10,2" ToolTip="Chọn tất cả" Command="{Binding SelectAllTargetsCommand}" />
                        <Button Content="Bỏ chọn" Padding="10,2" Margin="6,0,0,0" ToolTip="Bỏ chọn tất cả" Command="{Binding UnselectAllTargetsCommand}" />
                    </StackPanel>
                </Grid>
                <Border Style="{StaticResource Card}" ClipToBounds="True">
                    <ListBox ItemsSource="{Binding RunTargets}" SelectedItem="{Binding SelectedTarget}"
                             BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch"
                             PreviewMouseLeftButtonUp="TargetRow_Click">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13"
                                               VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding CookieStatus}" VerticalAlignment="Center"
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- RIGHT: cấu hình chi tiết của tk đang chọn -->
            <Grid Grid.Column="2">
                <TextBlock Text="Click 1 tài khoản BigSeller bên trái để cấu hình lượt chạy."
                           Style="{StaticResource Caption}" VerticalAlignment="Top"
                           Visibility="{Binding HasSelectedTarget, Converter={StaticResource InverseBoolToVis}}" />

                <Border Style="{StaticResource Card}" Padding="16" VerticalAlignment="Top"
                        DataContext="{Binding SelectedTarget}"
                        Visibility="{Binding DataContext.HasSelectedTarget, ElementName=Root, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="{Binding DisplayName}" Style="{StaticResource H2}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CookieStatus}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>

                        <TextBlock Text="Workbook" Style="{StaticResource Caption}" />
                        <TextBox Text="{Binding WorkbookPath, Mode=OneWay}" IsReadOnly="True" Margin="0,3,0,10"
                                 FontFamily="{StaticResource MonoFont}" FontSize="11.5" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Shop (↔ sheet)" Style="{StaticResource Caption}" />
                                <ComboBox Height="32" Margin="0,3,0,0" VerticalContentAlignment="Center"
                                          ItemsSource="{Binding Shops}" SelectedItem="{Binding SelectedShop}" DisplayMemberPath="DisplayName" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Sheet đang dùng" Style="{StaticResource Caption}" />
                                <TextBox Height="32" Margin="0,3,0,0" VerticalContentAlignment="Center"
                                         Text="{Binding SheetName, Mode=OneWay}" IsReadOnly="True" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text=" " Style="{StaticResource Caption}" />
                                <Button Height="32" Padding="14,0" Margin="0,3,0,0" Content="🗺 Map dữ liệu"
                                        Command="{Binding DataContext.OpenMapCommand, ElementName=Root}" CommandParameter="{Binding}"
                                        ToolTip="Map field BigSeller ↔ cột Excel cho shop đang chọn." />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Cấu hình chạy RIÊNG cho tài khoản này" Style="{StaticResource Caption}" Margin="0,4,0,6" />
                        <StackPanel Orientation="Horizontal">
                            <StackPanel><TextBlock Text="Từ dòng" Style="{StaticResource Caption}" />
                                <TextBox Width="80" Margin="0,3,0,0" Text="{Binding StartRow}" /></StackPanel>
                            <StackPanel Margin="10,0,0,0"><TextBlock Text="Đến dòng (0=hết)" Style="{StaticResource Caption}" />
                                <TextBox Width="100" Margin="0,3,0,0" Text="{Binding EndRow}" /></StackPanel>
                            <StackPanel Margin="10,0,0,0"><TextBlock Text="Import worker" Style="{StaticResource Caption}" />
                                <TextBox Width="90" Margin="0,3,0,0" Text="{Binding ImportWorkers}" /></StackPanel>
                            <StackPanel Margin="10,0,0,0"><TextBlock Text="Update worker" Style="{StaticResource Caption}" />
                                <TextBox Width="90" Margin="0,3,0,0" Text="{Binding UpdateWorkers}" /></StackPanel>
                            <StackPanel Margin="10,0,0,0"><TextBlock Text="Reload (s)" Style="{StaticResource Caption}" />
                                <TextBox Width="80" Margin="0,3,0,0" Text="{Binding ListingReloadSeconds}" /></StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Log -->
        <Border Grid.Row="3" CornerRadius="8" ClipToBounds="True" Margin="0,14,0,0" Background="{StaticResource LogBackgroundBrush}">
            <TextBox Style="{StaticResource LogTextBox}" b:LogText.Source="{Binding LogLines}" />
        </Border>
    </Grid>
</UserControl>
