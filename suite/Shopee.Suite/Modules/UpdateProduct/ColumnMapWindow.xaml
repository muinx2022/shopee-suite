<Window
    x:Class="Shopee.Suite.Modules.UpdateProduct.ColumnMapWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Map dữ liệu" SizeToContent="Height" Width="460"
    WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
    Background="{StaticResource WindowBackgroundBrush}"
    FontFamily="{StaticResource UiFont}">
    <StackPanel Margin="20">
        <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,4" TextWrapping="Wrap">
            <Run Text="Map field BigSeller ↔ cột Excel cho shop: " /><Run Text="{Binding ShopName, Mode=OneWay}" FontWeight="SemiBold" />
        </TextBlock>
        <TextBlock Text="Nhập CHỮ cột (A, B, C…); để trống = không dùng field đó." Style="{StaticResource Caption}" Margin="0,0,0,14" TextWrapping="Wrap" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Tên sp (tên đã sửa)" VerticalAlignment="Center" Margin="0,5" />
            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,5" Text="{Binding RewrittenName, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên gốc" VerticalAlignment="Center" Margin="0,5" />
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,5" Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="SKU" VerticalAlignment="Center" Margin="0,5" />
            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,5" Text="{Binding Sku, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Giá bán" VerticalAlignment="Center" Margin="0,5" />
            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,5" Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Item ID (Shopee)" VerticalAlignment="Center" Margin="0,5" />
            <TextBox Grid.Row="4" Grid.Column="1" Margin="0,5" Text="{Binding ItemId, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Link" VerticalAlignment="Center" Margin="0,5" />
            <TextBox Grid.Row="5" Grid.Column="1" Margin="0,5" Text="{Binding Link, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Hủy" MinWidth="90" IsCancel="True" Click="OnCancel" />
            <Button Style="{StaticResource PrimaryButton}" Content="OK" MinWidth="110" Margin="10,0,0,0" IsDefault="True" Click="OnOk" />
        </StackPanel>
    </StackPanel>
</Window>
