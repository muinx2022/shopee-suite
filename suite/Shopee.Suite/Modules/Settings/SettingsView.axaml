<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Shopee.Suite.Modules.Settings.SettingsView"
    x:Name="Root">

    <Grid Margin="28,22,28,24" RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Cài đặt" Classes="h1" />
                <TextBlock Text="Hiệu năng (trần cửa sổ Brave theo CPU/RAM), cấu hình AI, system prompt, và sao lưu/khôi phục dữ liệu."
                           Classes="caption" Margin="0,3,0,0" />
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{DynamicResource SubtleBrush}" CornerRadius="14" Padding="14,6">
                <TextBlock Text="{Binding Status}" FontSize="12.5" Foreground="{DynamicResource TextSecondaryBrush}" />
            </Border>
        </Grid>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- ══════════ TAB: Hiệu năng (trần cửa sổ Brave) ══════════ -->
            <TabItem Header="Hiệu năng">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                        <Border Classes="card" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Máy của bạn" Classes="h2" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding MachineInfo}" FontSize="14.5" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <!-- ── Phiên bản + tự cập nhật (Velopack) ── -->
                        <Border Classes="card" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Phiên bản &amp; cập nhật" Classes="h2" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding AppVersionText}" FontSize="14.5" FontWeight="SemiBold" FontFamily="{DynamicResource MonoFont}" />

                                <TextBlock Text="{Binding UpdateStatus}" Margin="0,10,0,0" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           IsVisible="{Binding UpdateStatus, Converter={StaticResource StringToBool}}" />

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="🔄  Kiểm tra bản mới" MinWidth="160"
                                            IsVisible="{Binding UpdateSupported}"
                                            Command="{Binding CheckUpdateCommand}" />
                                    <Button Classes="success" Content="⬆  Cập nhật &amp; khởi động lại" MinWidth="200" Margin="10,0,0,0"
                                            IsVisible="{Binding UpdateReady}"
                                            Command="{Binding ApplyUpdateCommand}"
                                            ToolTip.Tip="Đóng app + áp dụng bản đã tải + mở lại. Làm khi KHÔNG có job đang chạy." />
                                </StackPanel>

                                <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,10,0,0"
                                           IsVisible="{Binding UpdateNotSupported}"
                                           Text="ℹ Tự cập nhật chỉ hoạt động khi app được cài qua bộ cài Velopack (Setup.exe trên Windows / AppImage trên Linux). Bản chạy trực tiếp từ thư mục build không tự cập nhật." />
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Tài nguyên cho phép app dùng → tính số cửa sổ Brave tối đa" Classes="h2" Margin="0,0,0,12" />
                                <Grid ColumnDefinitions="Auto,Auto,*" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Số nhân CPU dùng" Classes="caption" VerticalAlignment="Center" Margin="0,0,12,8" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Width="80" Margin="0,0,8,8" VerticalContentAlignment="Center"
                                             Text="{Binding UsableCpu}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,0,8" Classes="caption">
                                        <Run Text="/ máy có " /><Run Text="{Binding CpuCoresMax, Mode=OneWay}" /><Run Text=" nhân   (mỗi cửa sổ ~1 nhân)" />
                                    </TextBlock>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="RAM dùng (GB)" Classes="caption" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Width="80" Margin="0,0,8,0" VerticalContentAlignment="Center"
                                             Text="{Binding UsableRamGb}" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Classes="caption">
                                        <Run Text="/ máy có " /><Run Text="{Binding RamGbMax, Mode=OneWay}" /><Run Text=" GB   (mỗi cửa sổ ~2GB)" />
                                    </TextBlock>
                                </Grid>

                                <Border Background="{DynamicResource SubtleBrush}" CornerRadius="6" Padding="12,8" Margin="0,14,0,0">
                                    <TextBlock Text="{Binding ComputedMaxInfo}" FontSize="14" FontWeight="SemiBold" />
                                </Border>

                                <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,12,0,0"
                                           Text="Đặt THẤP hơn để chừa CPU/RAM cho việc khác (máy mượt); CAO hơn = cào nhanh hơn nhưng máy dễ ì. Mặc định = nửa số nhân + toàn bộ RAM. Có hiệu lực đầy đủ từ lượt chạy kế tiếp." />
                                <Button Classes="primary" Content="💾  Lưu" MinWidth="110"
                                        HorizontalAlignment="Left" Margin="0,14,0,0" Command="{Binding SavePerformanceCommand}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════ TAB 1: Nhà cung cấp AI ══════════ -->
            <TabItem Header="Nhà cung cấp AI">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                        <Border Classes="card" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Nhà cung cấp AI đang dùng" Classes="h2" Margin="0,0,0,10" />
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox Width="200" SelectedItem="{Binding Provider}" ItemsSource="{Binding ProviderOptions}" />
                                    <TextBlock Text="Số mục / batch" Classes="caption" VerticalAlignment="Center" Margin="20,0,8,0" />
                                    <TextBox Width="70" Text="{Binding BatchSize}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Padding="18" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="OpenAI" Classes="h2" Margin="0,0,0,10" />
                                <TextBlock Text="Model" Classes="caption" />
                                <TextBox Margin="0,3,0,10" Text="{Binding OpenAiModel}" />
                                <TextBlock Text="API key" Classes="caption" />
                                <TextBox Margin="0,3,0,0" FontFamily="{DynamicResource MonoFont}" FontSize="12"
                                         Text="{Binding OpenAiApiKey}" />
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Padding="18" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Anthropic (Claude)" Classes="h2" Margin="0,0,0,10" />
                                <TextBlock Text="Model" Classes="caption" />
                                <TextBox Margin="0,3,0,10" Text="{Binding AnthropicModel}" />
                                <TextBlock Text="API key" Classes="caption" />
                                <TextBox Margin="0,3,0,0" FontFamily="{DynamicResource MonoFont}" FontSize="12"
                                         Text="{Binding AnthropicApiKey}" />
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Padding="18" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Google Gemini" Classes="h2" Margin="0,0,0,10" />
                                <TextBlock Text="Model" Classes="caption" />
                                <TextBox Margin="0,3,0,10" Text="{Binding GeminiModel}" />
                                <TextBlock Text="API key" Classes="caption" />
                                <TextBox Margin="0,3,0,0" FontFamily="{DynamicResource MonoFont}" FontSize="12"
                                         Text="{Binding GeminiApiKey}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Classes="primary" Content="💾  Lưu" MinWidth="110" Command="{Binding SaveCommand}" />
                            <Button Content="⚡  Test kết nối" MinWidth="130" Margin="10,0,0,0" Command="{Binding TestCommand}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════ TAB 2: System Prompt ══════════ -->
            <TabItem Header="System Prompt">
                <Grid Margin="0,12,0,0" RowDefinitions="Auto,*,*,Auto">

                    <TextBlock Grid.Row="0" Classes="caption" TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="System prompt cho 2 tác vụ AI ở Update Product. Để trống = dùng mặc định. Prompt viết lại tên có thể chứa {versionCount} (số phương án cần tạo)." />

                    <!-- Prompt viết lại TÊN -->
                    <DockPanel Grid.Row="1" Margin="0,0,0,12">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                            <TextBlock Text="Prompt — Viết lại TÊN sản phẩm" Classes="h2" VerticalAlignment="Center" />
                            <Button HorizontalAlignment="Right" Content="↩ Khôi phục mặc định" Command="{Binding ResetNamePromptCommand}" />
                        </Grid>
                        <Border Classes="card" ClipToBounds="True">
                            <TextBox Classes="mono" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Text="{Binding NameRewritePrompt}" />
                        </Border>
                    </DockPanel>

                    <!-- Prompt viết lại MÔ TẢ -->
                    <DockPanel Grid.Row="2" Margin="0,0,0,12">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                            <TextBlock Text="Prompt — Viết lại MÔ TẢ sản phẩm" Classes="h2" VerticalAlignment="Center" />
                            <Button HorizontalAlignment="Right" Content="↩ Khôi phục mặc định" Command="{Binding ResetDescriptionPromptCommand}" />
                        </Grid>
                        <Border Classes="card" ClipToBounds="True">
                            <TextBox Classes="mono" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Text="{Binding DescriptionPrompt}" />
                        </Border>
                    </DockPanel>

                    <Button Grid.Row="3" HorizontalAlignment="Left" Classes="primary"
                            Content="💾  Lưu prompt" MinWidth="130" Command="{Binding SaveCommand}" />
                </Grid>
            </TabItem>

            <!-- ══════════ TAB 3: Sao lưu / Khôi phục ══════════ -->
            <TabItem Header="Sao lưu / Khôi phục">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <Border Classes="card" Padding="18" MaxWidth="720" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Sao lưu / Khôi phục dữ liệu (đồng bộ sang máy khác)" Classes="h2" Margin="0,0,0,4" />
                            <TextBlock TextWrapping="Wrap" Classes="caption" Margin="0,0,0,12"
                                       Text="Đóng gói tài khoản + cookie + cấu hình ra 1 file .zip để mang sang máy khác. Cookie BigSeller mang theo dùng được; phiên Shopee có thể phải đăng nhập lại trên máy mới." />

                            <TextBlock Text="Chọn mục:" Classes="caption" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <CheckBox Content="Tài khoản BigSeller (+ cookie)" IsChecked="{Binding BackupBigSeller}" />
                                <CheckBox Content="Tài khoản Shopee + proxy" IsChecked="{Binding BackupShopee}" Margin="20,0,0,0" />
                                <CheckBox Content="Cấu hình AI (keys)" IsChecked="{Binding BackupAi}" Margin="20,0,0,0" />
                            </StackPanel>

                            <Button Classes="primary" Content="⬆  Sao lưu ra file .zip" MinWidth="190"
                                    HorizontalAlignment="Left" Command="{Binding ExportBackupCommand}" />

                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,16,0,14" />

                            <TextBlock Text="Khôi phục từ file .zip (áp dụng cho các mục đã tick ở trên):" Classes="caption" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton GroupName="impmode" Content="Gộp (thêm mới, giữ tk cũ)" IsChecked="True" VerticalAlignment="Center" />
                                <RadioButton GroupName="impmode" Content="Thay thế (ghi đè)" Margin="20,0,0,0" VerticalAlignment="Center"
                                             IsChecked="{Binding ImportReplace}" />
                            </StackPanel>

                            <TextBlock Text="Thư mục data workbook trên máy này (tuỳ chọn — đổi đường dẫn file Excel của tk khi sang máy khác):" Classes="caption" Margin="0,0,0,4" TextWrapping="Wrap" />
                            <Grid Margin="0,0,0,12" ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" Text="{Binding RebaseWorkbookDir}" FontFamily="{DynamicResource MonoFont}" FontSize="11.5" VerticalContentAlignment="Center" />
                                <Button Grid.Column="1" Content="📂" Width="40" Margin="8,0,0,0" Command="{Binding BrowseRebaseDirCommand}" />
                            </Grid>

                            <Button Classes="success" Content="⬇  Khôi phục từ file .zip" MinWidth="190"
                                    HorizontalAlignment="Left" Command="{Binding ImportBackupCommand}" />
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════ TAB 4: Đồng bộ nhiều máy (chỉ phần CLIENT) ══════════ -->
            <TabItem Header="Đồng bộ nhiều máy">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">

                        <Border Classes="card" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Máy này" Classes="h2" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding MachineLabel}" FontSize="14.5" FontWeight="SemiBold" FontFamily="{DynamicResource MonoFont}" />
                                <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,6,0,0"
                                           Text="Tên này nhận diện máy trên bảng trạng thái và khi giành/khoá việc giữa các máy." />

                                <TextBlock Text="Tên hiển thị (đặt tuỳ ý, vd: Máy của ABC):" Classes="caption" Margin="0,12,0,4" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" VerticalContentAlignment="Center"
                                             Text="{Binding MachineDisplayName}" />
                                    <Button Grid.Column="1" Content="💾 Lưu tên" Margin="8,0,0,0" Command="{Binding SaveMachineNameCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- App là CLIENT-only (Hub đã tách sang server web riêng) → luôn hiện phần Kết nối. -->
                        <Border Classes="card" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Kết nối tới Hub (server đồng bộ + điều phối)" Classes="h2" Margin="0,0,0,6" />
                                <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,0,0,12"
                                           Text="Dán URL + API token của Hub (server đồng bộ chạy riêng qua Cloudflare Tunnel). Khi bật, các máy chia sẻ cấu hình + tránh làm trùng tài khoản. Để trống = chạy độc lập như cũ." />

                                <CheckBox Content="Bật đồng bộ với Hub" IsChecked="{Binding HubEnabled}" Margin="0,0,0,12" />

                                <TextBlock Text="URL Hub" Classes="caption" />
                                <TextBox Margin="0,3,0,10" FontFamily="{DynamicResource MonoFont}" FontSize="12"
                                         Text="{Binding HubBaseUrl}" />

                                <TextBlock Text="API token" Classes="caption" />
                                <TextBox Margin="0,3,0,0" FontFamily="{DynamicResource MonoFont}" FontSize="12"
                                         Text="{Binding HubApiToken}" />

                                <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,10,0,0"
                                           Text="Bấm &quot;Kiểm tra&quot; để thử URL/token trước; &quot;Kết nối ngay&quot; lưu + áp dụng liền (khỏi khởi động lại)." />

                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button Classes="primary" Content="{Binding ConnectToggleText}" MinWidth="150"
                                            Command="{Binding ConnectToggleCommand}"
                                            ToolTip.Tip="Chưa nối → kết nối; đang nối → ngắt. Áp dụng ngay, không cần khởi động lại." />
                                    <Button Content="⚡  Kiểm tra" Margin="10,0,0,0" Command="{Binding TestHubClientCommand}"
                                            ToolTip.Tip="Ping thử Hub bằng URL/token đang nhập để biết có nối được không." />
                                    <Button Content="💾  Chỉ lưu" Margin="10,0,0,0" Command="{Binding SaveHubClientCommand}"
                                            ToolTip.Tip="Lưu cấu hình, áp dụng ở lần khởi động app kế tiếp." />
                                </StackPanel>

                                <TextBlock Text="{Binding HubClientStatus}" Margin="0,10,0,0" FontWeight="SemiBold" TextWrapping="Wrap"
                                           IsVisible="{Binding HubClientStatus, Converter={StaticResource StringToBool}}" />

                                <Button Content="⬆  Đẩy cấu hình lên Hub" HorizontalAlignment="Left" Margin="0,12,0,0"
                                        Command="{Binding PushConfigToHubCommand}"
                                        ToolTip.Tip="Đẩy accounts/bigseller/ai/cookie hiện tại lên Hub làm nguồn cho các máy khác kéo về." />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>