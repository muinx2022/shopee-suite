<UserControl
    x:Class="Shopee.Suite.Modules.Settings.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root">
    <UserControl.Resources>
        <!-- Nút chọn vai trò (RadioButton style-thành-nút): GIỮ trạng thái đã chọn, không mất khi rê chuột ra -->
        <Style x:Key="RoleToggle" TargetType="RadioButton">
            <Setter Property="MinWidth" Value="200" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Background="{StaticResource SubtleBrush}" BorderThickness="1.5" BorderBrush="{StaticResource BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="28,22,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Cài đặt" Style="{StaticResource H1}" />
                <TextBlock Text="Hiệu năng (trần cửa sổ Brave theo CPU/RAM), cấu hình AI, system prompt, và sao lưu/khôi phục dữ liệu."
                           Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{StaticResource SubtleBrush}" CornerRadius="14" Padding="14,6">
                <TextBlock Text="{Binding Status}" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>
        </Grid>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- ══════════ TAB: Hiệu năng (trần cửa sổ Brave) ══════════ -->
            <TabItem Header="Hiệu năng">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Máy của bạn" Style="{StaticResource H2}" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding MachineInfo}" FontSize="14.5" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Tài nguyên cho phép app dùng → tính số cửa sổ Brave tối đa" Style="{StaticResource H2}" Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Số nhân CPU dùng" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,12,8" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Width="80" Margin="0,0,8,8" VerticalContentAlignment="Center"
                                             Text="{Binding UsableCpu, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,0,8" Style="{StaticResource Caption}">
                                        <Run Text="/ máy có " /><Run Text="{Binding CpuCoresMax, Mode=OneWay}" /><Run Text=" nhân   (mỗi cửa sổ ~1 nhân)" />
                                    </TextBlock>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="RAM dùng (GB)" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Width="80" Margin="0,0,8,0" VerticalContentAlignment="Center"
                                             Text="{Binding UsableRamGb, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource Caption}">
                                        <Run Text="/ máy có " /><Run Text="{Binding RamGbMax, Mode=OneWay}" /><Run Text=" GB   (mỗi cửa sổ ~2GB)" />
                                    </TextBlock>
                                </Grid>

                                <Border Background="{StaticResource SubtleBrush}" CornerRadius="6" Padding="12,8" Margin="0,14,0,0">
                                    <TextBlock Text="{Binding ComputedMaxInfo}" FontSize="14" FontWeight="SemiBold" />
                                </Border>

                                <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,12,0,0"
                                           Text="Đặt THẤP hơn để chừa CPU/RAM cho việc khác (máy mượt); CAO hơn = cào nhanh hơn nhưng máy dễ ì. Mặc định = nửa số nhân + toàn bộ RAM. Có hiệu lực đầy đủ từ lượt chạy kế tiếp." />
                                <Button Style="{StaticResource PrimaryButton}" Content="💾  Lưu" MinWidth="110"
                                        HorizontalAlignment="Left" Margin="0,14,0,0" Command="{Binding SavePerformanceCommand}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════ TAB 1: Nhà cung cấp AI ══════════ -->
            <TabItem Header="Nhà cung cấp AI">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Nhà cung cấp AI đang dùng" Style="{StaticResource H2}" Margin="0,0,0,10" />
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox Width="200" SelectedItem="{Binding Provider}" ItemsSource="{Binding ProviderOptions}" />
                                    <TextBlock Text="Số mục / batch" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="20,0,8,0" />
                                    <TextBox Width="70" Text="{Binding BatchSize}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="OpenAI" Style="{StaticResource H2}" Margin="0,0,0,10" />
                                <TextBlock Text="Model" Style="{StaticResource Caption}" />
                                <TextBox Margin="0,3,0,10" Text="{Binding OpenAiModel, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="API key" Style="{StaticResource Caption}" />
                                <TextBox Margin="0,3,0,0" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                         Text="{Binding OpenAiApiKey, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Anthropic (Claude)" Style="{StaticResource H2}" Margin="0,0,0,10" />
                                <TextBlock Text="Model" Style="{StaticResource Caption}" />
                                <TextBox Margin="0,3,0,10" Text="{Binding AnthropicModel, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="API key" Style="{StaticResource Caption}" />
                                <TextBox Margin="0,3,0,0" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                         Text="{Binding AnthropicApiKey, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Google Gemini" Style="{StaticResource H2}" Margin="0,0,0,10" />
                                <TextBlock Text="Model" Style="{StaticResource Caption}" />
                                <TextBox Margin="0,3,0,10" Text="{Binding GeminiModel, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="API key" Style="{StaticResource Caption}" />
                                <TextBox Margin="0,3,0,0" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                         Text="{Binding GeminiApiKey, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Style="{StaticResource PrimaryButton}" Content="💾  Lưu" MinWidth="110" Command="{Binding SaveCommand}" />
                            <Button Content="⚡  Test kết nối" MinWidth="130" Margin="10,0,0,0" Command="{Binding TestCommand}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════ TAB 2: System Prompt ══════════ -->
            <TabItem Header="System Prompt">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="System prompt cho 2 tác vụ AI ở Update Product. Để trống = dùng mặc định. Prompt viết lại tên có thể chứa {versionCount} (số phương án cần tạo)." />

                    <!-- Prompt viết lại TÊN -->
                    <DockPanel Grid.Row="1" Margin="0,0,0,12">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                            <TextBlock Text="Prompt — Viết lại TÊN sản phẩm" Style="{StaticResource H2}" VerticalAlignment="Center" />
                            <Button HorizontalAlignment="Right" Content="↩ Khôi phục mặc định" Command="{Binding ResetNamePromptCommand}" />
                        </Grid>
                        <Border Style="{StaticResource Card}" ClipToBounds="True">
                            <TextBox Style="{StaticResource MonoTextBox}" FontSize="12"
                                     Text="{Binding NameRewritePrompt, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </DockPanel>

                    <!-- Prompt viết lại MÔ TẢ -->
                    <DockPanel Grid.Row="2" Margin="0,0,0,12">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                            <TextBlock Text="Prompt — Viết lại MÔ TẢ sản phẩm" Style="{StaticResource H2}" VerticalAlignment="Center" />
                            <Button HorizontalAlignment="Right" Content="↩ Khôi phục mặc định" Command="{Binding ResetDescriptionPromptCommand}" />
                        </Grid>
                        <Border Style="{StaticResource Card}" ClipToBounds="True">
                            <TextBox Style="{StaticResource MonoTextBox}" FontSize="12"
                                     Text="{Binding DescriptionPrompt, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </DockPanel>

                    <Button Grid.Row="3" HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}"
                            Content="💾  Lưu prompt" MinWidth="130" Command="{Binding SaveCommand}" />
                </Grid>
            </TabItem>

            <!-- ══════════ TAB 3: Sao lưu / Khôi phục ══════════ -->
            <TabItem Header="Sao lưu / Khôi phục">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <Border Style="{StaticResource Card}" Padding="18" MaxWidth="720" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Sao lưu / Khôi phục dữ liệu (đồng bộ sang máy khác)" Style="{StaticResource H2}" Margin="0,0,0,4" />
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource Caption}" Margin="0,0,0,12"
                                       Text="Đóng gói tài khoản + cookie + cấu hình ra 1 file .zip để mang sang máy khác. Cookie BigSeller mang theo dùng được; phiên Shopee có thể phải đăng nhập lại trên máy mới." />

                            <TextBlock Text="Chọn mục:" Style="{StaticResource Caption}" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <CheckBox Content="Tài khoản BigSeller (+ cookie)" IsChecked="{Binding BackupBigSeller}" />
                                <CheckBox Content="Tài khoản Shopee + proxy" IsChecked="{Binding BackupShopee}" Margin="20,0,0,0" />
                                <CheckBox Content="Cấu hình AI (keys)" IsChecked="{Binding BackupAi}" Margin="20,0,0,0" />
                            </StackPanel>

                            <Button Style="{StaticResource PrimaryButton}" Content="⬆  Sao lưu ra file .zip" MinWidth="190"
                                    HorizontalAlignment="Left" Command="{Binding ExportBackupCommand}" />

                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,16,0,14" />

                            <TextBlock Text="Khôi phục từ file .zip (áp dụng cho các mục đã tick ở trên):" Style="{StaticResource Caption}" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton GroupName="impmode" Content="Gộp (thêm mới, giữ tk cũ)" IsChecked="True" VerticalAlignment="Center" />
                                <RadioButton GroupName="impmode" Content="Thay thế (ghi đè)" Margin="20,0,0,0" VerticalAlignment="Center"
                                             IsChecked="{Binding ImportReplace}" />
                            </StackPanel>

                            <TextBlock Text="Thư mục data workbook trên máy này (tuỳ chọn — đổi đường dẫn file Excel của tk khi sang máy khác):" Style="{StaticResource Caption}" Margin="0,0,0,4" TextWrapping="Wrap" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding RebaseWorkbookDir}" FontFamily="{StaticResource MonoFont}" FontSize="11.5" VerticalContentAlignment="Center" />
                                <Button Grid.Column="1" Content="📂" Width="40" Margin="8,0,0,0" Command="{Binding BrowseRebaseDirCommand}" />
                            </Grid>

                            <Button Style="{StaticResource SuccessButton}" Content="⬇  Khôi phục từ file .zip" MinWidth="190"
                                    HorizontalAlignment="Left" Command="{Binding ImportBackupCommand}" />
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════ TAB 4: Đồng bộ nhiều máy ══════════ -->
            <TabItem Header="Đồng bộ nhiều máy">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">

                        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Máy này" Style="{StaticResource H2}" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding MachineLabel}" FontSize="14.5" FontWeight="SemiBold" FontFamily="{StaticResource MonoFont}" />
                                <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,6,0,0"
                                           Text="Tên này nhận diện máy trên bảng trạng thái và khi giành/khoá việc giữa các máy." />

                                <TextBlock Text="Tên hiển thị (đặt tuỳ ý, vd: Máy của ABC):" Style="{StaticResource Caption}" Margin="0,12,0,4" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" VerticalContentAlignment="Center"
                                             Text="{Binding MachineDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Content="💾 Lưu tên" Margin="8,0,0,0" Command="{Binding SaveMachineNameCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Bộ chọn vai trò máy này (mặc định chưa chọn gì; nút GIỮ trạng thái đã chọn) -->
                        <TextBlock Text="Vai trò máy này:" Style="{StaticResource Caption}" Margin="2,0,0,6" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <!-- Không dùng GroupName: việc loại-trừ-nhau do VM xử lý (setter), nên binding LUÔN đẩy đúng false về nguồn. -->
                            <RadioButton Style="{StaticResource RoleToggle}" Content="👤  Máy này là CLIENT"
                                         IsChecked="{Binding IsClientRole, Mode=TwoWay}" />
                            <RadioButton Style="{StaticResource RoleToggle}" Content="🖥  Máy này là HUB"
                                         IsChecked="{Binding IsHubRole, Mode=TwoWay}" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="2,0,0,12"
                                   Visibility="{Binding ShowRoleHint, Converter={StaticResource BoolToVis}}"
                                   Text="Chọn CLIENT (máy này kết nối tới Hub) hoặc HUB (máy này làm server cho các máy khác). Bấm vào đúng phần bạn cần." />

                        <Border Style="{StaticResource Card}" Padding="18"
                                Visibility="{Binding IsClientRole, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="Kết nối tới Hub (server đồng bộ + điều phối)" Style="{StaticResource H2}" Margin="0,0,0,6" />
                                <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,12"
                                           Text="Dán URL + API token do máy-Hub cung cấp (một máy của bạn bật chế độ Hub qua Cloudflare Tunnel). Khi bật, các máy chia sẻ cấu hình + tránh làm trùng tài khoản. Để trống = chạy độc lập như cũ." />

                                <CheckBox Content="Bật đồng bộ với Hub" IsChecked="{Binding HubEnabled}" Margin="0,0,0,12" />

                                <TextBlock Text="URL Hub" Style="{StaticResource Caption}" />
                                <TextBox Margin="0,3,0,10" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                         Text="{Binding HubBaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="API token" Style="{StaticResource Caption}" />
                                <TextBox Margin="0,3,0,0" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                         Text="{Binding HubApiToken, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,10,0,0"
                                           Text="Bấm &quot;Kiểm tra&quot; để thử URL/token trước; &quot;Kết nối ngay&quot; lưu + áp dụng liền (khỏi khởi động lại)." />

                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button Style="{StaticResource PrimaryButton}" Content="{Binding ConnectToggleText}" MinWidth="150"
                                            Command="{Binding ConnectToggleCommand}"
                                            ToolTip="Chưa nối → kết nối; đang nối → ngắt. Áp dụng ngay, không cần khởi động lại." />
                                    <Button Content="⚡  Kiểm tra" Margin="10,0,0,0" Command="{Binding TestHubClientCommand}"
                                            ToolTip="Ping thử Hub bằng URL/token đang nhập để biết có nối được không." />
                                    <Button Content="💾  Chỉ lưu" Margin="10,0,0,0" Command="{Binding SaveHubClientCommand}"
                                            ToolTip="Lưu cấu hình, áp dụng ở lần khởi động app kế tiếp." />
                                </StackPanel>

                                <TextBlock Text="{Binding HubClientStatus}" Margin="0,10,0,0" FontWeight="SemiBold" TextWrapping="Wrap"
                                           Visibility="{Binding HubClientStatus, Converter={StaticResource StringToVis}}" />

                                <Button Content="⬆  Đẩy cấu hình lên Hub" HorizontalAlignment="Left" Margin="0,12,0,0"
                                        Command="{Binding PushConfigToHubCommand}"
                                        ToolTip="Đẩy accounts/bigseller/ai/cookie hiện tại lên Hub làm nguồn cho các máy khác kéo về." />
                            </StackPanel>
                        </Border>

                        <!-- Chế độ Hub: máy này LÀM server -->
                        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,0"
                                Visibility="{Binding IsHubRole, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="Biến máy này thành Hub (server)" Style="{StaticResource H2}" Margin="0,0,0,6" />
                                <TextBlock Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,12"
                                           Text="Chỉ bật trên ĐÚNG 1 máy (máy luôn bật). Trên dashboard Cloudflare Zero Trust, tạo tunnel + Public Hostname (api.&lt;domain&gt; → HTTP localhost:cổng này). Cách A: dán tunnel token vào đây, app tự tải+chạy cloudflared. Cách B: cài cloudflared như service (cloudflared service install …) rồi ĐỂ TRỐNG ô token. Máy Hub vẫn chạy như một worker bình thường." />

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Cổng local" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBox Grid.Column="1" Width="90" VerticalContentAlignment="Center"
                                             Text="{Binding HubPort, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <TextBlock Text="Domain công khai (vd: api.tencuaban.com)" Style="{StaticResource Caption}" />
                                <TextBox Margin="0,3,0,10" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                         Text="{Binding HubDomain, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Cloudflare tunnel token" Style="{StaticResource Caption}" />
                                <TextBox Margin="0,3,0,10" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                         Text="{Binding HubTunnelToken, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="API token (client dùng để kết nối — phát cho các máy khác)" Style="{StaticResource Caption}" />
                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" FontFamily="{StaticResource MonoFont}" FontSize="12" VerticalContentAlignment="Center"
                                             Text="{Binding HubServerApiToken, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Content="🎲 Sinh" Width="70" Margin="8,0,0,0" Command="{Binding GenerateHubServerTokenCommand}" />
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                    <Button Style="{StaticResource SuccessButton}" Content="▶  Bật Hub" MinWidth="130" Command="{Binding StartHubCommand}" />
                                    <Button Content="■  Dừng Hub" MinWidth="120" Margin="10,0,0,0" Command="{Binding StopHubCommand}" />
                                    <TextBlock Text="{Binding HubServerStatus}" VerticalAlignment="Center" Margin="16,0,0,0" FontWeight="SemiBold" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
