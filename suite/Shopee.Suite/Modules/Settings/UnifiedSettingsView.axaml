<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="Shopee.Suite.Modules.Settings.UnifiedSettingsView">

    <!-- Màn Cài đặt GỘP: một ScrollViewer, hai section. Mỗi section nhúng thẳng view cài đặt con (view tự chứa
         resource/style của nó) qua ContentControl → DataTemplate/ViewLocator dựng đúng view. Section "Đơn hàng"
         ẩn khi module đơn hàng không khởi tạo được. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- ══════════ SECTION: Chế độ ứng dụng (LUÔN hiện ở mọi chế độ) ══════════ -->
            <Border Background="{DynamicResource SubtleBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="28,14">
                <StackPanel>
                    <TextBlock Text="CHẾ ĐỘ ỨNG DỤNG" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="Chọn nhóm chức năng hiển thị cho gọn. Đổi chế độ sẽ khởi động lại app; cập nhật vẫn tải bản đầy đủ."
                               Classes="caption" Margin="0,2,0,0" />
                </StackPanel>
            </Border>
            <StackPanel Margin="28,14" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Chế độ:" VerticalAlignment="Center" Classes="caption" />
                    <ComboBox MinWidth="380" VerticalAlignment="Center"
                              ItemsSource="{Binding Modes}"
                              SelectedItem="{Binding SelectedMode, Mode=TwoWay}" />
                    <Button Classes="primary" Content="Lưu &amp; khởi động lại"
                            Command="{Binding SaveModeAndRestartCommand}"
                            ToolTip.Tip="Lưu chế độ đã chọn rồi mở lại app để áp dụng" />
                </StackPanel>
            </StackPanel>

            <!-- ══════════ SECTION: Phiên bản & cập nhật (MỚI — LUÔN hiện, dùng chung cho mọi chế độ) ══════════ -->
            <!-- Card Update tách khỏi SettingsView để KHÔNG bị ẩn theo chế độ (Shopee mode ẩn cả section Workspace).
                 DataContext ở đây là UnifiedSettingsViewModel nên MỌI bind phải prefix Suite.* (card gốc trong
                 SettingsView bind trực tiếp SettingsViewModel). Suite VM luôn sống dù view của nó ẩn ⇒ nút vẫn chạy. -->
            <Border Background="{DynamicResource SubtleBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="28,14">
                <StackPanel>
                    <TextBlock Text="PHIÊN BẢN &amp; CẬP NHẬT" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="Cập nhật dùng chung cho mọi chế độ."
                               Classes="caption" Margin="0,2,0,0" />
                </StackPanel>
            </Border>
            <Border Classes="card" Padding="18" Margin="28,14" HorizontalAlignment="Left" MaxWidth="520">
                <StackPanel>
                    <TextBlock Text="Phiên bản &amp; cập nhật" Classes="h2" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding Suite.AppVersionText}" FontSize="14.5" FontWeight="SemiBold" FontFamily="{DynamicResource MonoFont}" />

                    <TextBlock Text="{Binding Suite.UpdateStatus}" Margin="0,10,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               IsVisible="{Binding Suite.UpdateStatus, Converter={StaticResource StringToBool}}" />

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="🔄  Kiểm tra bản mới" MinWidth="160"
                                IsVisible="{Binding Suite.UpdateSupported}"
                                Command="{Binding Suite.CheckUpdateCommand}" />
                        <Button Classes="success" Content="⬆  Cập nhật &amp; khởi động lại" MinWidth="200" Margin="10,0,0,0"
                                IsVisible="{Binding Suite.UpdateReady}"
                                Command="{Binding Suite.ApplyUpdateCommand}"
                                ToolTip.Tip="Đóng app + áp dụng bản đã tải + mở lại. Làm khi KHÔNG có job đang chạy." />
                    </StackPanel>

                    <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,10,0,0"
                               IsVisible="{Binding Suite.UpdateNotSupported}"
                               Text="ℹ Tự cập nhật chỉ hoạt động khi app được cài qua bộ cài Velopack (Setup.exe trên Windows / AppImage trên Linux). Bản chạy trực tiếp từ thư mục build không tự cập nhật." />
                </StackPanel>
            </Border>

            <!-- ══════════ SECTION: Workspace (Hiệu năng · đồng bộ Hub) — ẩn ở chế độ Shopee ══════════ -->
            <Border Background="{DynamicResource SubtleBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="28,14" IsVisible="{Binding ShowsWorkspaceSettings}">
                <StackPanel>
                    <TextBlock Text="WORKSPACE" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="Hiệu năng · đồng bộ Hub"
                               Classes="caption" Margin="0,2,0,0" />
                </StackPanel>
            </Border>
            <ContentControl Content="{Binding Suite}" IsVisible="{Binding ShowsWorkspaceSettings}" />

            <!-- ══════════ SECTION: Đơn hàng (ẩn khi module không chạy) ══════════ -->
            <Border Background="{DynamicResource SubtleBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1"
                    Padding="28,14" IsVisible="{Binding HasOrders}">
                <StackPanel>
                    <TextBlock Text="ĐƠN HÀNG" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="Trình duyệt · thư mục phiếu · chu kỳ theo dõi · Google Sheet · webhook"
                               Classes="caption" Margin="0,2,0,0" />
                </StackPanel>
            </Border>
            <ContentControl Content="{Binding Orders}" IsVisible="{Binding HasOrders}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
