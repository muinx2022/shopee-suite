<UserControl
    x:Class="Shopee.Suite.Modules.Fleet.FleetView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Icon ⟳ xoay liên tục khi nút đang chạy: Visibility=Visible (IsRunning) → spin; Collapsed → dừng.
             RenderTransform đặt INLINE trên từng spinner (tránh chia sẻ Freezable khi animate). -->
        <Style x:Key="SpinnerText" TargetType="TextBlock">
            <Setter Property="Text" Value="⟳" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard x:Name="SpinSb">
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                    From="0" To="360" Duration="0:0:0.8" RepeatBehavior="Forever" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="SpinSb" />
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Selectbox trạng thái trên ô lưới (Scrape/Import/Update): mặt ô = HIỆN TRẠNG (mục [0], đọc màu theo
             Brush); xổ ra chỉ 3 hành động đặt tay (mục [0] IsCurrent bị ẩn khỏi danh sách). Nhẹ chrome (không
             viền/nền) để đọc như chữ trạng thái cũ nhưng thêm mũi ▾ để đặt tay ngay tại ô. -->
        <Style x:Key="QueueStateCombo" TargetType="ComboBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="2,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}" FontWeight="SemiBold" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="28,22,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Trạng thái &amp; Giao việc" Style="{StaticResource H1}" />
                <TextBlock Text="Theo dõi máy + Hub giao việc cho từng máy (scrape · import · update theo dây chuyền)."
                           Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="110"
                    Content="⟳  Làm mới" Command="{Binding RefreshCommand}" />
        </Grid>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- ════════════ TAB 1: THEO DÕI ════════════ -->
            <TabItem Header="Theo dõi">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource SubtleBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding Machines}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Status}" Style="{StaticResource Caption}" Margin="0,4,0,8" />
                            <CheckBox Content="⚠ Chạy đè: bỏ qua khoá của máy khác ở các lượt chạy tới (chỉ bật khi chắc máy kia đã dừng)"
                                      IsChecked="{Binding ForceNextRun}" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource Card}" ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Máy" Binding="{Binding MachineName}" Width="170" />
                                <DataGridTextColumn Header="Tài khoản" Binding="{Binding AccountLabel}" Width="*" />
                                <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="*" />
                                <DataGridTextColumn Header="Việc" Binding="{Binding Op}" Width="100" />
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding State}" Width="140" />
                                <DataGridTextColumn Header="Cập nhật" Binding="{Binding Updated}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════ TAB 2: GIAO VIỆC ════════════ -->
            <TabItem Header="Giao việc">
                <Grid Margin="0,12,0,0">

                    <!-- ───── Bản HUB: bảng điều phối ───── -->
                    <Grid Visibility="{Binding IsHubBoard, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Bước 1: Hàng đợi việc — chọn 1 shop để giao -->
                        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Bước 1 — bấm chọn 1 shop trong bảng (mỗi dòng = 1 shop)"
                                           Style="{StaticResource H2}" Margin="12,10,12,6" />
                                <DataGrid ItemsSource="{Binding Queue}" SelectedItem="{Binding SelectedQueue}"
                                          AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                          CanUserAddRows="False" GridLinesVisibility="None" SelectionMode="Single">
                                    <!-- Gộp theo tài khoản: kẻ vạch phân nhóm ở dòng shop ĐẦU của mỗi tk -->
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAccountFirstRow}" Value="True">
                                                    <Setter Property="BorderThickness" Value="0,1,0,0" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tài khoản" Binding="{Binding AccountLabel}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="*" />
                                        <!-- Mỗi ô op là 1 selectbox: mặt ô hiện trạng thái (màu theo brush), bấm ▾ để đặt tay
                                             ✓ Xong / Chưa / ■ Dừng ngay tại ô. Nếu op ĐANG CHẠY (…Locked) → chỉ hiện label
                                             tĩnh, không cho selectbox (khỏi đè ledger giữa chừng phá lượt máy đang chạy). -->
                                        <DataGridTemplateColumn Header="Scrape" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <ComboBox Style="{StaticResource QueueStateCombo}"
                                                                  ItemsSource="{Binding ScrapeOptions}" SelectedItem="{Binding ScrapeSel, Mode=TwoWay}"
                                                                  ToolTip="{Binding ScrapeSel.Text}"
                                                                  Visibility="{Binding ScrapeLocked, Converter={StaticResource InverseBoolToVis}}" />
                                                        <TextBlock Text="{Binding ScrapeSel.Text}" Foreground="{Binding ScrapeSel.Brush}" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding ScrapeSel.Text}"
                                                                   Visibility="{Binding ScrapeLocked, Converter={StaticResource BoolToVis}}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Import" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <ComboBox Style="{StaticResource QueueStateCombo}"
                                                                  ItemsSource="{Binding ImportOptions}" SelectedItem="{Binding ImportSel, Mode=TwoWay}"
                                                                  ToolTip="{Binding ImportSel.Text}"
                                                                  Visibility="{Binding ImportLocked, Converter={StaticResource InverseBoolToVis}}" />
                                                        <TextBlock Text="{Binding ImportSel.Text}" Foreground="{Binding ImportSel.Brush}" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding ImportSel.Text}"
                                                                   Visibility="{Binding ImportLocked, Converter={StaticResource BoolToVis}}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Update" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <ComboBox Style="{StaticResource QueueStateCombo}"
                                                                  ItemsSource="{Binding UpdateOptions}" SelectedItem="{Binding UpdateSel, Mode=TwoWay}"
                                                                  ToolTip="{Binding UpdateSel.Text}"
                                                                  Visibility="{Binding UpdateLocked, Converter={StaticResource InverseBoolToVis}}" />
                                                        <TextBlock Text="{Binding UpdateSel.Text}" Foreground="{Binding UpdateSel.Brush}" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding UpdateSel.Text}"
                                                                   Visibility="{Binding UpdateLocked, Converter={StaticResource BoolToVis}}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Bước 2: Giao việc cho 1 máy (LUỒNG CHÍNH — thủ công) -->
                        <Border Grid.Row="1" Background="{StaticResource SubtleBrush}" CornerRadius="8" Padding="14,12" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Bước 2 — giao việc cho 1 máy" Style="{StaticResource H2}" Margin="0,0,0,10" />

                                <!-- Hàng chọn: mỗi cụm có nhãn nhỏ phía trên → canh đều, đỡ rối -->
                                <StackPanel Orientation="Horizontal">
                                    <!-- Việc (+ tuỳ chọn con, chỉ hiện khi Import → không xô ngang các cụm khác) -->
                                    <StackPanel VerticalAlignment="Top" Margin="0,0,22,0">
                                        <TextBlock Text="Việc" Style="{StaticResource Caption}" Margin="0,0,0,3" />
                                        <ComboBox ItemsSource="{Binding PinOps}" SelectedItem="{Binding PinOp}" Width="132" />
                                        <CheckBox IsChecked="{Binding PinImportFromClaimedTab}" Margin="1,7,0,0"
                                                  Content="Từ tab &quot;Đã nhận&quot;"
                                                  ToolTip="Khi chạy: mở trang Import, chọn tab &quot;Đã nhận&quot; rồi import theo logic sẵn có."
                                                  Visibility="{Binding IsPinImport, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>

                                    <!-- Máy đích (chấm 🟢/🟡/⚪ để khỏi ghim nhầm máy đang tắt → việc nằm "đã xếp" chờ mãi) -->
                                    <StackPanel VerticalAlignment="Top" Margin="0,0,22,0">
                                        <TextBlock Text="Cho máy" Style="{StaticResource Caption}" Margin="0,0,0,3" />
                                        <ComboBox ItemsSource="{Binding MachineRows}" SelectedItem="{Binding PinMachine}" Width="220">
                                            <!-- Acc BigSeller đang do máy khác giữ → máy đó khoá (CanPin=false): acc chỉ 1 máy/1 thời điểm. -->
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="IsEnabled" Value="{Binding CanPin}" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="ToolTip" Value="Tài khoản này đang chạy trên máy khác — chỉ ghim được cho đúng máy đó (mỗi acc 1 máy tại 1 thời điểm)." />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.ItemContainerStyle>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" ToolTip="{Binding Online}">
                                                        <TextBlock Text="{Binding Dot}" Margin="0,0,6,0" />
                                                        <TextBlock Text="{Binding Name}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Khoảng dòng -->
                                    <StackPanel VerticalAlignment="Top">
                                        <TextBlock Text="Dòng (0 = theo cấu hình máy)" Style="{StaticResource Caption}" Margin="0,0,0,3" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Width="58" VerticalContentAlignment="Center"
                                                     Text="{Binding PinStartRow}" ToolTip="Từ dòng (0 = để client dùng cấu hình của nó)" />
                                            <TextBlock Text="→" VerticalAlignment="Center" Margin="8,0,8,0" />
                                            <TextBox Width="58" VerticalContentAlignment="Center"
                                                     Text="{Binding PinEndRow}" ToolTip="Đến dòng (0 = hết)" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Ghim + Huỷ đứng CẠNH nhau. Huỷ chỉ hiện khi shop đang chọn CÓ việc chạy/xếp;
                                     lúc đó nút Ghim bị khoá (2 nút loại trừ nhau: đang có việc → chỉ Huỷ). -->
                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                    <Button Content="📌  Ghim cho máy này" Command="{Binding AssignManualCommand}"
                                            Style="{StaticResource SuccessButton}" MinWidth="160" />
                                    <TextBlock Style="{StaticResource SpinnerText}"
                                               Visibility="{Binding PinBusy, Converter={StaticResource BoolToVis}}">
                                        <TextBlock.RenderTransform><RotateTransform Angle="0" /></TextBlock.RenderTransform>
                                    </TextBlock>
                                    <Button Content="✖  Huỷ việc của shop đang chọn" Command="{Binding CancelSelectedCommand}"
                                            Style="{StaticResource DangerButton}" Margin="12,0,0,0"
                                            Visibility="{Binding HasCancelableWork, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Style="{StaticResource SpinnerText}"
                                               Visibility="{Binding CancelBusy, Converter={StaticResource BoolToVis}}">
                                        <TextBlock.RenderTransform><RotateTransform Angle="0" /></TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Text="{Binding ActionStatus}" Margin="0,12,0,0" TextWrapping="Wrap"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <!-- Nâng cao: Hub TỰ giao việc theo vai trò (ẩn mặc định — đa số chỉ cần Giao tay ở trên).
                             Đặt trạng thái thủ công giờ nằm ngay trên lưới (selectbox mỗi ô op ở Bước 1). -->
                        <Expander Grid.Row="2" Margin="0,10,0,0" Header="⚙  Nâng cao — để Hub tự giao việc theo vai trò">
                            <StackPanel Margin="0,8,0,0">
                                <Border Background="{StaticResource SubtleBrush}" CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                                    <WrapPanel Orientation="Horizontal">
                                        <TextBlock Text="Chế độ:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />
                                        <RadioButton Content="Tự theo vai trò" IsChecked="{Binding AutoMode}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <RadioButton Content="Thủ công" IsChecked="{Binding ManualMode}" VerticalAlignment="Center" Margin="0,0,16,0" />
                                        <Button Content="{Binding DispatchButtonText}" Command="{Binding ToggleDispatchCommand}"
                                                Style="{StaticResource PrimaryButton}" MinWidth="160" Margin="0,0,16,0" />
                                        <CheckBox Content="Tự đồng bộ workbook/cookie khi bàn giao (xuyên máy)" IsChecked="{Binding AutoSyncHandoff}"
                                                  VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </WrapPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Padding="0">
                                    <StackPanel>
                                        <TextBlock Text="Vai trò máy" Style="{StaticResource H2}" Margin="12,10,12,2" />
                                        <TextBlock Text="Gán mỗi máy 1 loại việc — Hub tự đẩy đúng loại cho máy đó (Mọi việc = nhận tất)."
                                                   Style="{StaticResource Caption}" Margin="12,0,12,6" />
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="190">
                                            <ItemsControl ItemsSource="{Binding MachineRows}" Margin="0,0,0,8">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="12,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="30" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="200" />
                                                                <ColumnDefinition Width="170" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Dot}" VerticalAlignment="Center" FontSize="14" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="2" Text="{Binding Online}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                            <ComboBox Grid.Column="3" ItemsSource="{Binding RoleOptions}"
                                                                      SelectedItem="{Binding Role, Mode=TwoWay}" Margin="0,2" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Expander>
                    </Grid>

                    <!-- ───── Bản CLIENT: việc của máy này ───── -->
                    <Grid Visibility="{Binding IsClientPanel, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource SubtleBrush}" CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ReceiveStateText}" FontWeight="SemiBold" FontSize="13.5" />
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,3,0,0" TextWrapping="Wrap">
                                        <Run Text="Vai trò Hub đặt: " /><Run Text="{Binding MyRole}" FontWeight="SemiBold" /><Run Text="   ·   Việc &quot;Giao tay&quot; (ghim) thì máy chạy dù chưa có vai trò." />
                                    </TextBlock>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="180" Margin="12,0,0,0"
                                        Content="{Binding ReceiveToggleText}" Command="{Binding ToggleReceiveCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        ToolTip="Bật/tắt nhận việc Hub giao. Đang nhận = máy tự chạy khi có việc." />
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" ClipToBounds="True">
                            <DataGrid ItemsSource="{Binding MyJobs}" AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Việc" Binding="{Binding Op}" Width="110" />
                                    <DataGridTextColumn Header="Tài khoản" Binding="{Binding AccountLabel}" Width="*" />
                                    <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="*" />
                                    <DataGridTextColumn Header="Dòng (Hub giao)" Binding="{Binding Rows}" Width="120" />
                                    <DataGridTemplateColumn Header="Trạng thái" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StateText}" Foreground="{Binding StateBrush}" FontWeight="SemiBold" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <TextBlock Grid.Row="2" Margin="2,8,0,0" Style="{StaticResource Caption}" TextWrapping="Wrap"
                                   Text="Mẹo: muốn máy này dừng nhận việc mới (để chạy tay) thì bấm nút ở trên cùng." />
                    </Grid>

                    <!-- ───── Chưa bật đồng bộ ───── -->
                    <TextBlock Visibility="{Binding IsCoordOff, Converter={StaticResource BoolToVis}}"
                               Margin="0,48,0,0" HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                               Text="Chưa bật đồng bộ Hub trên máy này.&#x0a;Vào Cài đặt → Đồng bộ nhiều máy để chọn vai trò Client hoặc bật Hub." />
                </Grid>
            </TabItem>

            <!-- ════════════ TAB 3: SEARCH (ĐA MÁY) ════════════ -->
            <TabItem Header="Search (đa máy)">
                <Grid Margin="0,12,0,0">

                    <!-- ───── Bản HUB: 2 tab con — ① Cấu hình & Máy | ② Kết quả (status luôn ở đáy) ───── -->
                    <DockPanel Visibility="{Binding IsHubBoard, Converter={StaticResource BoolToVis}}">
                        <TextBlock DockPanel.Dock="Bottom" Text="{Binding SearchActionStatus}" Margin="2,8,0,0"
                                   FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TabControl Background="Transparent" BorderThickness="0">

                            <!-- ① CẤU HÌNH & MÁY -->
                            <TabItem Header="①  Cấu hình &amp; Máy">
                                <Grid Margin="0,10,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="1.3*" />
                                        <RowDefinition Height="1*" />
                                    </Grid.RowDefinitions>

                                    <!-- Bước 1 + cấu hình chia khối -->
                                    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="18,16" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Bước 1 — chọn file link category (.txt mỗi dòng 1 link) để chia cho các máy"
                                                       Style="{StaticResource Caption}" />
                                            <Grid Margin="0,4,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Text="{Binding SearchFileDisplay}" IsReadOnly="True"
                                                         FontSize="11.5" VerticalContentAlignment="Center" />
                                                <Button Grid.Column="1" Content="📂  Chọn file" Margin="8,0,0,0" Command="{Binding ChooseSearchFileCommand}" />
                                            </Grid>

                                            <WrapPanel Orientation="Horizontal">
                                                <StackPanel Margin="0,0,16,0">
                                                    <TextBlock Text="Số acc khóa/máy" Style="{StaticResource Caption}" />
                                                    <TextBox Width="70" Margin="0,4,0,0" Text="{Binding AccountsPerClient}" VerticalContentAlignment="Center"
                                                             ToolTip="Mỗi máy khóa tối đa ngần này tài khoản Shopee (máy khác không đụng)." />
                                                </StackPanel>
                                                <StackPanel Margin="0,0,16,0">
                                                    <TextBlock Text="Lane" Style="{StaticResource Caption}" />
                                                    <TextBox Width="56" Margin="0,4,0,0" Text="{Binding SearchLanes}" VerticalContentAlignment="Center"
                                                             ToolTip="Số tab/cửa sổ chạy song song trên mỗi máy." />
                                                </StackPanel>
                                                <StackPanel Margin="0,0,16,0">
                                                    <TextBlock Text="Khu vực (Nơi Bán)" Style="{StaticResource Caption}" />
                                                    <TextBox Width="160" Margin="0,4,0,0" Text="{Binding SearchRegion}" VerticalContentAlignment="Center" />
                                                </StackPanel>
                                            </WrapPanel>
                                            <TextBlock Text="{Binding SearchSummary}" FontWeight="SemiBold" Margin="0,12,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Danh sách link: checkbox chọn/bỏ (mặc định tick hết) -->
                                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                                        <DockPanel>
                                            <Grid DockPanel.Dock="Top" Margin="12,10,12,6">
                                                <TextBlock Text="Chọn link để search (mặc định tick hết — bỏ tick thì tính lại số link + chia lại)"
                                                           Style="{StaticResource H2}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Button Content="Tất cả" MinWidth="66" Command="{Binding SelectAllLinksCommand}" />
                                                    <Button Content="Bỏ hết" MinWidth="66" Margin="6,0,0,0" Command="{Binding UnselectAllLinksCommand}" />
                                                </StackPanel>
                                            </Grid>
                                            <ListBox ItemsSource="{Binding SearchLinkRows}" BorderThickness="0" Background="Transparent"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="12,2" VerticalContentAlignment="Center">
                                                            <TextBlock Text="{Binding Link}" TextTrimming="CharacterEllipsis" />
                                                        </CheckBox>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </DockPanel>
                                    </Border>

                                    <!-- Bước 2: danh sách máy — bấm Chạy ở máy nào thì máy đó nhận phần link của nó -->
                                    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" ClipToBounds="True" Margin="0,10,0,0">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Top"
                                                       Text="Bước 2 — bỏ tick máy nào để KHÔNG dùng (link tự chia lại cho các máy còn lại). Bấm ▶ Chạy ở máy nào thì máy đó chạy đúng phần link của nó (khóa acc trước khi chạy)."
                                                       Style="{StaticResource H2}" Margin="12,10,12,6" TextWrapping="Wrap" />
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding SearchClients}" Margin="0,0,0,8">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="12,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="34" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="220" />
                                                                    <ColumnDefinition Width="170" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center"
                                                                          ToolTip="Bỏ tick để không dùng máy này (link chia lại cho các máy còn lại)." />
                                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="2" Text="{Binding StateText}" Foreground="{Binding StateBrush}"
                                                                           FontWeight="SemiBold" VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="3" Text="{Binding RangeLabel}" Foreground="{StaticResource TextSecondaryBrush}"
                                                                           VerticalAlignment="Center" />
                                                                <StackPanel Grid.Column="4" Orientation="Horizontal">
                                                                    <Button Content="▶  Chạy" MinWidth="92" Style="{StaticResource SuccessButton}"
                                                                            Command="{Binding DataContext.RunSearchForClientCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}" />
                                                                    <TextBlock Style="{StaticResource SpinnerText}"
                                                                               Visibility="{Binding PendingRun, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock.RenderTransform><RotateTransform Angle="0" /></TextBlock.RenderTransform>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- ② KẾT QUẢ: kho gộp + lọc/xuất Excel -->
                            <TabItem Header="②  Kết quả">
                                <Grid Margin="0,10,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Kho gộp: các client đẩy kết quả về Hub → xuất 1 Excel gộp -->
                                    <Border Grid.Row="0" Background="{StaticResource SubtleBrush}" CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                                        <Grid>
                                            <TextBlock Text="{Binding MergedProductText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="📦  Xuất Excel gộp (tất cả máy)" Command="{Binding ExportMergedCommand}"
                                                        Style="{StaticResource PrimaryButton}" MinWidth="210" />
                                                <Button Content="🗑  Xóa kho gộp" Command="{Binding ClearMergedCommand}"
                                                        Style="{StaticResource DangerButton}" Margin="8,0,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Kết quả gộp về Hub — lưới cập nhật liên tục -->
                                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                                        <DockPanel>
                                            <Grid DockPanel.Dock="Top" Margin="12,10,12,6">
                                                <TextBlock Text="Kết quả gộp về Hub (tự cập nhật khi client đẩy về)"
                                                           Style="{StaticResource H2}" VerticalAlignment="Center" />
                                                <Button HorizontalAlignment="Right" Content="⟳  Làm mới" MinWidth="96"
                                                        Command="{Binding RefreshMergedCommand}" />
                                            </Grid>
                                            <DataGrid ItemsSource="{Binding MergedProducts}" AutoGenerateColumns="False" IsReadOnly="True"
                                                      HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                                      EnableRowVirtualization="True" BorderThickness="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding Name}" Width="2.4*" />
                                                    <DataGridTextColumn Header="Giá" Binding="{Binding Price}" Width="90" />
                                                    <DataGridTextColumn Header="Bán/tháng" Binding="{Binding MonthlySold}" Width="90" />
                                                    <DataGridTextColumn Header="Rating" Binding="{Binding Rating}" Width="70" />
                                                    <DataGridTextColumn Header="Danh mục" Binding="{Binding Category}" Width="1.2*" />
                                                    <DataGridTextColumn Header="Khu vực" Binding="{Binding ShopLocation}" Width="1*" />
                                                    <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="1*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </DockPanel>

                    <!-- ───── Bản CLIENT: việc search xem ở tab Giao việc ───── -->
                    <TextBlock Visibility="{Binding IsClientPanel, Converter={StaticResource BoolToVis}}"
                               Margin="0,48,0,0" HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                               Text="Bảng chia link Search chỉ hiển thị trên máy Hub.&#x0a;Việc Search mà Hub giao cho máy này sẽ chạy tự động và hiện ở tab “Giao việc” (mục Việc của máy này)." />

                    <!-- ───── Chưa bật đồng bộ ───── -->
                    <TextBlock Visibility="{Binding IsCoordOff, Converter={StaticResource BoolToVis}}"
                               Margin="0,48,0,0" HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                               Text="Chưa bật đồng bộ Hub trên máy này.&#x0a;Vào Cài đặt → Đồng bộ nhiều máy để bật Hub." />
                </Grid>
            </TabItem>

            <!-- ══════════ TAB LOG (nhật ký nhiều máy gửi về Hub) ══════════ -->
            <TabItem Header="Log">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="🗑  Xoá log" Command="{Binding ClearLogsCommand}"
                                Style="{StaticResource DangerButton}" />
                        <TextBlock VerticalAlignment="Center" Style="{StaticResource Caption}"
                                   Text="Nhật ký từ tất cả các máy (client gửi về Hub) — mới nhất ở trên." />
                    </DockPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Logs}" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserAddRows="False"
                              Background="Transparent" BorderThickness="0" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Thời gian" Binding="{Binding Time}" Width="90" />
                            <DataGridTextColumn Header="Máy" Binding="{Binding Machine}" Width="150" />
                            <DataGridTextColumn Header="Nội dung" Binding="{Binding Text}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding Brush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
