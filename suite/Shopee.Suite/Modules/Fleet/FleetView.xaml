<UserControl
    x:Class="Shopee.Suite.Modules.Fleet.FleetView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Icon ⟳ xoay liên tục khi nút đang chạy: Visibility=Visible (IsRunning) → spin; Collapsed → dừng.
             RenderTransform đặt INLINE trên từng spinner (tránh chia sẻ Freezable khi animate). -->
        <Style x:Key="SpinnerText" TargetType="TextBlock">
            <Setter Property="Text" Value="⟳" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard x:Name="SpinSb">
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                    From="0" To="360" Duration="0:0:0.8" RepeatBehavior="Forever" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="SpinSb" />
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="28,22,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Trạng thái &amp; Giao việc" Style="{StaticResource H1}" />
                <TextBlock Text="Theo dõi máy + Hub giao việc cho từng máy (scrape · import · update theo dây chuyền)."
                           Style="{StaticResource Caption}" Margin="0,3,0,0" />
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="110"
                    Content="⟳  Làm mới" Command="{Binding RefreshCommand}" />
        </Grid>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- ════════════ TAB 1: THEO DÕI ════════════ -->
            <TabItem Header="Theo dõi">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource SubtleBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{Binding Machines}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Status}" Style="{StaticResource Caption}" Margin="0,4,0,8" />
                            <CheckBox Content="⚠ Chạy đè: bỏ qua khoá của máy khác ở các lượt chạy tới (chỉ bật khi chắc máy kia đã dừng)"
                                      IsChecked="{Binding ForceNextRun}" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource Card}" ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Máy" Binding="{Binding MachineName}" Width="170" />
                                <DataGridTextColumn Header="Tài khoản" Binding="{Binding AccountLabel}" Width="*" />
                                <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="*" />
                                <DataGridTextColumn Header="Việc" Binding="{Binding Op}" Width="100" />
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding State}" Width="140" />
                                <DataGridTextColumn Header="Cập nhật" Binding="{Binding Updated}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════ TAB 2: GIAO VIỆC ════════════ -->
            <TabItem Header="Giao việc">
                <Grid Margin="0,12,0,0">

                    <!-- ───── Bản HUB: bảng điều phối ───── -->
                    <Grid Visibility="{Binding IsHubBoard, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Bước 1: Hàng đợi việc — chọn 1 shop để giao -->
                        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Bước 1 — bấm chọn 1 shop trong bảng (mỗi dòng = 1 shop)"
                                           Style="{StaticResource H2}" Margin="12,10,12,6" />
                                <DataGrid ItemsSource="{Binding Queue}" SelectedItem="{Binding SelectedQueue}"
                                          AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                          CanUserAddRows="False" GridLinesVisibility="None" SelectionMode="Single">
                                    <!-- Gộp theo tài khoản: kẻ vạch phân nhóm ở dòng shop ĐẦU của mỗi tk -->
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAccountFirstRow}" Value="True">
                                                    <Setter Property="BorderThickness" Value="0,1,0,0" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tài khoản" Binding="{Binding AccountLabel}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="*" />
                                        <DataGridTemplateColumn Header="Scrape" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ScrapeText}" Foreground="{Binding ScrapeBrush}" FontWeight="SemiBold" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Import" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ImportText}" Foreground="{Binding ImportBrush}" FontWeight="SemiBold" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Update" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding UpdateText}" Foreground="{Binding UpdateBrush}" FontWeight="SemiBold" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Kế tiếp" Binding="{Binding NextOpText}" Width="140" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Bước 2: Giao việc cho 1 máy (LUỒNG CHÍNH — thủ công) -->
                        <Border Grid.Row="1" Background="{StaticResource SubtleBrush}" CornerRadius="8" Padding="12,10" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Bước 2 — giao việc cho 1 máy" Style="{StaticResource H2}" Margin="0,0,0,8" />
                                <WrapPanel Orientation="Horizontal">
                                    <TextBlock Text="Việc" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />
                                    <ComboBox ItemsSource="{Binding PinOps}" SelectedItem="{Binding PinOp}" Width="120" Margin="0,0,8,0" />
                                    <TextBlock Text="cho máy" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox ItemsSource="{Binding MachineRows}" SelectedItem="{Binding PinMachine}"
                                              DisplayMemberPath="Name" Width="200" Margin="0,0,12,0" />
                                    <TextBlock Text="dòng" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBox Width="58" Margin="0,0,4,0" VerticalContentAlignment="Center"
                                             Text="{Binding PinStartRow}" ToolTip="Từ dòng (0 = để client dùng cấu hình của nó)" />
                                    <TextBlock Text="→" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <TextBox Width="58" Margin="0,0,12,0" VerticalContentAlignment="Center"
                                             Text="{Binding PinEndRow}" ToolTip="Đến dòng (0 = hết)" />
                                    <Button Content="📌  Ghim cho máy này" Command="{Binding AssignManualCommand}"
                                            Style="{StaticResource SuccessButton}" Margin="0,0,8,0" />
                                    <TextBlock Style="{StaticResource SpinnerText}"
                                               Visibility="{Binding PinBusy, Converter={StaticResource BoolToVis}}">
                                        <TextBlock.RenderTransform><RotateTransform Angle="0" /></TextBlock.RenderTransform>
                                    </TextBlock>
                                    <Button Content="✖  Huỷ việc của shop đang chọn" Command="{Binding CancelSelectedCommand}"
                                            Style="{StaticResource DangerButton}" Margin="8,0,0,0" />
                                    <TextBlock Style="{StaticResource SpinnerText}"
                                               Visibility="{Binding CancelBusy, Converter={StaticResource BoolToVis}}">
                                        <TextBlock.RenderTransform><RotateTransform Angle="0" /></TextBlock.RenderTransform>
                                    </TextBlock>
                                </WrapPanel>
                                <TextBlock Text="{Binding ActionStatus}" Margin="0,8,0,0" TextWrapping="Wrap"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <!-- Bước 3: Đặt trạng thái thủ công cho shop đang chọn (scrape auto vẫn chạy; đặt tay đè được) -->
                        <Border Grid.Row="2" Background="{StaticResource SubtleBrush}" CornerRadius="8" Padding="12,10" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Bước 3 — đặt trạng thái thủ công (shop đang chọn)" Style="{StaticResource H2}" Margin="0,0,0,2" />
                                <TextBlock Text="✓ Xong = đánh dấu đã xong · Chưa = reset (scrape sẽ giao + chạy lại từ đầu) · ■ Dừng = đánh dấu dừng dở"
                                           Style="{StaticResource Caption}" Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="78" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Scrape" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,3">
                                        <Button Content="✓ Xong" Command="{Binding SetStateCommand}" CommandParameter="scrape:completed" Margin="0,0,6,0" />
                                        <Button Content="Chưa" Command="{Binding SetStateCommand}" CommandParameter="scrape:idle" Margin="0,0,6,0" />
                                        <Button Content="■ Dừng" Command="{Binding SetStateCommand}" CommandParameter="scrape:stopped" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Import" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,3">
                                        <Button Content="✓ Xong" Command="{Binding SetStateCommand}" CommandParameter="import:completed" Margin="0,0,6,0" />
                                        <Button Content="Chưa" Command="{Binding SetStateCommand}" CommandParameter="import:idle" Margin="0,0,6,0" />
                                        <Button Content="■ Dừng" Command="{Binding SetStateCommand}" CommandParameter="import:stopped" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Update" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,3">
                                        <Button Content="✓ Xong" Command="{Binding SetStateCommand}" CommandParameter="update:completed" Margin="0,0,6,0" />
                                        <Button Content="Chưa" Command="{Binding SetStateCommand}" CommandParameter="update:idle" Margin="0,0,6,0" />
                                        <Button Content="■ Dừng" Command="{Binding SetStateCommand}" CommandParameter="update:stopped" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Nâng cao: Hub TỰ giao việc theo vai trò (ẩn mặc định — đa số chỉ cần Giao tay ở trên) -->
                        <Expander Grid.Row="3" Margin="0,10,0,0" Header="⚙  Nâng cao — để Hub tự giao việc theo vai trò">
                            <StackPanel Margin="0,8,0,0">
                                <Border Background="{StaticResource SubtleBrush}" CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                                    <WrapPanel Orientation="Horizontal">
                                        <TextBlock Text="Chế độ:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />
                                        <RadioButton Content="Tự theo vai trò" IsChecked="{Binding AutoMode}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <RadioButton Content="Thủ công" IsChecked="{Binding ManualMode}" VerticalAlignment="Center" Margin="0,0,16,0" />
                                        <Button Content="{Binding DispatchButtonText}" Command="{Binding ToggleDispatchCommand}"
                                                Style="{StaticResource PrimaryButton}" MinWidth="160" Margin="0,0,16,0" />
                                        <CheckBox Content="Tự đồng bộ workbook/cookie khi bàn giao (xuyên máy)" IsChecked="{Binding AutoSyncHandoff}"
                                                  VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </WrapPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Padding="0">
                                    <StackPanel>
                                        <TextBlock Text="Vai trò máy" Style="{StaticResource H2}" Margin="12,10,12,2" />
                                        <TextBlock Text="Gán mỗi máy 1 loại việc — Hub tự đẩy đúng loại cho máy đó (Mọi việc = nhận tất)."
                                                   Style="{StaticResource Caption}" Margin="12,0,12,6" />
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="190">
                                            <ItemsControl ItemsSource="{Binding MachineRows}" Margin="0,0,0,8">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="12,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="30" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="200" />
                                                                <ColumnDefinition Width="170" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Dot}" VerticalAlignment="Center" FontSize="14" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="2" Text="{Binding Online}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                            <ComboBox Grid.Column="3" ItemsSource="{Binding RoleOptions}"
                                                                      SelectedItem="{Binding Role, Mode=TwoWay}" Margin="0,2" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Expander>
                    </Grid>

                    <!-- ───── Bản CLIENT: việc của máy này ───── -->
                    <Grid Visibility="{Binding IsClientPanel, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource SubtleBrush}" CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ReceiveStateText}" FontWeight="SemiBold" FontSize="13.5" />
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,3,0,0" TextWrapping="Wrap">
                                        <Run Text="Vai trò Hub đặt: " /><Run Text="{Binding MyRole}" FontWeight="SemiBold" /><Run Text="   ·   Việc &quot;Giao tay&quot; (ghim) thì máy chạy dù chưa có vai trò." />
                                    </TextBlock>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center" MinWidth="180" Margin="12,0,0,0"
                                        Content="{Binding ReceiveToggleText}" Command="{Binding ToggleReceiveCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        ToolTip="Bật/tắt nhận việc Hub giao. Đang nhận = máy tự chạy khi có việc." />
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" ClipToBounds="True">
                            <DataGrid ItemsSource="{Binding MyJobs}" AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Việc" Binding="{Binding Op}" Width="110" />
                                    <DataGridTextColumn Header="Tài khoản" Binding="{Binding AccountLabel}" Width="*" />
                                    <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="*" />
                                    <DataGridTextColumn Header="Dòng (Hub giao)" Binding="{Binding Rows}" Width="120" />
                                    <DataGridTemplateColumn Header="Trạng thái" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StateText}" Foreground="{Binding StateBrush}" FontWeight="SemiBold" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <TextBlock Grid.Row="2" Margin="2,8,0,0" Style="{StaticResource Caption}" TextWrapping="Wrap"
                                   Text="Mẹo: muốn máy này dừng nhận việc mới (để chạy tay) thì bấm nút ở trên cùng." />
                    </Grid>

                    <!-- ───── Chưa bật đồng bộ ───── -->
                    <TextBlock Visibility="{Binding IsCoordOff, Converter={StaticResource BoolToVis}}"
                               Margin="0,48,0,0" HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                               Text="Chưa bật đồng bộ Hub trên máy này.&#x0a;Vào Cài đặt → Đồng bộ nhiều máy để chọn vai trò Client hoặc bật Hub." />
                </Grid>
            </TabItem>

            <!-- ════════════ TAB 3: SEARCH (ĐA MÁY) ════════════ -->
            <TabItem Header="Search (đa máy)">
                <Grid Margin="0,12,0,0">

                    <!-- ───── Bản HUB: chia link + giao từng máy ───── -->
                    <Grid Visibility="{Binding IsHubBoard, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="0.9*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="1.4*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Bước 1 + cấu hình chia khối -->
                        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="18,16" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Bước 1 — chọn file link category (.txt mỗi dòng 1 link) để chia cho các máy"
                                           Style="{StaticResource Caption}" />
                                <Grid Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding SearchFileDisplay}" IsReadOnly="True"
                                             FontSize="11.5" VerticalContentAlignment="Center" />
                                    <Button Grid.Column="1" Content="📂  Chọn file" Margin="8,0,0,0" Command="{Binding ChooseSearchFileCommand}" />
                                </Grid>

                                <WrapPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="Số acc khóa/máy" Style="{StaticResource Caption}" />
                                        <TextBox Width="70" Margin="0,4,0,0" Text="{Binding AccountsPerClient}" VerticalContentAlignment="Center"
                                                 ToolTip="Mỗi máy khóa tối đa ngần này tài khoản Shopee (máy khác không đụng)." />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="Lane" Style="{StaticResource Caption}" />
                                        <TextBox Width="56" Margin="0,4,0,0" Text="{Binding SearchLanes}" VerticalContentAlignment="Center"
                                                 ToolTip="Số tab/cửa sổ chạy song song trên mỗi máy." />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="Khu vực (Nơi Bán)" Style="{StaticResource Caption}" />
                                        <TextBox Width="160" Margin="0,4,0,0" Text="{Binding SearchRegion}" VerticalContentAlignment="Center" />
                                    </StackPanel>
                                </WrapPanel>
                                <TextBlock Text="{Binding SearchSummary}" FontWeight="SemiBold" Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Bước 2: danh sách máy — bấm Chạy ở máy nào thì máy đó nhận KHỐI KẾ tiếp -->
                        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="Bước 2 — bỏ tick máy nào để KHÔNG dùng (link tự chia lại cho các máy còn lại). Bấm ▶ Chạy ở máy nào thì máy đó chạy đúng phần link của nó (khóa acc trước khi chạy)."
                                           Style="{StaticResource H2}" Margin="12,10,12,6" TextWrapping="Wrap" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SearchClients}" Margin="0,0,0,8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="12,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="34" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="220" />
                                                        <ColumnDefinition Width="170" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center"
                                                              ToolTip="Bỏ tick để không dùng máy này (link chia lại cho các máy còn lại)." />
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Text="{Binding StateText}" Foreground="{Binding StateBrush}"
                                                               FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="3" Text="{Binding RangeLabel}" Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                                                        <Button Content="▶  Chạy" MinWidth="92" Style="{StaticResource SuccessButton}"
                                                                Command="{Binding DataContext.RunSearchForClientCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" />
                                                        <TextBlock Style="{StaticResource SpinnerText}"
                                                                   Visibility="{Binding PendingRun, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock.RenderTransform><RotateTransform Angle="0" /></TextBlock.RenderTransform>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <!-- Kho gộp: các client đẩy kết quả về Hub → xuất 1 Excel gộp -->
                        <Border Grid.Row="2" Background="{StaticResource SubtleBrush}" CornerRadius="8" Padding="12,10" Margin="0,10,0,0">
                            <Grid>
                                <TextBlock Text="{Binding MergedProductText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="📦  Xuất Excel gộp (tất cả máy)" Command="{Binding ExportMergedCommand}"
                                            Style="{StaticResource PrimaryButton}" MinWidth="210" />
                                    <Button Content="🗑  Xóa kho gộp" Command="{Binding ClearMergedCommand}"
                                            Style="{StaticResource DangerButton}" Margin="8,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Kết quả gộp về Hub — lưới cập nhật liên tục (như bảng sản phẩm tab Search cũ) -->
                        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" ClipToBounds="True" Margin="0,10,0,0">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="12,10,12,6">
                                    <TextBlock Text="Kết quả gộp về Hub (tự cập nhật khi client đẩy về)"
                                               Style="{StaticResource H2}" VerticalAlignment="Center" />
                                    <Button HorizontalAlignment="Right" Content="⟳  Làm mới" MinWidth="96"
                                            Command="{Binding RefreshMergedCommand}" />
                                </Grid>
                                <DataGrid ItemsSource="{Binding MergedProducts}" AutoGenerateColumns="False" IsReadOnly="True"
                                          HeadersVisibility="Column" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                          EnableRowVirtualization="True" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding Name}" Width="2.4*" />
                                        <DataGridTextColumn Header="Giá" Binding="{Binding Price}" Width="90" />
                                        <DataGridTextColumn Header="Bán/tháng" Binding="{Binding MonthlySold}" Width="90" />
                                        <DataGridTextColumn Header="Rating" Binding="{Binding Rating}" Width="70" />
                                        <DataGridTextColumn Header="Danh mục" Binding="{Binding Category}" Width="1.2*" />
                                        <DataGridTextColumn Header="Khu vực" Binding="{Binding ShopLocation}" Width="1*" />
                                        <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="1*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <TextBlock Grid.Row="4" Text="{Binding SearchActionStatus}" Margin="2,10,0,0"
                                   FontWeight="SemiBold" TextWrapping="Wrap" />
                    </Grid>

                    <!-- ───── Bản CLIENT: việc search xem ở tab Giao việc ───── -->
                    <TextBlock Visibility="{Binding IsClientPanel, Converter={StaticResource BoolToVis}}"
                               Margin="0,48,0,0" HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                               Text="Bảng chia link Search chỉ hiển thị trên máy Hub.&#x0a;Việc Search mà Hub giao cho máy này sẽ chạy tự động và hiện ở tab “Giao việc” (mục Việc của máy này)." />

                    <!-- ───── Chưa bật đồng bộ ───── -->
                    <TextBlock Visibility="{Binding IsCoordOff, Converter={StaticResource BoolToVis}}"
                               Margin="0,48,0,0" HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                               Text="Chưa bật đồng bộ Hub trên máy này.&#x0a;Vào Cài đặt → Đồng bộ nhiều máy để bật Hub." />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
