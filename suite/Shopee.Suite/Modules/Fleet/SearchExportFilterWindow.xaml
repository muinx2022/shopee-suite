<Window
    x:Class="Shopee.Suite.Modules.Fleet.SearchExportFilterWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Xuất Excel gộp — bộ lọc" Height="330" Width="460"
    WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
    Background="{StaticResource WindowBackgroundBrush}"
    FontFamily="{StaticResource UiFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource Caption}" Margin="0,0,0,12"
                   Text="Chọn bộ lọc rồi bấm Xuất — chỉ các sản phẩm khớp mới được đưa vào file Excel gộp." TextWrapping="Wrap" />

        <!-- Giá / Đã bán -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Giá ≥" Style="{StaticResource Caption}" />
                <TextBox x:Name="MinPriceBox" Width="130" Margin="0,4,0,0" Text="0" VerticalContentAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Bán/tháng từ" Style="{StaticResource Caption}" />
                <TextBox x:Name="MinSoldFromBox" Width="100" Margin="0,4,0,0" Text="0" VerticalContentAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock Text="đến" Style="{StaticResource Caption}" />
                <TextBox x:Name="MinSoldToBox" Width="100" Margin="0,4,0,0" Text="0" VerticalContentAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Danh mục -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Danh mục" Style="{StaticResource Caption}" />
            <ComboBox x:Name="CategoryBox" Margin="0,4,0,0" />
        </StackPanel>

        <TextBlock Grid.Row="3" VerticalAlignment="Bottom" Style="{StaticResource Caption}" TextWrapping="Wrap"
                   Text="Để 0 = không giới hạn. Danh mục = (Tất cả) để lấy hết." />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" MinWidth="90" IsCancel="True" Click="OnCancel" />
            <Button Style="{StaticResource PrimaryButton}" Content="📦  Xuất" MinWidth="120"
                    Margin="10,0,0,0" IsDefault="True" Click="OnOk" />
        </StackPanel>
    </Grid>
</Window>
