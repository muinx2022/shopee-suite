<Window
    x:Class="Shopee.Suite.MessageDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize" ShowInTaskbar="False" WindowStyle="SingleBorderWindow"
    MinWidth="360" MaxWidth="560"
    Background="{StaticResource WindowBackgroundBrush}" FontFamily="{StaticResource UiFont}">
    <StackPanel Margin="24,22,24,18">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="IconText" FontSize="26" Margin="0,0,16,0" VerticalAlignment="Top" />
            <TextBlock x:Name="MessageText" TextWrapping="Wrap" MaxWidth="430" FontSize="13.5"
                       LineHeight="20" VerticalAlignment="Center"
                       Foreground="{StaticResource TextPrimaryBrush}" />
        </StackPanel>
        <StackPanel x:Name="Buttons" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0" />
    </StackPanel>
</Window>
