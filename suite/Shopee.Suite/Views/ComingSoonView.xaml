<UserControl
    x:Class="Shopee.Suite.Views.ComingSoonView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="32">
        <Border Style="{StaticResource Card}" Padding="48" HorizontalAlignment="Center"
                VerticalAlignment="Center" MaxWidth="560">
            <StackPanel HorizontalAlignment="Center">
                <Border Width="64" Height="64" CornerRadius="16" Background="{StaticResource SubtleBrush}"
                        HorizontalAlignment="Center">
                    <TextBlock Text="🚧" FontFamily="Segoe UI Emoji" FontSize="30"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding Title}" Style="{StaticResource H1}"
                           HorizontalAlignment="Center" Margin="0,20,0,0" />
                <Border Background="{StaticResource SubtleBrush}" CornerRadius="12" Padding="10,4" Margin="0,10,0,0"
                        HorizontalAlignment="Center">
                    <TextBlock Text="Sắp có" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />
                </Border>
                <TextBlock Text="{Binding Description}" Style="{StaticResource Body}"
                           Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center"
                           Margin="0,16,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
