<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Shopee.Suite.Views.ComingSoonView">
    <Grid Margin="32">
        <Border Classes="card" Padding="48" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560">
            <StackPanel HorizontalAlignment="Center">
                <Border Width="64" Height="64" CornerRadius="16" Background="{DynamicResource SubtleBrush}"
                        HorizontalAlignment="Center">
                    <TextBlock Classes="emoji" Text="🚧" FontSize="30"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Classes="h1" Text="{Binding Title}" HorizontalAlignment="Center" Margin="0,20,0,0" />
                <Border Background="{DynamicResource SubtleBrush}" CornerRadius="12" Padding="10,4" Margin="0,10,0,0"
                        HorizontalAlignment="Center">
                    <TextBlock Text="Sắp có" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}" />
                </Border>
                <TextBlock Classes="body" Text="{Binding Description}"
                           Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Center" Margin="0,16,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
