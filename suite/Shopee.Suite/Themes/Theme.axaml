<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="using:System">

    <Styles.Resources>
        <!-- ══════════ COLOR / BRUSH TOKENS ══════════ -->
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D7" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#106EBE" />
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#005A9E" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#00783C" />
        <SolidColorBrush x:Key="SuccessHoverBrush" Color="#06632F" />
        <SolidColorBrush x:Key="DangerBrush" Color="#C8463C" />
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#B23A31" />
        <SolidColorBrush x:Key="WarningBrush" Color="#C88200" />

        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F7FA" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D7D9DE" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#EEF1F5" />

        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1E2230" />
        <SolidColorBrush x:Key="SidebarHeaderBrush" Color="#161925" />
        <SolidColorBrush x:Key="SidebarItemHoverBrush" Color="#2A3042" />
        <SolidColorBrush x:Key="SidebarSelectedBrush" Color="#2A3042" />
        <SolidColorBrush x:Key="SidebarTextBrush" Color="#C7CCD6" />
        <SolidColorBrush x:Key="SidebarMutedBrush" Color="#7E869B" />

        <SolidColorBrush x:Key="LogBackgroundBrush" Color="#121212" />
        <SolidColorBrush x:Key="LogForegroundBrush" Color="#E8E8E8" />

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1B1F24" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6E727A" />
        <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFF" />

        <!-- ══════════ FONTS ══════════ -->
        <!-- Inter nhúng (phủ tiếng Việt, giống hệt Win/Ubuntu). Mono cho log/list; Emoji cho icon chuỗi. -->
        <FontFamily x:Key="UiFont">avares://Avalonia.Fonts.Inter/Assets#Inter</FontFamily>
        <FontFamily x:Key="MonoFont">Consolas, Cascadia Mono, DejaVu Sans Mono, Liberation Mono, monospace</FontFamily>
        <FontFamily x:Key="EmojiFont">Segoe UI Emoji, Noto Color Emoji, sans-serif</FontFamily>

        <!-- ══════════ RESKIN FLUENTTHEME → look phẳng/gọn/pro như bản WPF ══════════ -->
        <!-- Accent xanh của app (tab đang chọn, viền focus, highlight…). -->
        <Color x:Key="SystemAccentColor">#0078D7</Color>
        <Color x:Key="SystemAccentColorLight1">#1C86E0</Color>
        <Color x:Key="SystemAccentColorDark1">#106EBE</Color>
        <!-- Bo góc chung cho control Fluent (TextBox/ComboBox/…) — Fluent mặc định hơi vuông. -->
        <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
        <!-- Tab: Fluent mặc định font header RẤT to (~24) → thu về gọn. (Chỉ override FontSize — các key khác
             sai kiểu/không tồn tại sẽ làm vỡ template TabControl → view trống.) -->
        <sys:Double x:Key="TabItemHeaderFontSize">13</sys:Double>
        <!-- Cỡ chữ nội dung control Fluent (button/textbox/combo/list/datagrid…) — nhỏ lại để hợp màn Full HD
             (bản trước hơi to; máy dev 4K nhìn khác). Fluent mặc định 14. -->
        <sys:Double x:Key="ControlContentThemeFontSize">12.5</sys:Double>

        <!-- Button PHẲNG bo góc (thay template Fluent) — nền thẻ + viền mảnh, hover đổi nền nhưng GIỮ màu chữ/viền
             của variant (primary/success/danger là outline: chữ+viền màu, không tô nền). Card (Welcome) bo tròn hơn. -->
        <ControlTheme x:Key="{x:Type Button}" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="13,6" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Foreground="{TemplateBinding Foreground}" Padding="{TemplateBinding Padding}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#PART_bd">
                <Setter Property="Background" Value="{DynamicResource SubtleBrush}" />
            </Style>
            <Style Selector="^:pressed /template/ Border#PART_bd">
                <Setter Property="Background" Value="{DynamicResource SubtleBrush}" />
                <Setter Property="Opacity" Value="0.9" />
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Opacity" Value="0.45" />
            </Style>
        </ControlTheme>
    </Styles.Resources>

    <!-- ══════════ TYPOGRAPHY (class) — cỡ chữ gọn cho Full HD ══════════ -->
    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.body">
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.caption">
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.emoji">
        <Setter Property="FontFamily" Value="{DynamicResource EmojiFont}" />
    </Style>

    <!-- ══════════ BUTTON variants (class) — outline: chữ + viền màu trên nền thẻ ══════════ -->
    <Style Selector="Button.primary">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.success">
        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.danger">
        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Thẻ bấm được (màn Welcome): bo tròn hơn, canh trái, hover viền accent + nền xanh nhạt. -->
    <Style Selector="Button.card">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="18,16" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.card:pointerover /template/ Border#PART_bd">
        <Setter Property="Background" Value="#F4F9FF" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <!-- ══════════ TEXTBOX variants (class) ══════════ -->
    <Style Selector="TextBox.mono">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>
    <Style Selector="TextBox.log">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource LogForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource LogBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>
    <!-- Giữ NỀN TỐI khi hover/focus: FluentTheme mặc định đổi nền TextBox sang sáng lúc pointerover/focus (đè
         nền tối của log) → chữ log sáng trở nên mờ trên nền sáng. Ép border-element giữ nền/chữ log. -->
    <Style Selector="TextBox.log /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource LogBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LogBackgroundBrush}" />
    </Style>
    <Style Selector="TextBox.log:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource LogBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LogBackgroundBrush}" />
    </Style>
    <Style Selector="TextBox.log:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource LogBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LogBackgroundBrush}" />
    </Style>
    <Style Selector="TextBox.log:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource LogForegroundBrush}" />
    </Style>
    <Style Selector="TextBox.log:focus">
        <Setter Property="Foreground" Value="{DynamicResource LogForegroundBrush}" />
    </Style>

    <!-- ══════════ CARD (class trên Border) ══════════ -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <!-- ══════════ DATAGRID ══════════ -->
    <!-- Canh giữa dọc nội dung ô (WPF căn giữa mặc định; Avalonia mặc định căn trên). -->
    <Style Selector="DataGridCell">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- ══════════ TOP NAV (ListBox.topnav) — tab module ngang trên app bar tối ══════════ -->
    <Style Selector="ListBox.topnav">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,0" />
    </Style>
    <Style Selector="ListBox.topnav ListBoxItem">
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="ListBox.topnav ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SidebarItemHoverBrush}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <!-- Tab đang chọn: nền accent + chữ trắng (Foreground truyền xuống các TextBlock không tự đặt màu). -->
    <Style Selector="ListBox.topnav ListBoxItem:selected">
        <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="ListBox.topnav ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="ListBox.topnav ListBoxItem:selected:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <!-- Màu chữ tab: xám sáng trên nền tối; tab đang chọn → trắng. Đặt TRỰC TIẾP lên TextBlock con
         (không set inline trong template) để thắng mọi setter mặc định của Fluent. Rule :selected phải
         đứng SAU rule nền để thắng theo thứ tự tài liệu (Avalonia ưu tiên rule khai báo sau khi cùng cấp). -->
    <Style Selector="ListBox.topnav ListBoxItem TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
    </Style>
    <Style Selector="ListBox.topnav ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Brand trên app bar tối: nút phẳng, nền trong suốt, hover tối nhẹ (dùng lại template Button toàn cục). -->
    <Style Selector="Button.brand">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="16,0" />
    </Style>
    <Style Selector="Button.brand:pointerover /template/ Border#PART_bd">
        <Setter Property="Background" Value="{DynamicResource SidebarHeaderBrush}" />
    </Style>
    <Style Selector="Button.brand:pressed /template/ Border#PART_bd">
        <Setter Property="Background" Value="{DynamicResource SidebarHeaderBrush}" />
    </Style>
</Styles>
